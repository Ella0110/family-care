page {
  --font-scale: 1;
  --font-xs: calc(20rpx * var(--font-scale));
  --font-sm: calc(24rpx * var(--font-scale));
  --font-base: calc(28rpx * var(--font-scale));
  --font-md: calc(32rpx * var(--font-scale));
  --font-lg: calc(40rpx * var(--font-scale));
  --font-xl: calc(48rpx * var(--font-scale));
  --font-2xl: calc(56rpx * var(--font-scale));
  --font-3xl: calc(64rpx * var(--font-scale));
  --font-4xl: calc(80rpx * var(--font-scale));
  --color-primary: #1d4ed8;
  --color-danger: #b42318;
  --color-text: #111827;
  --color-text-secondary: #4b5563;
  --color-bg: #f5f5f5;
  --color-card: #ffffff;

  min-height: 100%;
  font-size: var(--font-md);
  line-height: 1.6;
  color: var(--color-text);
  background: var(--color-bg);
}

.page-root {
  min-height: 100vh;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
  background: var(--color-bg);
  color: var(--color-text);
}

.card {
  box-sizing: border-box;
  padding: 32rpx;
  border-radius: 24rpx;
  background: var(--color-card);
  box-shadow: 0 12rpx 32rpx rgba(17, 24, 39, 0.08);
}

.btn-primary,
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  padding: 0 32rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  font-size: var(--font-lg);
  font-weight: 600;
}

.btn-primary {
  background: var(--color-primary);
  color: #ffffff;
}

.btn-secondary {
  background: var(--color-card);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}
