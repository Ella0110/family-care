page {
  --color-primary: #2563eb;
  --color-danger: #dc2626;
  --color-text: #111827;
  --color-text-secondary: #8E8E93;
  --color-bg: #eef4fe;
  --color-card: #ffffff;

  min-height: 100%;
  font-size: 32rpx;
  line-height: 1.6;
  color: var(--color-text);
  background: var(--color-bg);
}

.page-root {
  min-height: 100vh;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
  background: var(--color-bg);
  color: var(--color-text);
}

.card {
  box-sizing: border-box;
  padding: 48rpx;
  border-radius: 64rpx; 
  background: var(--color-card);
  box-shadow: 0 12rpx 32rpx rgba(17, 24, 39, 0.08);
}

.btn-primary,
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
  text-align: center;
}

.btn-primary {
  background: var(--color-primary);
  color: #ffffff;
}

.btn-secondary {
  background: var(--color-card);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}
