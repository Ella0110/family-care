page {
  --font-base: 32rpx;
  --font-lg: 40rpx;
  --font-xl: 48rpx;
  --color-primary: #1d4ed8;
  --color-danger: #b42318;
  --color-text: #111827;
  --color-text-secondary: #4b5563;
  --color-bg: #f5f5f5;
  --color-card: #ffffff;

  min-height: 100%;
  font-size: var(--font-base);
  line-height: 1.6;
  color: var(--color-text);
  background: var(--color-bg);
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
  background: var(--color-bg);
  color: var(--color-text);
}

.card {
  box-sizing: border-box;
  padding: 32rpx;
  border-radius: 24rpx;
  background: var(--color-card);
  box-shadow: 0 12rpx 32rpx rgba(17, 24, 39, 0.08);
}

.btn-primary,
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  padding: 0 32rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  font-size: var(--font-lg);
  font-weight: 600;
}

.btn-primary {
  background: var(--color-primary);
  color: #ffffff;
}

.btn-secondary {
  background: var(--color-card);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}
