page {
  background: var(--bg-page);
}

.profile-selector-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 48rpx;
}

.profile-selector-page__header {
  padding: 0 40rpx;
  margin-bottom: 40rpx;
}

.profile-selector-page__title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.35;
}

.profile-selector-page__subtitle {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.profile-selector-page__loading {
  margin: 0 40rpx 24rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.profile-selector-page__list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.profile-selector-card {
  margin: 0 40rpx;
  padding: 32rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-card);
  box-shadow: var(--shadow-card);
}

.profile-selector-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.profile-selector-card__identity {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-selector-card__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--text-on-primary);
  font-size: 32rpx;
  font-weight: 800;
}

.profile-selector-card__main {
  min-width: 0;
  flex: 1;
}

.profile-selector-card__name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.profile-selector-card__name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.4;
}

.profile-selector-card__current {
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  background: var(--color-primary);
  color: var(--text-on-primary);
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.3;
  flex-shrink: 0;
}

.profile-selector-card__relation {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

.profile-selector-card__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.profile-selector-card__time {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
  text-align: right;
}

.profile-selector-card__arrow {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.profile-selector-card__bottom {
  margin-top: 28rpx;
}

.profile-selector-card__bp-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.profile-selector-card__value {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.2;
}

.profile-selector-card__unit {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

.profile-selector-card__status {
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.4;
  white-space: nowrap;
  flex-shrink: 0;
}

.profile-selector-card__status.is-normal {
  background: var(--bg-success-light);
  color: var(--color-success);
}

.profile-selector-card__status.is-low {
  background: var(--bg-primary-light);
  color: var(--bp-low);
}

.profile-selector-card__status.is-elevated {
  background: var(--bg-warning-light);
  color: var(--bp-elevated);
}

.profile-selector-card__status.is-stage1 {
  background: var(--bg-warning-light);
  color: var(--bp-high1);
}

.profile-selector-card__status.is-stage2,
.profile-selector-card__status.is-stage3,
.profile-selector-card__status.is-danger {
  background: var(--bg-danger-light);
  color: var(--bp-high2);
}

.profile-selector-card__empty {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}
