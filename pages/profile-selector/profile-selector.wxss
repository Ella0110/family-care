page {
  background: #f2f2f7;
}

.profile-selector-page {
  min-height: 100vh;
  background: #f2f2f7;
  padding-bottom: 48rpx;
}

.profile-selector-page__header {
  padding: 0 40rpx;
  margin-bottom: 40rpx;
}

.profile-selector-page__title {
  font-size: 40rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.35;
}

.profile-selector-page__subtitle {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #94a3b8;
}

.profile-selector-page__loading {
  margin: 0 40rpx 24rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.profile-selector-page__list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.profile-selector-card {
  margin: 0 40rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
}

.profile-selector-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.profile-selector-card__identity {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-selector-card__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
}

.profile-selector-card__main {
  min-width: 0;
  flex: 1;
}

.profile-selector-card__name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.profile-selector-card__name {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.4;
}

.profile-selector-card__current {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  background: #3478f6;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.3;
}

.profile-selector-card__relation {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.4;
}

.profile-selector-card__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.profile-selector-card__time {
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.4;
  text-align: right;
}

.profile-selector-card__arrow {
  font-size: 24rpx;
  color: #cbd5e1;
  line-height: 1;
}

.profile-selector-card__bottom {
  margin-top: 28rpx;
}

.profile-selector-card__bp-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.profile-selector-card__value {
  font-size: 48rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.2;
}

.profile-selector-card__unit {
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.4;
}

.profile-selector-card__status {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.4;
}

.profile-selector-card__status.is-normal {
  background: #f0fff4;
  color: #34c759;
}

.profile-selector-card__status.is-low {
  background: #eff6ff;
  color: #007aff;
}

.profile-selector-card__status.is-elevated {
  background: #fff9eb;
  color: #f5a623;
}

.profile-selector-card__status.is-stage1 {
  background: #fff4eb;
  color: #ff9500;
}

.profile-selector-card__status.is-stage2,
.profile-selector-card__status.is-stage3,
.profile-selector-card__status.is-danger {
  background: #fff0f0;
  color: #ff3b30;
}

.profile-selector-card__empty {
  font-size: 28rpx;
  color: #94a3b8;
  line-height: 1.5;
}
