.invite-accept-page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #f2f2f7;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.invite-accept-card {
  width: 85%;
  max-width: 640rpx;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.invite-accept-card__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #eff6ff;
}

.invite-accept-card__avatar--fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #475569;
  font-weight: 700;
}

.invite-accept-card__headline {
  margin-top: 32rpx;
  color: #64748b;
  font-size: 30rpx;
  line-height: 1.6;
  text-align: center;
}

.invite-accept-card__title {
  margin-top: 8rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.45;
  text-align: center;
}

.invite-accept-card__title--center,
.invite-accept-card__text--center {
  text-align: center;
}

.invite-accept-card__text {
  margin-top: 16rpx;
  color: #94a3b8;
  font-size: 26rpx;
  line-height: 1.7;
}

.invite-accept-card__button {
  width: 100%;
  min-height: 96rpx;
  margin-top: 48rpx;
  box-shadow: 0 8px 24px rgba(52, 120, 246, 0.2);
}

.invite-accept-card__secondary {
  margin-top: 24rpx;
  padding: 8rpx 0;
  background: transparent;
  color: #94a3b8;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.5;
}

.invite-accept-card__secondary::after {
  border: none;
}

.invite-accept-card__invalid-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
  border-radius: 50%;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  color: #94a3b8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}
