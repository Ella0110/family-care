.invite-accept-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.invite-accept-card {
  padding: 40rpx;
  border-radius: 32rpx;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
}

.invite-accept-card__eyebrow {
  font-size: 24rpx;
  font-weight: 700;
  color: #94a3b8;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.invite-accept-card__title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 20rpx;
  line-height: 1.35;
}

.invite-accept-card__text,
.invite-accept-card__profile-summary,
.invite-accept-card__message,
.invite-accept-card__expiry,
.invite-accept-card__hint,
.invite-accept-card__permission {
  font-size: 30rpx;
  line-height: 1.6;
}

.invite-accept-card__text,
.invite-accept-card__profile-summary,
.invite-accept-card__expiry,
.invite-accept-card__hint {
  color: #94a3b8;
}

.invite-accept-card__title--center,
.invite-accept-card__text--center {
  text-align: center;
}

.invite-accept-card__inviter {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.invite-accept-card__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #eff6ff;
}

.invite-accept-card__avatar--fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #475569;
}

.invite-accept-card__inviter-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.5;
}

.invite-accept-card__section {
  margin-bottom: 32rpx;
}

.invite-accept-card__section-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #94a3b8;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.invite-accept-card__profile {
  padding: 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid #f1f5f9;
  background: #ffffff;
  margin-bottom: 16rpx;
}

.invite-accept-card__profile:last-of-type {
  margin-bottom: 0;
}

.invite-accept-card__profile-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.invite-accept-card__permission--enabled {
  color: #10b981;
}

.invite-accept-card__permission--disabled {
  color: #ef4444;
}

.invite-accept-card__button {
  min-height: 96rpx;
  margin-top: 24rpx;
  box-shadow: 0 8px 24px rgba(49, 130, 247, 0.2);
}

.invite-accept-card__secondary {
  min-height: 88rpx;
  padding: 24rpx 32rpx;
  margin-top: 16rpx;
  background: transparent;
  color: #94a3b8;
  border: none;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
  box-sizing: border-box;
}

.invite-accept-card__secondary::after,
.invite-accept-card__ghost-button::after {
  border: none;
}

.invite-accept-card__invalid-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  color: #94a3b8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}

.invite-accept-card__ghost-button {
  margin-top: 24rpx;
  background: transparent;
  color: #3478f6;
  font-size: 30rpx;
  font-weight: 600;
}

.invite-accept-card--success .invite-accept-card__title {
  color: #0f172a;
}
