.invite-accept-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.invite-accept-card {
  padding: 32rpx;
}

.invite-accept-card__title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.invite-accept-card__text,
.invite-accept-card__profile-summary,
.invite-accept-card__message,
.invite-accept-card__expiry,
.invite-accept-card__hint,
.invite-accept-card__permission {
  font-size: 28rpx;
  line-height: 1.6;
}

.invite-accept-card__text,
.invite-accept-card__profile-summary,
.invite-accept-card__expiry,
.invite-accept-card__hint {
  color: var(--color-text-secondary);
}

.invite-accept-card__inviter {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.invite-accept-card__avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(37, 99, 235, 0.12);
}

.invite-accept-card__inviter-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.invite-accept-card__section {
  margin-bottom: 24rpx;
}

.invite-accept-card__section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.invite-accept-card__profile {
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(15, 23, 42, 0.08);
}

.invite-accept-card__profile:first-of-type {
  border-top: none;
  padding-top: 0;
}

.invite-accept-card__profile-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.invite-accept-card__permission--enabled {
  color: #137333;
}

.invite-accept-card__permission--disabled {
  color: #b42318;
}

.invite-accept-card__button {
  min-height: 96rpx;
  margin-top: 24rpx;
}

.invite-accept-card__secondary {
  min-height: 88rpx;
  margin-top: 16rpx;
}

.invite-accept-card--success .invite-accept-card__title {
  color: #137333;
}
