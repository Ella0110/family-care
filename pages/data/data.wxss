/* ========== 页面基础 ========== */
page {
    background-color: var(--bg-page);
}

.data-page {
    min-height: 100vh;
    background: var(--bg-page);
}

/* ========== Loading ========== */
.data-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background: var(--bg-page);
}

.data-loading__spinner {
    width: 56rpx;
    height: 56rpx;
    border-radius: var(--radius-full);
    border: 6rpx solid var(--bg-primary-light);
    border-top-color: var(--color-primary);
    animation: data-loading-spin 0.8s linear infinite;
}

@keyframes data-loading-spin {
    from {
        transform: rotate(0deg);
    }
    to {
        transform: rotate(360deg);
    }
}

.data-profile-entry {
    display: inline-flex;
    align-items: center;
}

.data-profile-entry__dot {
    width: 18rpx;
    height: 18rpx;
    border-radius: var(--radius-full);
    background: var(--color-danger);
    flex-shrink: 0;
}

.data-profile-entry__text {
    font-size: 36rpx;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: 1rpx;
}

.data-profile-entry__arrow {
    font-size: 22rpx;
    color: var(--text-secondary);
    margin-left: 4rpx;
}

/* ========== 空态 ========== */
.data-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 200rpx - env(safe-area-inset-bottom));
    box-sizing: border-box;
}

/* ========== 错误态 ========== */

.data-state__title {
    font-size: 36rpx;
    font-weight: 700;
    color: var(--text-primary);
}

.data-state__text {
    font-size: 26rpx;
    color: var(--text-secondary);
    line-height: 1.6;
}

/* ==========================================================
   最近血压卡片（以下全部保持用户已调好的样式，不做任何修改）
   ========================================================== */
.data-latest {
    margin-bottom: 36rpx;
    padding: 64rpx 64rpx 48rpx;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-card);
}

.data-latest--empty {
    padding: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
}

.data-latest__status {
    display: inline-flex;
    align-items: center;
    gap: 10rpx;
    padding: 0;
    border-radius: 0;
    font-size: 26rpx;
    font-weight: 700;
    line-height: 1.4;
    background: transparent;
}

.data-latest__status.is-normal {
    color: var(--text-primary);
}
.data-latest__status.is-low {
    color: var(--bp-low);
}
.data-latest__status.is-elevated {
    color: var(--bp-elevated);
}
.data-latest__status.is-stage1 {
    color: var(--bp-high1);
}
.data-latest__status.is-stage2,
.data-latest__status.is-stage3,
.data-latest__status.is-danger {
    color: var(--bp-high2);
}

.data-latest__status-dot {
    width: 18rpx;
    height: 18rpx;
    border-radius: var(--radius-full);
    background: currentColor;
}

.data-latest__numbers {
    display: flex;
    align-items: baseline;
    flex-wrap: nowrap;
    margin-bottom: 56rpx;
    line-height: 1;
}

.data-latest__systolic {
    font-size: 135rpx;
    font-weight: 800;
    font-family:
        ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji",
        "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
    letter-spacing: -2rpx;
}

.data-latest__systolic.is-normal {
    color: var(--text-primary);
}
.data-latest__systolic.is-low {
    color: var(--bp-low);
}
.data-latest__systolic.is-elevated {
    color: var(--bp-elevated);
}
.data-latest__systolic.is-stage1 {
    color: var(--bp-high1);
}
.data-latest__systolic.is-stage2,
.data-latest__systolic.is-stage3,
.data-latest__systolic.is-danger {
    color: var(--bp-high2);
}

.data-latest__separator {
    font-size: 36rpx;
    font-weight: 900;
    color: var(--text-tertiary);
    line-height: 1.2;
}

.data-latest__diastolic {
    font-size: 105rpx;
    font-weight: 700;
    letter-spacing: -2rpx;
    font-family:
        ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji",
        "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
}

.data-latest__diastolic.is-normal {
    color: var(--text-primary);
}
.data-latest__diastolic.is-low {
    color: var(--bp-low);
}
.data-latest__diastolic.is-elevated {
    color: var(--bp-elevated);
}
.data-latest__diastolic.is-stage1 {
    color: var(--bp-high1);
}
.data-latest__diastolic.is-stage2,
.data-latest__diastolic.is-stage3,
.data-latest__diastolic.is-danger {
    color: var(--bp-high2);
}

.data-latest__unit {
    font-size: 22rpx;
    font-weight: 900;
    color: var(--text-secondary);
    align-self: flex-end;
    line-height: 1.4;
}

.data-latest__divider {
    height: 1rpx;
    background: var(--border-light);
}

.data-latest__meta {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 88rpx;
}

.data-latest__meta-group {
    display: flex;
    flex-direction: column;
    gap: 8rpx;
}

.data-latest__meta-label {
    font-size: 24rpx;
    color: var(--text-secondary);
    font-weight: 400;
}

.data-latest__meta-value {
    font-size: 30rpx;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.5;
}

.data-latest__meta-hr {
    color: var(--text-primary);
}
.data-latest__meta-hr.is-alert {
    color: var(--color-danger);
}

.data-latest__recorder {
    color: var(--text-tertiary);
    font-size: 22rpx;
    line-height: 1.4;
}

.data-latest__empty {
    display: flex;
    justify-content: center;
}

.data-latest__empty-card {
    width: 100%;
    padding: 80rpx 48rpx;
    background: rgba(255, 255, 255, 0.8);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    box-sizing: border-box;
}

.data-latest__empty-orbit {
    width: 200rpx;
    height: 200rpx;
    border: 4rpx dashed var(--bg-primary-light);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: data-empty-spin 10s linear infinite;
}

.data-latest__empty-orbit-fill {
    width: 164rpx;
    height: 164rpx;
    border-radius: var(--radius-full);
    background: var(--bg-primary-light);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: data-empty-counter-spin 10s linear infinite;
}

.data-latest__empty-heart {
    width: 100rpx;
    height: 100rpx;
}

.data-latest__empty-title {
    font-size: 36rpx;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.35;
}

.data-latest__empty-text {
    font-size: 26rpx;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 520rpx;
}

.data-latest__empty-button {
    width: 80%;
    min-height: 88rpx;
    border-radius: var(--radius-md);
    background: var(--color-primary);
    color: var(--text-on-primary);
    font-size: 32rpx;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1.4;
    text-align: center;
    box-sizing: border-box;
}

.data-latest__empty-button::after {
    border: 0;
}

.data-latest__empty-import {
    font-size: 26rpx;
    color: var(--text-link);
    line-height: 1.5;
}

@keyframes data-empty-spin {
    from {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }
}

@keyframes data-empty-counter-spin {
    from {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(-360deg);
    }
}

/* ==========================================================
   数据分析卡片（以下为重新设计的结构）
   ========================================================== */
.data-analysis {
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-card);
}

/* --- 通用行 --- */
.da-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    /* gap:rpx; */
}

/* 第一行：数据分析 + 全部记录 */
.da-row--header {
    margin-bottom: 24rpx;
}

.da-title {
    font-size: 36rpx;
    font-weight: 800;
    color: var(--text-primary);
}

.da-allrecords {
    font-size: 26rpx;
    font-weight: 600;
    color: var(--text-link);
    line-height: 1.5;
}

/* 第二行：Tabs */

.da-tabs {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    background: var(--bg-input);
    border-radius: var(--radius-sm);
    padding: 4rpx;
    /* gap:24rpx; */
}

.da-tab {
    min-width: 100rpx;
    border-radius: var(--radius-sm);
    text-align: center;
    color: var(--text-secondary);
    font-size: 26rpx;
    font-weight: 600;
    transition: all 0.2s;
    line-height: 1.5;
}

.da-tab--active {
    background: var(--bg-card);
    color: var(--text-link);
    box-shadow: var(--shadow-card);
}

.da-tab--disabled {
    opacity: 0.4;
}

/* 第三行：区块标题 + 下载 */

.da-section-title-group {
    display: flex;
    align-items: center;
    gap: 8rpx;
}

.da-section-title {
    font-size: 30rpx;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.5;
}

.da-section-help {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32rpx;
    height: 32rpx;
    border-radius: var(--radius-full);
    background: var(--border-light);
    color: var(--text-secondary);
    font-size: 22rpx;
    font-weight: 700;
}

.da-download {
    display: flex;
    align-items: center;
    gap: 6rpx;
}

.da-download-arrow {
    font-size: 22rpx;
    color: var(--text-link);
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32rpx;
    height: 32rpx;
    border-radius: var(--radius-full);
    padding: 8rpx;
    background: var(--bg-page);
    font-family:
        ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji",
        "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
}

.da-download-text {
    font-size: 22rpx;
    color: var(--text-link);
    font-weight: 600;
}

/* --- 统计摘要 --- */
.da-summary {
    display: flex;
    align-items: stretch;
    flex-wrap: wrap;
    gap: 16rpx;
}

.da-summary__item {
    flex: 1 1 0;
    min-width: 0;
    padding: 24rpx 18rpx;
    border-radius: var(--radius-lg);
    background: var(--bg-page);
    text-align: center;
}

.da-summary__value {
    font-size: 36rpx;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.2;
}

.da-summary__value--normal {
    color: var(--text-primary);
}

.da-summary__value--danger {
    color: var(--color-danger);
}

.da-summary__label {
    font-size: 22rpx;
    color: var(--text-secondary);
    font-weight: 400;
    line-height: 1.5;
    white-space: nowrap;
}

/* --- 图表 --- */
.da-canvas {
    width: 100%;
    height: 420rpx;
    margin-bottom: 16rpx;
}

.da-canvas--short {
    height: 360rpx;
}

/* --- 图例 --- */
.da-legend {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28rpx;
    color: var(--text-secondary);
    font-size: 22rpx;
    line-height: 1.5;
}

.da-legend__item {
    display: inline-flex;
    align-items: center;
    gap: 8rpx;
}

.da-legend__line {
    width: 28rpx;
    height: 0;
    border-top-width: 4rpx;
    border-top-style: solid;
}

.da-legend__line--systolic {
    border-top-color: var(--color-primary);
}

.da-legend__line--diastolic {
    border-top-color: var(--color-primary);
}

.da-legend__line--hr {
    border-top-color: var(--color-warning);
}

.da-legend__dot {
    width: 12rpx;
    height: 12rpx;
    border-radius: var(--radius-full);
    background: var(--color-warning);
}

.da-legend__dot_normal {
    width: 12rpx;
    height: 12rpx;
    border-radius: var(--radius-full);
    background: var(--color-success);
}

/* --- 区块分隔线 --- */
.da-divider {
    height: 1rpx;
    background: var(--border-light);
}

/* --- 空态 --- */
.da-empty {
    border-radius: var(--radius-sm);
    background: var(--bg-page);
    text-align: center;
    color: var(--text-secondary);
    font-size: 26rpx;
    line-height: 1.6;
}

/* ==========================================================
   悬浮录入按钮
   ========================================================== */
.data-add-button {
    position: fixed;
    left: 50%;
    transform: translateX(-50%);
    bottom: calc(env(safe-area-inset-bottom) + 8rpx);
    width: 112rpx;
    height: 112rpx;
    border-radius: var(--radius-full);
    border: none;
    background: var(--color-primary);
    color: var(--text-on-primary);
    font-size: 56rpx;
    font-weight: 300;
    line-height: 108rpx;
    text-align: center;
    box-shadow: var(--shadow-button);
    z-index: 999;
    padding: 0;
}

.data-add-button::after {
    border: none;
}

.data-add-button--pressed {
    background: var(--color-primary);
    box-shadow: var(--shadow-button);
    opacity: 0.9;
}

/* ========== 导出画布 ========== */
.data-export-canvas {
    position: fixed;
    left: -9999px;
    width: 375px;
}

/* ========== 权限挽回弹窗 ========== */
.data-permission-modal {
    position: fixed;
    inset: 0;
    z-index: 1400;
}

.data-permission-modal__mask {
    position: absolute;
    inset: 0;
    background: var(--bg-overlay);
}

.data-permission-modal__panel {
    position: absolute;
    left: 48rpx;
    right: 48rpx;
    top: 50%;
    transform: translateY(-50%);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
}

.data-permission-modal__title {
    font-size: 36rpx;
    font-weight: 700;
    text-align: center;
    color: var(--text-primary);
}

.data-permission-modal__subtitle {
    text-align: center;
    color: var(--text-secondary);
    font-size: 30rpx;
    line-height: 1.6;
}

.data-permission-modal__step {
    font-size: 26rpx;
    color: var(--text-secondary);
    line-height: 1.6;
}

.data-permission-modal__actions {
    display: flex;
    gap: 20rpx;
}

.data-permission-modal__button {
    flex: 1;
}
