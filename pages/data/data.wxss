/* ========== 页面基础 ========== */
page {
  background-color: #EEF4FE;
}

.data-page {
  min-height: 100vh;
  padding: 0 28rpx;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
  background: #EEF4FE;
}

/* ========== Loading ========== */
.data-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #ffffff;
}

.data-loading__spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 6rpx solid #dbeafe;
  border-top-color: #3182f7;
  animation: data-loading-spin 0.8s linear infinite;
}

@keyframes data-loading-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ========== 档案切换入口 ========== */
.data-profile-entry {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 0 20rpx;
}

.data-profile-entry__dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #EF4444;
  flex-shrink: 0;
}

.data-profile-entry__text {
  font-size: 38rpx;
  font-weight: 800;
  color: #0F172A;
  letter-spacing: 1rpx;
}

.data-profile-entry__arrow {
  font-size: 22rpx;
  color: #94A3B8;
  margin-left: 4rpx;
}

/* ========== 空态 ========== */
.data-empty {
  padding-top: 120rpx;
}

/* ========== 错误态 ========== */
.data-state {
  margin-bottom: 24rpx;
}

.data-state__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.data-state__text {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #64748b;
}

/* ==========================================================
   最近血压卡片（以下全部保持用户已调好的样式，不做任何修改）
   ========================================================== */
.data-latest {
  margin-bottom: 48rpx;
  padding: 64rpx 64rpx 48rpx;
  border-radius: 64rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.data-latest__content {}

.data-latest__status {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1;
}

.data-latest__status.is-danger { color: #DC2626; }
.data-latest__status.is-warning { color: #F59E0B; }
.data-latest__status.is-normal { color: #000000; }

.data-latest__status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: currentColor;
}

.data-latest__numbers {
  display: flex;
  align-items: baseline;
  margin-top: 24rpx;
  margin-bottom: 56rpx;
  line-height: 1;
}

.data-latest__systolic {
  font-size: 3.75rem;
  font-weight: 800;
  font-family: ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji",
               "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
  letter-spacing: -2rpx;
}

.data-latest__systolic.is-normal { color: #000000; }
.data-latest__systolic.is-alert { color: #DC2626; }

.data-latest__separator {
  font-size: 1.875rem;
  font-weight: 900;
  color: #CBD5E1;
  margin: 0 12rpx;
  line-height: 2.25rem;
}

.data-latest__diastolic {
  font-size: 3rem;
  font-weight: 700;
  letter-spacing: -2rpx;
  font-family: ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji",
               "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
}

.data-latest__diastolic.is-normal { color: #000000; }
.data-latest__diastolic.is-alert { color: #F59E0B; }

.data-latest__unit {
  font-size: 28rpx;
  font-weight: 900;
  color: #94A3B8;
  margin-left: 12rpx;
  align-self: flex-end;
  padding-bottom: 12rpx;
}

.data-latest__divider {
  height: 1rpx;
  background: #E5E7EB;
  margin: 28rpx 0 24rpx;
}

.data-latest__meta {
  display: flex;
  align-items: flex-start;
  gap: 88rpx;
}

.data-latest__meta-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.data-latest__meta-label {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 400;
}

.data-latest__meta-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E293B;
}

.data-latest__meta-hr { color: #000000; }
.data-latest__meta-hr.is-alert { color: #DC2626; }

.data-latest__empty {
  text-align: center;
  padding: 40rpx 0 24rpx;
}

.data-latest__empty-icon {
  font-size: 80rpx;
  color: #CBD5E1;
}

.data-latest__empty-title {
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.data-latest__empty-text {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #94A3B8;
}

/* ==========================================================
   数据分析卡片（以下为重新设计的结构）
   ========================================================== */
.data-analysis {
  padding: 48rpx 48rpx 40rpx;
  border-radius: 64rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

/* --- 通用行 --- */
.da-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* gap:rpx; */
}

/* 第一行：数据分析 + 全部记录 */
.da-row--header {
  margin-bottom: 24rpx;
}

.da-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #0F172A;
}

.da-allrecords {
  font-size: 26rpx;
  font-weight: 600;
  color: #3182F7;
}

/* 第二行：Tabs */
.da-row--tabs {
  margin-bottom: 48rpx;
}

.da-tabs {
  display: flex;
  align-items: center;
  background: #F1F5F9;
  border-radius: 999rpx;
  padding: 4rpx;
  /* gap:24rpx; */
}

.da-tab {
  min-width: 100rpx;
  padding: 8rpx 16rpx;
  border-radius: 500rpx;
  text-align: center;
  color: #64748B;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.da-tab--active {
  background: #FFFFFF;
  color: #1D4ED8;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.08);
}

.da-tab--disabled {
  opacity: 0.4;
}

/* 第三行：区块标题 + 下载 */
.da-row--section-header {
  margin-bottom: 20rpx;
}

.da-section-title-group {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.da-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E293B;
}

.da-section-help {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #E2E8F0;
  color: #94A3B8;
  font-size: 20rpx;
  font-weight: 700;
}

.da-download {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.da-download-arrow {
  font-size: 24rpx;
  color: #3182F7;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  padding:8rpx;
  background: #f7f7f7;
  font-family: ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji",
               "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
}

.da-download-text {
  font-size: 24rpx;
  color: #3182F7;
  font-weight: 600;
}

/* --- 统计摘要 --- */
.da-summary {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.da-summary__item {
  flex: 1;
  padding: 20rpx 16rpx;
  border-radius: 50rpx;
  background: #F8FAFC;
  text-align: center;
}

.da-summary__value {
  font-size: 40rpx;
  font-weight: 800;
  color: #1E293B;
  line-height: 1.2;
}

.da-summary__value--normal {
  color: #1E293B;
}

.da-summary__value--danger {
  color: #DC2626;
}

.da-summary__label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94A3B8;
  font-weight: 400;
}

/* --- 图表 --- */
.da-canvas {
  width: 100%;
  height: 420rpx;
  margin-bottom: 16rpx;
}

.da-canvas--short {
  height: 360rpx;
}

/* --- 图例 --- */
.da-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  margin-bottom: 8rpx;
  color: #64748B;
  font-size: 22rpx;
}

.da-legend__item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.da-legend__line {
  width: 28rpx;
  height: 0;
  border-top-width: 4rpx;
  border-top-style: solid;
}

.da-legend__line--systolic {
  border-top-color: #1E40AF;
}

.da-legend__line--diastolic {
  border-top-color: #93C5FD;
}

.da-legend__line--hr {
  border-top-color: #F59E0B;
}

.da-legend__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #EF4444;
}

.da-legend__dot_normal {
    width: 12rpx;
    height: 12rpx;
    border-radius: 50%;
    background: #3182F7;
  }

/* --- 区块分隔线 --- */
.da-divider {
  height: 1rpx;
  background: #E5E7EB;
  margin: 32rpx 0;
}

/* --- 空态 --- */
.da-empty {
  padding: 48rpx 24rpx;
  border-radius: 16rpx;
  background: #F8FAFC;
  text-align: center;
  color: #94A3B8;
  font-size: 26rpx;
  margin-top: 16rpx;
}

/* ==========================================================
   悬浮录入按钮
   ========================================================== */
.data-add-button {
  position: fixed;
  left: 50%;
  bottom: calc(env(safe-area-inset-bottom) + 56px);
  width: 112rpx;
  height: 112rpx;
  margin-left: -56rpx;
  border-radius: 50%;
  border: none;
  background: #3182F7;
  color: #FFFFFF;
  font-size: 56rpx;
  font-weight: 300;
  line-height: 108rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(49, 130, 247, 0.35);
  z-index: 999;
  padding: 0;
}

.data-add-button::after {
  border: none;
}

.data-add-button--pressed {
  background: #2563EB;
  box-shadow: 0 4rpx 16rpx rgba(49, 130, 247, 0.4);
  opacity: 0.9;
}

/* ========== 导出画布 ========== */
.data-export-canvas {
  position: fixed;
  left: -9999px;
  width: 375px;
}

/* ========== 权限挽回弹窗 ========== */
.data-permission-modal {
  position: fixed;
  inset: 0;
  z-index: 1400;
}

.data-permission-modal__mask {
  position: absolute;
  inset: 0;
  background: rgba(17, 24, 39, 0.4);
}

.data-permission-modal__panel {
  position: absolute;
  left: 48rpx;
  right: 48rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 48rpx 40rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
}

.data-permission-modal__title {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  color: #111827;
}

.data-permission-modal__subtitle {
  margin-top: 12rpx;
  text-align: center;
  color: #64748B;
  font-size: 28rpx;
}

.data-permission-modal__step {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #64748B;
}

.data-permission-modal__actions {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.data-permission-modal__button {
  flex: 1;
}
