page {
  background-color: #F0F5FF;
}

.data-page {
  min-height: 100vh;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
  background: #F0F5FF;
}

.data-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #ffffff;
}

.data-loading__spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 6rpx solid #dbeafe;
  border-top-color: #3182f7;
  animation: data-loading-spin 0.8s linear infinite;
}

@keyframes data-loading-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.data-page__header {
  text-align: center;
  font-size: var(--font-xl);
  font-weight: 700;
  color: #111827;
  margin-bottom: 20rpx;
}

.data-profile-entry {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 24rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #1e3a8a;
}

.data-profile-entry__text {
  font-size: var(--font-sm);
  font-weight: 600;
}

.data-profile-entry__arrow {
  font-size: 20rpx;
  color: #64748b;
}

.data-empty {
  padding-top: 120rpx;
}

.data-state,
.data-latest,
.data-analysis {
  margin-bottom: 24rpx;
}

.data-state__title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: #111827;
}

.data-state__text {
  margin-top: 12rpx;
  font-size: var(--font-sm);
  color: #64748b;
}

.data-latest__status {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  font-size: var(--font-sm);
  font-weight: 600;
}

.data-latest__status.is-danger {
  color: #dc2626;
}

.data-latest__status.is-warning {
  color: #d97706;
}

.data-latest__status.is-normal {
  color: #059669;
}

.data-latest__status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: currentColor;
}

.data-latest__status-dot.is-danger {
  background: #dc2626;
}

.data-latest__status-dot.is-warning {
  background: #d97706;
}

.data-latest__status-dot.is-normal {
  background: #059669;
}

.data-latest__numbers {
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
  margin-top: 18rpx;
  line-height: 1;
}

.data-latest__number {
  font-size: 78rpx;
  font-weight: 700;
}

.data-latest__number.is-normal {
  color: #2563eb;
}

.data-latest__number.is-alert {
  color: #dc2626;
}

.data-latest__separator {
  padding-bottom: 8rpx;
  font-size: 54rpx;
  font-weight: 500;
  color: #2563eb;
}

.data-latest__unit {
  padding-bottom: 10rpx;
  margin-left: 8rpx;
  font-size: var(--font-sm);
  color: #94a3b8;
}

.data-latest__meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 20rpx;
  font-size: var(--font-sm);
  color: #64748b;
}

.data-latest__meta-item.is-alert {
  color: #dc2626;
}

.data-latest__empty {
  text-align: center;
  padding: 24rpx 0 12rpx;
}

.data-latest__empty-icon {
  font-size: 72rpx;
  color: #d1d5db;
}

.data-latest__empty-title {
  margin-top: 12rpx;
  font-size: var(--font-lg);
  font-weight: 600;
  color: #111827;
}

.data-latest__empty-text {
  margin-top: 8rpx;
  font-size: var(--font-sm);
  color: #64748b;
}

.data-analysis__title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: #111827;
}

.data-analysis__toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
}

.data-analysis__tabs {
  display: flex;
  gap: 12rpx;
}

.data-analysis__tab {
  min-width: 110rpx;
  padding: 12rpx 0;
  border-radius: 999rpx;
  text-align: center;
  background: #e5edff;
  color: #64748b;
  font-size: var(--font-sm);
  font-weight: 600;
}

.data-analysis__tab--active {
  background: #dbeafe;
  color: #1d4ed8;
}

.data-analysis__tab--disabled {
  opacity: 0.45;
}

.data-analysis__records-link,
.data-chart-section__action {
  font-size: var(--font-sm);
  font-weight: 600;
  color: #3182f7;
}

.data-summary {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.data-summary__item {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f8fbff;
}

.data-summary__item--wide {
  grid-column: span 1;
}

.data-summary__label {
  font-size: var(--font-xs);
  color: #64748b;
}

.data-summary__value {
  margin-top: 10rpx;
  font-size: var(--font-base);
  font-weight: 700;
  color: #111827;
}

.data-summary__value.is-normal {
  color: #2563eb;
}

.data-summary__value.is-danger {
  color: #dc2626;
}

.data-chart-section {
  margin-top: 28rpx;
}

.data-chart-section__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.data-chart-section__title {
  font-size: var(--font-base);
  font-weight: 700;
  color: #111827;
}

.data-chart-section__canvas {
  width: 100%;
  height: 460rpx;
  margin-top: 20rpx;
}

.data-chart-section__canvas--secondary {
  margin-top: 20rpx;
}

.data-chart-section__empty {
  margin-top: 20rpx;
  padding: 48rpx 24rpx;
  border-radius: 24rpx;
  background: #f8fbff;
  text-align: center;
  color: #64748b;
  font-size: var(--font-sm);
}

.data-chart-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  flex-wrap: wrap;
  margin-top: 10rpx;
  color: #475569;
  font-size: var(--font-xs);
}

.data-chart-legend__item {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

.data-chart-legend__line {
  width: 36rpx;
  height: 0;
  border-top-width: 4rpx;
  border-top-style: solid;
}

.data-chart-legend__line--systolic {
  border-top-color: #1E40AF;
}

.data-chart-legend__line--diastolic {
  border-top-color: #93C5FD;
}

.data-chart-legend__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #EF4444;
}

.data-bottom-switcher {
  margin: 32rpx 0 12rpx;
  text-align: center;
  color: #3182f7;
  font-size: var(--font-sm);
  font-weight: 600;
}

.data-add-button {
  position: fixed;
  left: 50%;
  bottom: calc(96rpx + env(safe-area-inset-bottom));
  width: 112rpx;
  height: 112rpx;
  margin-left: -56rpx;
  border-radius: 50%;
  border: none;
  background: #3182f7;
  color: #ffffff;
  font-size: 60rpx;
  line-height: 112rpx;
  box-shadow: 0 2px 8px rgba(49, 130, 247, 0.3);
}

.data-add-button--pressed {
  transform: scale(0.95);
  background: #2563eb;
}

.data-export-canvas {
  position: fixed;
  left: -9999px;
  width: 375px;
}

.data-permission-modal {
  position: fixed;
  inset: 0;
  z-index: 1400;
}

.data-permission-modal__mask {
  position: absolute;
  inset: 0;
  background: rgba(17, 24, 39, 0.36);
}

.data-permission-modal__panel {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
}

.data-permission-modal__title {
  font-size: var(--font-lg);
  font-weight: 700;
  text-align: center;
}

.data-permission-modal__subtitle {
  margin-top: 12rpx;
  text-align: center;
  color: var(--color-text-secondary);
  font-size: var(--font-base);
}

.data-permission-modal__step {
  margin-top: 16rpx;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.data-permission-modal__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.data-permission-modal__button {
  flex: 1;
}
