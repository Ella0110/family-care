<view class="page page-root data-page" style="--font-scale: {{fontScale}};">
  <view wx:if="{{pageReady}}">
    <view wx:if="{{hasProfile}}" class="data-profile-entry" bindtap="handleOpenProfileSwitcher">
      <text class="data-profile-entry__text">{{profileTitle}}</text>
      <text class="data-profile-entry__arrow">▼</text>
    </view>

    <view wx:if="{{!hasProfile}}" class="data-empty">
      <empty-state
        icon="♥"
        title="记录家人的血压，从第一条开始"
        subtitle="先建一个档案吧"
        buttonText="为家人或自己建档案"
        bind:buttontap="handleCreateProfile"
      />
    </view>

    <view wx:else>
      <view wx:if="{{errorText}}" class="card data-state">
        <view class="data-state__title">暂时无法加载数据</view>
        <view class="data-state__text">{{errorText}}</view>
      </view>

      <view wx:else>
        <view class="card data-latest">
          <view wx:if="{{latestRecordDisplay}}" class="data-latest__content">
            <view class="data-latest__status {{latestRecordDisplay.statusClassName}}">
              <view class="data-latest__status-dot {{latestRecordDisplay.statusClassName}}"></view>
              <text>{{latestRecordDisplay.statusText}}</text>
            </view>

            <view class="data-latest__numbers">
              <text class="data-latest__number {{latestRecordDisplay.systolicClassName}}">{{latestRecordDisplay.systolicText}}</text>
              <text class="data-latest__separator"> / </text>
              <text class="data-latest__number {{latestRecordDisplay.diastolicClassName}}">{{latestRecordDisplay.diastolicText}}</text>
              <text class="data-latest__unit">mmHg</text>
            </view>

            <view class="data-latest__meta">
              <view class="data-latest__meta-item {{latestRecordDisplay.heartRateClassName}}">
                最近心率 {{latestRecordDisplay.heartRateText}}
              </view>
              <view class="data-latest__meta-item">
                测量时间 {{latestRecordDisplay.measuredAtText}}
              </view>
            </view>
          </view>

          <view wx:else class="data-latest__empty">
            <view class="data-latest__empty-icon">♥</view>
            <view class="data-latest__empty-title">开启你的健康记录</view>
            <view class="data-latest__empty-text">每天定时测量并记录</view>
          </view>
        </view>

        <view wx:if="{{hasAnyRecords}}" class="card data-analysis">
          <view class="data-analysis__title">数据分析</view>

          <view class="data-analysis__toolbar">
            <view class="data-analysis__tabs">
              <view
                wx:for="{{periodOptions}}"
                wx:key="days"
                class="data-analysis__tab {{selectedDays === item.days ? 'data-analysis__tab--active' : ''}} {{!item.enabled ? 'data-analysis__tab--disabled' : ''}}"
                data-days="{{item.days}}"
                bindtap="handleSelectPeriod"
              >
                {{item.label}}
              </view>
            </view>

            <view class="data-analysis__records-link" bindtap="handleViewAllRecords">全部记录 ></view>
          </view>

          <view wx:if="{{hasRangeRecords}}">
            <view class="data-summary">
              <view class="data-summary__item">
                <view class="data-summary__label">已达标</view>
                <view class="data-summary__value is-normal">{{rangeSummary.normalCount}} 次</view>
              </view>

              <view class="data-summary__item">
                <view class="data-summary__label">未达标</view>
                <view class="data-summary__value is-danger">{{rangeSummary.abnormalCount}} 次</view>
              </view>

              <view class="data-summary__item data-summary__item--wide">
                <view class="data-summary__label">平均值</view>
                <view class="data-summary__value">{{rangeSummary.averageText}} mmHg</view>
              </view>
            </view>

            <view class="data-chart-section">
              <view class="data-chart-section__header">
                <view class="data-chart-section__title">血压数据</view>
                <view class="data-chart-section__action" bindtap="handleExportBloodPressureChart">下载</view>
              </view>

              <canvas id="dataBpChart" type="2d" class="data-chart-section__canvas"></canvas>

              <view class="data-chart-legend">
                <view class="data-chart-legend__item">
                  <view class="data-chart-legend__line data-chart-legend__line--systolic"></view>
                  <text>收缩压</text>
                </view>
                <view class="data-chart-legend__item">
                  <view class="data-chart-legend__line data-chart-legend__line--diastolic"></view>
                  <text>舒张压</text>
                </view>
                <view class="data-chart-legend__item">
                  <view class="data-chart-legend__dot"></view>
                  <text>超标</text>
                </view>
              </view>
            </view>

            <view class="data-chart-section">
              <view class="data-chart-section__header">
                <view class="data-chart-section__title">心率数据</view>
                <view class="data-chart-section__action" bindtap="handleExportHeartRateChart">下载</view>
              </view>

              <canvas wx:if="{{hasHeartRateData}}" id="dataHeartRateChart" type="2d" class="data-chart-section__canvas data-chart-section__canvas--secondary"></canvas>

              <view wx:else class="data-chart-section__empty">
                暂无心率数据
              </view>
            </view>
          </view>

          <view wx:else class="data-chart-section__empty">
            当前时间范围内暂无趋势数据
          </view>
        </view>

      </view>
    </view>
  </view>

  <view wx:else class="data-loading">
    <view class="data-loading__spinner"></view>
  </view>

  <button
    wx:if="{{pageReady && hasProfile && canWriteCurrentProfile}}"
    class="data-add-button"
    hover-class="data-add-button--pressed"
    bindtap="handleOpenRecordPanel"
  >
    +
  </button>

  <profile-switcher
    show="{{showProfileSwitcher}}"
    profiles="{{profiles}}"
    current-profile-id="{{currentProfileId}}"
    return-tab="/pages/data/data"
    bind:select="handleSelectProfile"
    bind:close="handleCloseProfileSwitcher"
  />

  <record-panel
    show="{{showRecordPanel}}"
    profile-id="{{currentProfileId}}"
    record="{{editingRecord}}"
    bind:success="handleRecordPanelSuccess"
    bind:delete="handleRecordPanelDelete"
    bind:close="handleCloseRecordPanel"
  />

  <canvas
    id="dataExportCanvas"
    type="2d"
    class="data-export-canvas"
    style="height: {{exportCanvasHeight}}px;"
  ></canvas>

  <view wx:if="{{showPermissionModal}}" class="data-permission-modal">
    <view class="data-permission-modal__mask"></view>
    <view class="data-permission-modal__panel card">
      <view class="data-permission-modal__title">无法保存图片</view>
      <view class="data-permission-modal__subtitle">需要开启“相册写入”权限</view>
      <view class="data-permission-modal__step">步骤 1：点击下方“去设置”按钮</view>
      <view class="data-permission-modal__step">步骤 2：将“添加到相册”设为允许</view>
      <view class="data-permission-modal__actions">
        <button class="btn-primary data-permission-modal__button" bindtap="handleOpenPermissionSetting">
          去设置
        </button>
        <button class="btn-secondary data-permission-modal__button" bindtap="handleClosePermissionModal">
          暂不下载
        </button>
      </view>
    </view>
  </view>
</view>
