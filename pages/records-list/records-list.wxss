page {
    background: var(--bg-page);
}

.records-page {
    min-height: 100vh;
    padding: 24rpx 32rpx 60rpx;
    background: var(--bg-page);
}

.records-viewer-tip {
    color: var(--text-secondary);
    font-size: 24rpx;
}

.records-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.records-toolbar__month {
    display: inline-flex;
    align-items: center;
    min-height: 80rpx;
}

.records-toolbar__month-bar {
    width: 4rpx;
    height: 32rpx;
    border-radius: 2rpx;
    background: var(--color-primary);
    margin-right: 12rpx;
}

.records-toolbar__month-text {
    color: var(--text-primary);
    font-size: 30rpx;
    font-weight: 700;
}

.records-toolbar__month-arrow {
    margin-left: 8rpx;
    color: var(--text-secondary);
    font-size: 22rpx;
}

.records-toolbar__actions {
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.records-toolbar__export,
.records-toolbar__import {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 120rpx;
    min-height: 64rpx;
    padding: 20rpx 24rpx;
    margin: 0;
    border-radius: var(--radius-sm);
    font-size: 26rpx;
    line-height: 1.4;
    text-align: center;
}

.records-toolbar__export::after,
.records-toolbar__import::after {
    border: 0;
}

.records-toolbar__import {
    background: var(--bg-card);
    border: 2rpx solid var(--border-light);
    color: var(--text-secondary);
}

.records-toolbar__export {
    background: var(--color-primary);
    color: var(--text-on-primary);
    box-shadow: var(--shadow-button);
}

.records-state-card {
    margin-bottom: 24rpx;
    padding: 40rpx;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-card);
}

.records-state-card__title {
    color: var(--text-primary);
    font-size: 36rpx;
    font-weight: 700;
}

.records-state-card__text {
    color: var(--text-secondary);
    font-size: 26rpx;
    line-height: 1.7;
}

.records-state-card__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 80rpx;
    border-radius: var(--radius-md);
    background: var(--color-primary);
    color: var(--text-on-primary);
    font-size: 32rpx;
    font-weight: 600;
    line-height: 1.4;
    box-shadow: var(--shadow-button);
}

.records-state-card__button::after {
    border: 0;
}

.records-state-card__button--ghost {
    background: var(--bg-input);
    color: var(--text-secondary);
    box-shadow: none;
}

.records-group + .records-group {
    margin-top: 32rpx;
}

.records-group__title {
    margin: 0;
    color: var(--color-primary);
    font-size: 30rpx;
    font-weight: 700;
}

.records-group__card {
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-card);
}

.records-row-swipe {
    position: relative;
    overflow: hidden;
    background: var(--bg-card);
}

.records-row-swipe + .records-row-swipe {
    border-top: 1rpx solid var(--border-light);
}

.records-row-swipe__delete {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 160rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-danger);
    color: var(--text-on-primary);
    font-size: 32rpx;
    font-weight: 700;
}

.records-row {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 132rpx) minmax(0, 1fr) auto auto;
    align-items: flex-start;
    gap: 18rpx;
    min-height: 96rpx;
    box-sizing: border-box;
    background: var(--bg-card);
    transition: transform 0.18s ease;
}

.records-row__time {
    color: var(--text-secondary);
    font-size: 26rpx;
    font-weight: 600;
    line-height: 1.5;
    align-self: center;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.records-row__main {
    min-width: 0;
}

.records-row__value {
    color: var(--text-primary);
    font-size: 36rpx;
    font-weight: 700;
    line-height: 1.25;
    white-space: nowrap;
    flex-shrink: 0;
}

.records-row__heart {
    margin-top: 6rpx;
    color: var(--text-secondary);
    font-size: 26rpx;
    line-height: 1.4;
}

.records-row__recorder {
    margin-top: 6rpx;
    color: var(--text-tertiary);
    font-size: 22rpx;
    line-height: 1.4;
}

.records-row__status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: center;
    border-radius: var(--radius-sm);
    font-size: 22rpx;
    font-weight: 700;
    white-space: nowrap;
    box-sizing: border-box;
    flex-shrink: 0;
}

.records-status--low {
    background: var(--bg-primary-light);
    color: var(--bp-low);
}

.records-status--normal {
    background: var(--bg-success-light);
    color: var(--bp-normal);
}

.records-status--elevated {
    background: var(--bg-warning-light);
    color: var(--bp-elevated);
}

.records-status--stage1 {
    background: var(--bg-warning-light);
    color: var(--bp-high1);
}

.records-status--stage2,
.records-status--stage3,
.records-status--danger {
    background: var(--bg-danger-light);
    color: var(--bp-high2);
}

.records-status--strong {
    font-weight: 800;
}

.records-row__arrow {
    color: var(--text-tertiary);
    font-size: 36rpx;
    line-height: 1;
    align-self: center;
    flex-shrink: 0;
}

.records-footer {
    padding: 36rpx 0 12rpx;
    color: var(--text-secondary);
    font-size: 26rpx;
    text-align: center;
    line-height: 1.6;
}

.records-export-canvas {
    position: fixed;
    left: -9999px;
    top: 0;
    width: 375px;
    pointer-events: none;
}

.records-export-sheet,
.records-export-preview,
.records-permission-modal,
.records-dialog-layer,
.records-feedback-layer {
    position: fixed;
    inset: 0;
}

.records-export-sheet {
    z-index: 30;
}

.records-export-sheet__mask,
.records-permission-modal__mask,
.records-dialog-layer__mask,
.records-feedback-layer__mask {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.5);
}

.records-export-sheet__panel {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    background: var(--bg-card);
    box-shadow: var(--shadow-sheet);
}

.records-export-sheet__handle {
    width: 80rpx;
    height: 8rpx;
    margin: 0 auto;
    border-radius: var(--radius-pill);
    background: var(--border-light);
}

.records-export-sheet__title {
    color: var(--text-primary);
    font-size: 36rpx;
    font-weight: 800;
    text-align: center;
}

.records-export-sheet__subtitle {
    color: var(--text-secondary);
    font-size: 24rpx;
    text-align: center;
}

.records-export-sheet__ranges {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
}

.records-export-sheet__range {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 28rpx 0;
    border: 2rpx solid var(--border-light);
    border-radius: var(--radius-md);
    text-align: center;
}

.records-export-sheet__range.is-active {
    border-color: var(--color-primary);
}

.records-export-sheet__range-number {
    color: var(--text-primary);
    font-size: 52rpx;
    font-weight: 900;
    line-height: 1;
}

.records-export-sheet__range.is-active .records-export-sheet__range-number {
    color: var(--color-primary);
}

.records-export-sheet__range-label {
    margin-top: 4rpx;
    color: var(--text-secondary);
    font-size: 22rpx;
}

.records-export-sheet__actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
}

.records-export-sheet__action {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 88rpx;
    margin: 0;
    border-radius: var(--radius-md);
    font-size: 32rpx;
    font-weight: 600;
    text-align: center;
    box-sizing: border-box;
}

.records-export-sheet__action::after {
    border: 0;
}

.records-export-sheet__action--primary {
    background: var(--color-primary);
    color: var(--text-on-primary);
    box-shadow: var(--shadow-button);
}

.records-export-sheet__action--secondary {
    background: var(--bg-input);
    color: var(--text-secondary);
}

.records-export-sheet__cancel {
    color: var(--text-secondary);
    font-size: 30rpx;
    text-align: center;
}

.records-export-preview {
    z-index: 35;
    display: flex;
    flex-direction: column;
    background: var(--bg-page);
}

.records-export-preview__header {
    padding: 36rpx 32rpx 20rpx;
}

.records-export-preview__title {
    color: var(--text-primary);
    font-size: 36rpx;
    font-weight: 800;
}

.records-export-preview__subtitle {
    margin-top: 10rpx;
    color: var(--text-secondary);
    font-size: 24rpx;
    line-height: 1.6;
}

.records-export-preview__scroll {
    flex: 1;
    min-height: 0;
    padding: 8rpx 32rpx 196rpx;
    box-sizing: border-box;
}

.records-export-preview__card {
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-card);
    padding: 24rpx;
}

.records-export-preview__image {
    display: block;
    width: 100%;
    border-radius: var(--radius-sm);
}

.records-export-preview__actions {
    position: fixed;
    right: 0;
    bottom: 0;
    left: 0;
    display: flex;
    background: rgba(255, 255, 255, 0.98);
    box-shadow: var(--shadow-sheet);
}

.records-export-preview__button {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 88rpx;
    margin: 0;
    border-radius: var(--radius-md);
    font-size: 32rpx;
    font-weight: 700;
    text-align: center;
}

.records-export-preview__button::after {
    border: 0;
}

.records-export-preview__button--primary {
    background: var(--color-primary);
    color: var(--text-on-primary);
    box-shadow: var(--shadow-button);
}

.records-export-preview__button--secondary {
    background: var(--bg-card);
    border: 2rpx solid var(--border-light);
    color: var(--text-secondary);
}

.records-permission-modal {
    z-index: 40;
}

.records-permission-modal__panel {
    position: absolute;
    left: 32rpx;
    right: 32rpx;
    background: var(--bg-card);
}

.records-permission-modal__panel {
    top: 50%;
    transform: translateY(-50%);
    padding: 40rpx;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-float);
}

.records-permission-modal__title,
.records-dialog-layer__title,
.records-feedback-layer__title {
    color: var(--text-primary);
    font-size: 36rpx;
    font-weight: 700;
    line-height: 1.4;
}

.records-permission-modal__subtitle,
.records-dialog-layer__text {
    margin-top: 12rpx;
    color: var(--text-secondary);
    font-size: 24rpx;
    line-height: 1.6;
}

.records-permission-modal__step {
    margin-top: 16rpx;
    color: var(--text-secondary);
    font-size: 26rpx;
    line-height: 1.6;
}

.records-permission-modal__actions {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
    margin-top: 28rpx;
}

.records-permission-modal__button {
    min-height: 84rpx;
    margin: 0;
    border-radius: var(--radius-md);
    font-size: 28rpx;
    font-weight: 700;
}

.records-permission-modal__button::after {
    border: 0;
}

.records-permission-modal__button--primary {
    background: var(--color-primary);
    color: var(--text-on-primary);
    box-shadow: var(--shadow-button);
}

.records-permission-modal__button--secondary {
    background: var(--bg-input);
    color: var(--text-secondary);
}

.records-dialog-layer {
    z-index: 9999;
}

.records-dialog-layer__card,
.records-feedback-layer__card {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 1;
    background: var(--bg-card);
    box-sizing: border-box;
    text-align: center;
}

.records-dialog-layer__card {
    width: calc(100% - 96rpx);
    transform: translate(-50%, -50%);
    padding: 48rpx;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-float);
    animation: records-dialog-enter 220ms ease-out;
}

.records-dialog-layer__icon-wrap,
.records-feedback-layer__icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 80rpx;
    height: 80rpx;
    margin-bottom: 24rpx;
    border-radius: var(--radius-full);
    background: var(--bg-danger-light);
}

.records-dialog-layer__icon,
.records-feedback-layer__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-danger);
    font-size: 40rpx;
}

.records-dialog-layer__confirm {
    width: 100%;
    min-height: 88rpx;
    margin: 40rpx 0 0;
    padding: 28rpx;
    border-radius: var(--radius-md);
    background: var(--color-danger);
    color: var(--text-on-primary);
    font-size: 30rpx;
    font-weight: 700;
}

.records-dialog-layer__confirm::after {
    border: 0;
}

.records-dialog-layer__cancel {
    margin-top: 24rpx;
    color: var(--text-secondary);
    font-size: 28rpx;
}

.records-feedback-layer {
    z-index: 9999;
}

.records-feedback-layer__card {
    width: 400rpx;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24rpx;
    padding: 48rpx;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-float);
    animation: records-feedback-enter 220ms
        cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.records-feedback-layer__title {
    margin-top: 0;
    font-size: 32rpx;
}

@keyframes records-dialog-enter {
    from {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.9);
    }

    to {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
    }
}

@keyframes records-feedback-enter {
    from {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.8);
    }

    to {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
    }
}
