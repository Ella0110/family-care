.records-header {
  position: sticky;
  top: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: -32rpx -32rpx 28rpx;
  padding: 28rpx 32rpx 24rpx;
  background: #f5f5f5;
}

.records-header__back {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: calc(30rpx * var(--font-scale));
  font-weight: 700;
}

.records-header__text {
  flex: 1;
}

.records-header__title {
  color: #111827;
  font-size: calc(42rpx * var(--font-scale));
  font-weight: 800;
  line-height: 1.3;
}

.records-header__subtitle {
  margin-top: 6rpx;
  color: #4b5563;
  font-size: calc(28rpx * var(--font-scale));
}

.records-viewer-tip {
  margin: 0 0 20rpx;
  color: #6b7280;
  font-size: calc(24rpx * var(--font-scale));
}

.records-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.records-actions__button {
  flex: 1;
  min-height: 84rpx;
  margin: 0;
  padding: 0 20rpx;
  font-size: calc(28rpx * var(--font-scale));
}

.records-state {
  margin-top: 24rpx;
}

.records-state__title {
  color: #111827;
  font-size: calc(40rpx * var(--font-scale));
  font-weight: 800;
}

.records-state__text {
  margin-top: 14rpx;
  color: #4b5563;
  font-size: calc(30rpx * var(--font-scale));
}

.records-state__button {
  margin-top: 32rpx;
}

.records-group + .records-group {
  margin-top: 32rpx;
}

.records-group__title {
  margin: 0 0 16rpx 8rpx;
  color: #374151;
  font-size: calc(32rpx * var(--font-scale));
  font-weight: 800;
}

.records-group__card {
  padding: 0;
  overflow: hidden;
}

.record-row {
  display: grid;
  grid-template-columns: 140rpx 1fr auto 56rpx;
  align-items: center;
  gap: 18rpx;
  min-height: 132rpx;
  padding: 24rpx 24rpx;
  box-sizing: border-box;
}

.record-row + .record-row {
  border-top: 1rpx solid #e5e7eb;
}

.record-row__time {
  color: #4b5563;
  font-size: calc(30rpx * var(--font-scale));
  font-weight: 700;
  white-space: nowrap;
}

.record-row__value {
  color: #111827;
  font-size: calc(34rpx * var(--font-scale));
  font-weight: 800;
}

.record-row__heart {
  margin-top: 4rpx;
  color: #6b7280;
  font-size: calc(26rpx * var(--font-scale));
}

.record-row__arrow {
  color: #9ca3af;
  font-size: calc(44rpx * var(--font-scale));
  line-height: 1;
}

.records-more {
  margin: 32rpx 0 8rpx;
  color: #6b7280;
  font-size: calc(28rpx * var(--font-scale));
  text-align: center;
}

.records-export-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 375px;
  pointer-events: none;
}

.records-permission-modal {
  position: fixed;
  inset: 0;
  z-index: 40;
}

.records-permission-modal__mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
}

.records-permission-modal__panel {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
}

.records-permission-modal__title {
  color: #111827;
  font-size: calc(38rpx * var(--font-scale));
  font-weight: 800;
  line-height: 1.35;
}

.records-permission-modal__subtitle {
  margin-top: 12rpx;
  color: #4b5563;
  font-size: calc(30rpx * var(--font-scale));
  line-height: 1.6;
}

.records-permission-modal__step {
  margin-top: 16rpx;
  color: #6b7280;
  font-size: calc(28rpx * var(--font-scale));
  line-height: 1.6;
}

.records-permission-modal__actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 28rpx;
}

.records-permission-modal__button {
  width: 100%;
  margin: 0;
}
