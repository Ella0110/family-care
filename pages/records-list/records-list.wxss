page {
    background: #f0f4fa;
}

.records-page {
    min-height: 100vh;
    padding: 24rpx 32rpx 60rpx;
    background: #f0f4fa;
}

.records-viewer-tip {
    margin-bottom: 20rpx;
    color: #94a3b8;
    font-size: 24rpx;
}

.records-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20rpx;
    margin-bottom: 24rpx;
}

.records-toolbar__month {
    display: inline-flex;
    align-items: center;
    min-height: 80rpx;
}

.records-toolbar__month-bar {
    width: 4rpx;
    height: 32rpx;
    border-radius: 2rpx;
    background: #3182f7;
    margin-right: 12rpx;
}

.records-toolbar__month-text {
    color: #1e293b;
    font-size: 30rpx;
    font-weight: 700;
}

.records-toolbar__month-arrow {
    margin-left: 8rpx;
    color: #94a3b8;
    font-size: 22rpx;
}

.records-toolbar__actions {
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.records-toolbar__export,
.records-toolbar__import {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 120rpx;
    min-height: 64rpx;
    padding: 20rpx 24rpx;
    margin: 0;
    border-radius: 16rpx;
    font-size: 26rpx;
    line-height: 1.4;
    text-align: center;
}

.records-toolbar__export::after,
.records-toolbar__import::after {
    border: 0;
}

.records-toolbar__import {
    background: #ffffff;
    border: 2rpx solid #e2e8f0;
    color: #64748b;
}

.records-toolbar__export {
    background: #3182f7;
    color: #ffffff;
}

.records-state-card {
    margin-bottom: 24rpx;
    padding: 40rpx;
    border-radius: 24rpx;
    background: #ffffff;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.records-state-card__title {
    color: #1e293b;
    font-size: 36rpx;
    font-weight: 700;
}

.records-state-card__text {
    margin-top: 12rpx;
    color: #94a3b8;
    font-size: 26rpx;
    line-height: 1.7;
}

.records-state-card__actions {
    margin-top: 24rpx;
}

.records-state-card__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 80rpx;
    padding: 20rpx 28rpx;
    margin: 24rpx 0 0;
    border-radius: 20rpx;
    background: #3182f7;
    color: #ffffff;
    font-size: 32rpx;
    font-weight: 600;
    line-height: 1.4;
}

.records-state-card__button::after {
    border: 0;
}

.records-state-card__button--ghost {
    background: #f1f5f9;
    color: #64748b;
}

.records-group + .records-group {
    margin-top: 32rpx;
}

.records-group__title {
    margin: 0 0 16rpx;
    color: #3182f7;
    font-size: 30rpx;
    font-weight: 700;
}

.records-group__card {
    overflow: hidden;
    border-radius: 24rpx;
    background: #ffffff;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.records-row-swipe {
    position: relative;
    overflow: hidden;
    background: #ffffff;
}

.records-row-swipe + .records-row-swipe {
    border-top: 1rpx solid #f1f5f9;
}

.records-row-swipe__delete {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 160rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ef4444;
    color: #ffffff;
    font-size: 32rpx;
    font-weight: 700;
}

.records-row {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(132rpx, auto) minmax(0, 1fr) auto auto;
    align-items: flex-start;
    gap: 18rpx;
    min-height: 96rpx;
    padding: 24rpx 28rpx;
    box-sizing: border-box;
    background: #ffffff;
    transition: transform 0.18s ease;
}

.records-row__time {
    color: #64748b;
    font-size: 26rpx;
    font-weight: 600;
    white-space: nowrap;
    line-height: 1.5;
    padding-top: 4rpx;
}

.records-row__main {
    min-width: 0;
}

.records-row__value {
    color: #1e293b;
    font-size: 36rpx;
    font-weight: 700;
    line-height: 1.25;
}

.records-row__heart {
    margin-top: 6rpx;
    color: #94a3b8;
    font-size: 26rpx;
    line-height: 1.4;
}

.records-row__recorder {
    margin-top: 6rpx;
    color: #cbd5e1;
    font-size: 22rpx;
    line-height: 1.4;
}

.records-row__status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40rpx;
    padding: 8rpx 16rpx;
    border-radius: 12rpx;
    font-size: 22rpx;
    font-weight: 700;
    white-space: nowrap;
    box-sizing: border-box;
}

.records-status--normal {
    background: #e6f6ec;
    color: #227442;
}

.records-status--warning {
    background: #f6f4e0;
    color: #e38902;
}

.records-status--danger {
    background: #FAE4E2;
    color: #b8342d;
}

.records-status--strong {
    font-weight: 800;
}

.records-row__arrow {
    color: #cbd5e1;
    font-size: 36rpx;
    line-height: 1;
}

.records-footer {
    padding: 36rpx 0 12rpx;
    color: #94a3b8;
    font-size: 26rpx;
    text-align: center;
    line-height: 1.6;
}

.records-export-canvas {
    position: fixed;
    left: -9999px;
    top: 0;
    width: 375px;
    pointer-events: none;
}

.records-export-sheet,
.records-export-preview,
.records-permission-modal,
.records-dialog-layer,
.records-feedback-layer {
    position: fixed;
    inset: 0;
}

.records-export-sheet {
    z-index: 30;
}

.records-export-sheet__mask,
.records-permission-modal__mask,
.records-dialog-layer__mask,
.records-feedback-layer__mask {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.5);
}

.records-export-sheet__panel {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    padding: 24rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
    border-radius: 40rpx 40rpx 0 0;
    background: #ffffff;
}

.records-export-sheet__handle {
    width: 80rpx;
    height: 8rpx;
    margin: 0 auto;
    border-radius: 999rpx;
    background: #e2e8f0;
}

.records-export-sheet__title {
    margin-top: 32rpx;
    color: #1e293b;
    font-size: 36rpx;
    font-weight: 800;
    text-align: center;
}

.records-export-sheet__subtitle {
    margin-top: 12rpx;
    color: #94a3b8;
    font-size: 24rpx;
    text-align: center;
}

.records-export-sheet__ranges {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20rpx;
    margin-top: 40rpx;
}

.records-export-sheet__range {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 28rpx 0;
    border: 2rpx solid #e2e8f0;
    border-radius: 24rpx;
    text-align: center;
}

.records-export-sheet__range.is-active {
    border-color: #3182f7;
}

.records-export-sheet__range-number {
    color: #1e293b;
    font-size: 52rpx;
    font-weight: 900;
    line-height: 1;
}

.records-export-sheet__range.is-active .records-export-sheet__range-number {
    color: #3182f7;
}

.records-export-sheet__range-label {
    margin-top: 4rpx;
    color: #94a3b8;
    font-size: 22rpx;
}

.records-export-sheet__actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20rpx;
    margin-top: 32rpx;
}

.records-export-sheet__action {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 88rpx;
    margin: 0;
    border-radius: 20rpx;
    padding: 24rpx 28rpx;
    font-size: 32rpx;
    font-weight: 600;
    text-align: center;
    box-sizing: border-box;
}

.records-export-sheet__action::after {
    border: 0;
}

.records-export-sheet__action--primary {
    background: #3182f7;
    color: #ffffff;
}

.records-export-sheet__action--secondary {
    background: #f1f5f9;
    color: #64748b;
}

.records-export-sheet__cancel {
    margin-top: 28rpx;
    color: #94a3b8;
    font-size: 30rpx;
    text-align: center;
}

.records-export-preview {
    z-index: 35;
    display: flex;
    flex-direction: column;
    background: #eef3fb;
}

.records-export-preview__header {
    padding: 36rpx 32rpx 20rpx;
}

.records-export-preview__title {
    color: #1e293b;
    font-size: 36rpx;
    font-weight: 800;
}

.records-export-preview__subtitle {
    margin-top: 10rpx;
    color: #94a3b8;
    font-size: 24rpx;
    line-height: 1.6;
}

.records-export-preview__scroll {
    flex: 1;
    min-height: 0;
    padding: 8rpx 32rpx 196rpx;
    box-sizing: border-box;
}

.records-export-preview__card {
    border-radius: 32rpx;
    background: #ffffff;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    padding: 24rpx;
}

.records-export-preview__image {
    display: block;
    width: 100%;
    border-radius: 20rpx;
}

.records-export-preview__actions {
    position: fixed;
    right: 0;
    bottom: 0;
    left: 0;
    display: flex;
    gap: 16rpx;
    padding: 20rpx 32rpx calc(env(safe-area-inset-bottom) + 28rpx);
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 -12rpx 32rpx rgba(17, 24, 39, 0.08);
}

.records-export-preview__button {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 88rpx;
    margin: 0;
    border-radius: 20rpx;
    font-size: 32rpx;
    font-weight: 700;
    text-align: center;
}

.records-export-preview__button::after {
    border: 0;
}

.records-export-preview__button--primary {
    background: #3478f6;
    color: #ffffff;
}

.records-export-preview__button--secondary {
    background: #ffffff;
    border: 2rpx solid #e2e8f0;
    color: #64748b;
}

.records-permission-modal {
    z-index: 40;
}

.records-permission-modal__panel {
    position: absolute;
    left: 32rpx;
    right: 32rpx;
    background: #ffffff;
}

.records-permission-modal__panel {
    top: 50%;
    transform: translateY(-50%);
    padding: 40rpx;
    border-radius: 24rpx;
    box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.12);
}

.records-permission-modal__title,
.records-dialog-layer__title,
.records-feedback-layer__title {
    color: #1e293b;
    font-size: 36rpx;
    font-weight: 700;
    line-height: 1.4;
}

.records-permission-modal__subtitle,
.records-dialog-layer__text {
    margin-top: 12rpx;
    color: #94a3b8;
    font-size: 24rpx;
    line-height: 1.6;
}

.records-permission-modal__step {
    margin-top: 16rpx;
    color: #64748b;
    font-size: 26rpx;
    line-height: 1.6;
}

.records-permission-modal__actions {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
    margin-top: 28rpx;
}

.records-permission-modal__button {
    min-height: 84rpx;
    margin: 0;
    border-radius: 20rpx;
    font-size: 28rpx;
    font-weight: 700;
}

.records-permission-modal__button::after {
    border: 0;
}

.records-permission-modal__button--primary {
    background: #3182f7;
    color: #ffffff;
}

.records-permission-modal__button--secondary {
    background: #f1f5f9;
    color: #64748b;
}

.records-dialog-layer {
    z-index: 9999;
}

.records-dialog-layer__card,
.records-feedback-layer__card {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 1;
    background: #ffffff;
    box-sizing: border-box;
    text-align: center;
}

.records-dialog-layer__card {
    width: calc(100% - 96rpx);
    transform: translate(-50%, -50%);
    padding: 48rpx;
    border-radius: 32rpx;
    border: 1rpx solid #e2e8f0;
    box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.1);
    animation: records-dialog-enter 220ms ease-out;
}

.records-dialog-layer__icon-wrap,
.records-feedback-layer__icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 80rpx;
    height: 80rpx;
    margin-bottom: 24rpx;
    border-radius: 24rpx;
    background: #fef2f2;
}

.records-dialog-layer__icon,
.records-feedback-layer__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #ef4444;
    font-size: 40rpx;
}

.records-dialog-layer__confirm {
    width: 100%;
    min-height: 88rpx;
    margin: 40rpx 0 0;
    padding: 28rpx;
    border-radius: 24rpx;
    background: #ef4444;
    color: #ffffff;
    font-size: 30rpx;
    font-weight: 700;
}

.records-dialog-layer__confirm::after {
    border: 0;
}

.records-dialog-layer__cancel {
    margin-top: 24rpx;
    color: #94a3b8;
    font-size: 28rpx;
}

.records-feedback-layer {
    z-index: 9999;
}

.records-feedback-layer__card {
    width: 400rpx;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24rpx;
    padding: 48rpx;
    border-radius: 32rpx;
    box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.16);
    animation: records-feedback-enter 220ms
        cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.records-feedback-layer__title {
    margin-top: 0;
    font-size: 32rpx;
}

@keyframes records-dialog-enter {
    from {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.9);
    }

    to {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
    }
}

@keyframes records-feedback-enter {
    from {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.8);
    }

    to {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
    }
}
