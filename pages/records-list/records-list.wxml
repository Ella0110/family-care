<view class="page page-root" style="--font-scale: {{fontScale}};">
  <view class="records-header">
    <view class="records-header__back" bindtap="handleBack">返回</view>
    <view class="records-header__text">
      <view class="records-header__title">{{profileName}} 的记录</view>
      <view class="records-header__subtitle">按测量时间倒序展示</view>
    </view>
  </view>

  <view wx:if="{{isViewerMode}}" class="records-viewer-tip">
    你以查看者身份访问，不可修改记录
  </view>

  <view class="card records-actions">
    <button
      class="btn-secondary records-actions__button"
      bindtap="handleExportImage"
      loading="{{isExportingImage}}"
      disabled="{{isLoading || !!errorText || isExportingImage || isExportingCsv}}"
    >
      导出图片
    </button>
    <button
      class="btn-secondary records-actions__button"
      bindtap="handleExportData"
      loading="{{isExportingCsv}}"
      disabled="{{isLoading || !!errorText || isExportingImage || isExportingCsv}}"
    >
      导出数据
    </button>
    <button
      wx:if="{{canWriteCurrentProfile}}"
      class="btn-primary records-actions__button"
      bindtap="handleImportRecords"
      disabled="{{isExportingImage || isExportingCsv}}"
    >
      导入
    </button>
  </view>

  <view wx:if="{{isLoading}}" class="card records-state">
    <view class="records-state__title">正在加载记录</view>
    <view class="records-state__text">请稍候...</view>
  </view>

  <view wx:elif="{{errorText}}" class="card records-state">
    <view class="records-state__title">暂时无法加载</view>
    <view class="records-state__text">{{errorText}}</view>
    <button class="btn-secondary records-state__button" bindtap="loadRecords">重试</button>
  </view>

  <view wx:elif="{{!hasRecords}}" class="card records-state">
    <view class="records-state__title">还没有记录，去录入第一条</view>
    <button wx:if="{{canWriteCurrentProfile}}" class="btn-primary records-state__button" bindtap="handleAddRecord">录入血压</button>
  </view>

  <view wx:else class="records-groups">
    <view wx:for="{{groups}}" wx:key="date" class="records-group">
      <view class="records-group__title">{{item.label}}</view>
      <view class="card records-group__card">
        <view
          wx:for="{{item.records}}"
          wx:for-item="record"
          wx:key="_id"
          class="record-row"
          data-record-id="{{record._id}}"
          bindtap="handleRecordTap"
        >
          <view class="record-row__time">{{record.timeText}}</view>
          <view class="record-row__main">
            <view class="record-row__value">{{record.valueText}}</view>
            <view wx:if="{{record.heartRateText}}" class="record-row__heart">{{record.heartRateText}}</view>
          </view>
          <bp-status-tag
            systolic="{{record.payload.systolic}}"
            diastolic="{{record.payload.diastolic}}"
            reference-lines="{{referenceLines}}"
          />
          <view wx:if="{{!isViewerMode}}" class="record-row__arrow">›</view>
        </view>
      </view>
    </view>

    <view wx:if="{{hasMore}}" class="records-more">
      还有更多记录未加载
    </view>
  </view>

  <canvas
    id="recordsExportCanvas"
    type="2d"
    class="records-export-canvas"
    style="height: {{exportCanvasHeight}}px;"
  ></canvas>

  <view wx:if="{{showPermissionModal}}" class="records-permission-modal">
    <view class="records-permission-modal__mask"></view>
    <view class="records-permission-modal__panel card">
      <view class="records-permission-modal__title">无法保存图片</view>
      <view class="records-permission-modal__subtitle">需要开启“相册写入”权限</view>
      <view class="records-permission-modal__step">步骤 1：点击下方“去设置”按钮</view>
      <view class="records-permission-modal__step">步骤 2：将“添加到相册”设为允许</view>
      <view class="records-permission-modal__actions">
        <button class="btn-primary records-permission-modal__button" bindtap="handleOpenPermissionSetting">
          去设置
        </button>
        <button class="btn-secondary records-permission-modal__button" bindtap="handleClosePermissionModal">
          暂不下载
        </button>
      </view>
    </view>
  </view>
</view>
