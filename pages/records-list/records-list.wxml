<view class="page page-root records-page">
  <view wx:if="{{isViewerMode}}" class="records-viewer-tip" style="font-size:{{fs.label}}; margin-bottom: {{fs.spaceMD}};">
    当前以查看者身份访问，仅可查看和导出记录
  </view>

  <view class="records-toolbar" style="gap: {{fs.spaceMD}}; margin-bottom: {{fs.spaceLG}};">
    <picker
      mode="multiSelector"
      range="{{monthPickerRanges}}"
      value="{{monthPickerValue}}"
      bindchange="handleMonthPickerChange"
    >
      <view class="records-toolbar__month">
        <view class="records-toolbar__month-bar"></view>
        <text class="records-toolbar__month-text" style="font-size:{{fs.body}}">{{monthLabel}}</text>
        <text class="records-toolbar__month-arrow" style="font-size:{{fs.caption}}">▼</text>
      </view>
    </picker>

    <view class="records-toolbar__actions">
      <button
        class="records-toolbar__export"
        bindtap="handleOpenExportSheet"
        disabled="{{isLoading || !!errorText || isExportingImage || isExportingCsv}}"
       style="font-size:{{fs.secondary}}">
        下载 ↓
      </button>
      <button
        wx:if="{{canWriteCurrentProfile}}"
        class="records-toolbar__import"
        bindtap="handleImportRecords"
        disabled="{{isExportingImage || isExportingCsv}}"
       style="font-size:{{fs.secondary}}">
        导入 ↑
      </button>
    </view>
  </view>

  <view wx:if="{{isLoading}}" class="records-state-card">
      <view class="records-state-card__title" style="font-size:{{fs.title}}">正在加载记录</view>
    <view class="records-state-card__text" style="font-size:{{fs.secondary}}; margin-top: {{fs.spaceSM}};">请稍候...</view>
  </view>

  <view wx:elif="{{errorText}}" class="records-state-card">
    <view class="records-state-card__title" style="font-size:{{fs.title}}">暂时无法加载</view>
    <view class="records-state-card__text" style="font-size:{{fs.secondary}}; margin-top: {{fs.spaceSM}};">{{errorText}}</view>
    <button class="records-state-card__button" bindtap="loadAllRecords" style="font-size:{{fs.button}}; margin-top: {{fs.spaceLG}}; padding: {{fs.spaceMD}} {{fs.spaceLG}};">重试</button>
  </view>

  <view wx:elif="{{!hasRecords}}" class="records-state-card">
    <view class="records-state-card__title" style="font-size:{{fs.title}}">{{monthLabel}} 暂无记录</view>
    <view class="records-state-card__text" style="font-size:{{fs.secondary}}; margin-top: {{fs.spaceSM}};">可以切换月份查看历史记录，或导入历史数据。</view>
    <view class="records-state-card__actions" style="margin-top: {{fs.spaceLG}};">
      <button wx:if="{{canWriteCurrentProfile}}" class="records-state-card__button records-state-card__button--ghost" bindtap="handleImportRecords" style="font-size:{{fs.button}}; margin-top: 0; padding: {{fs.spaceMD}} {{fs.spaceLG}};">导入记录</button>
    </view>
  </view>

  <view wx:else class="records-groups">
    <view wx:for="{{groups}}" wx:key="date" class="records-group" id="{{item.anchorId}}">
      <view class="records-group__title" style="font-size:{{fs.body}}; margin-bottom: {{fs.spaceMD}};">{{item.label}}</view>

      <view class="records-group__card">
        <view
          wx:for="{{item.records}}"
          wx:for-item="record"
          wx:key="_id"
          class="records-row-swipe"
        >
          <view
            wx:if="{{record.canDelete}}"
            class="records-row-swipe__delete"
            data-record-id="{{record._id}}"
            bindtap="handleDeleteActionTap"
           style="font-size:{{fs.button}}">
            删除
          </view>

          <view
            class="records-row"
            style="{{record.swipeOffsetText}}; padding: {{fs.spaceLG}} {{fs.spaceLG}};"
            data-record-id="{{record._id}}"
            bindtap="handleRecordTap"
            bindtouchstart="handleRowTouchStart"
            bindtouchmove="handleRowTouchMove"
            bindtouchend="handleRowTouchEnd"
            bindtouchcancel="handleRowTouchEnd"
          >
            <view class="records-row__time" style="font-size:{{fs.secondary}}">{{record.timeText}}</view>
            <view class="records-row__main">
              <view class="records-row__value" style="font-size:{{fs.title}}">{{record.valueText}}</view>
              <view wx:if="{{record.heartRateText}}" class="records-row__heart" style="font-size:{{fs.secondary}}">{{record.heartRateText}}</view>
              <view wx:if="{{record.recorderText}}" class="records-row__recorder" style="font-size:{{fs.caption}}">{{record.recorderText}}</view>
            </view>
            <view class="records-row__status {{record.statusClassName}}" style="font-size:{{fs.caption}}; padding: {{fs.spaceXS}} {{fs.spaceMD}};">{{record.statusText}}</view>
            <view wx:if="{{!isViewerMode}}" class="records-row__arrow" style="font-size:{{fs.title}}">›</view>
          </view>
        </view>
      </view>
    </view>

    <view class="records-footer" style="font-size:{{fs.secondary}}">
      <text wx:if="{{hasMore}}">— 该月仅显示前 200 条记录 —</text>
      <text wx:else>— 已加载全部记录 —</text>
    </view>
  </view>

  <record-panel
    show="{{showRecordPanel}}"
    profile-id="{{profileId}}"
    edit-record="{{editingRecord}}"
    bind:success="handleRecordPanelSuccess"
    bind:delete="handleRecordPanelDelete"
    bind:close="handleCloseRecordPanel"
    bind:visibilitychange="handleRecordPanelVisibilityChange"
  />

  <canvas
    id="recordsExportCanvas"
    type="2d"
    class="records-export-canvas"
    style="height: {{exportCanvasHeight}}px;"
  ></canvas>

  <view wx:if="{{showExportSheet}}" class="records-export-sheet">
    <view class="records-export-sheet__mask" bindtap="handleCloseExportSheet"></view>
    <view class="records-export-sheet__panel" style="padding: {{fs.spaceLG}} {{fs.spaceXL}} calc(env(safe-area-inset-bottom) + {{fs.spaceXL}});">
      <view class="records-export-sheet__handle"></view>
      <view class="records-export-sheet__title" style="font-size:{{fs.title}}; margin-top: {{fs.spaceXL}};">导出数据</view>
      <view class="records-export-sheet__subtitle" style="font-size:{{fs.label}}; margin-top: {{fs.spaceSM}};">选择需要导出的时间范围</view>

      <view class="records-export-sheet__ranges" style="gap: {{fs.spaceMD}}; margin-top: {{fs.spaceXL}};">
        <view
          wx:for="{{[7, 30, 90]}}"
          wx:key="*this"
          class="records-export-sheet__range {{selectedExportDays === item ? 'is-active' : ''}}"
          data-days="{{item}}"
          bindtap="handleSelectExportDays"
        >
          <view class="records-export-sheet__range-number" style="font-size:{{fs.title}}">{{item}}</view>
          <view class="records-export-sheet__range-label" style="font-size:{{fs.caption}}">天</view>
        </view>
      </view>

      <view class="records-export-sheet__actions" style="gap: {{fs.spaceMD}}; margin-top: {{fs.spaceXL}};">
        <button
          class="records-export-sheet__action records-export-sheet__action--primary"
          bindtap="handleExportImage"
          loading="{{isExportingImage}}"
          disabled="{{isExportingImage || isExportingCsv}}"
         style="font-size:{{fs.button}}; padding: {{fs.spaceLG}} {{fs.spaceLG}};">
          导出图片
        </button>
        <button
          class="records-export-sheet__action records-export-sheet__action--secondary"
          bindtap="handleExportData"
          loading="{{isExportingCsv}}"
          disabled="{{isExportingImage || isExportingCsv}}"
         style="font-size:{{fs.button}}; padding: {{fs.spaceLG}} {{fs.spaceLG}};">
          导出数据
        </button>
      </view>

      <view class="records-export-sheet__cancel" bindtap="handleCloseExportSheet" style="font-size:{{fs.body}}; margin-top: {{fs.spaceLG}};">取消</view>
    </view>
  </view>

  <view wx:if="{{showExportPreview}}" class="records-export-preview">
    <view class="records-export-preview__header">
      <view class="records-export-preview__title" style="font-size:{{fs.title}}">导出预览</view>
      <view class="records-export-preview__subtitle" style="font-size:{{fs.label}}">确认图片内容完整后，再保存到相册。</view>
    </view>
    <scroll-view scroll-y class="records-export-preview__scroll">
      <view class="records-export-preview__card">
        <image
          src="{{exportTempFilePath}}"
          mode="widthFix"
          class="records-export-preview__image"
        />
      </view>
    </scroll-view>
    <view class="records-export-preview__actions" style="gap: {{fs.spaceMD}}; padding: {{fs.spaceMD}} {{fs.spaceXL}} calc(env(safe-area-inset-bottom) + {{fs.spaceLG}});">
      <button
        class="records-export-preview__button records-export-preview__button--secondary"
        bindtap="onCancelPreview"
        disabled="{{isExportingImage}}"
       style="font-size:{{fs.button}}">
        取消
      </button>
      <button
        class="records-export-preview__button records-export-preview__button--primary"
        bindtap="onConfirmSave"
        loading="{{isExportingImage}}"
        disabled="{{isExportingImage}}"
       style="font-size:{{fs.button}}">
        保存到相册
      </button>
    </view>
  </view>

  <view wx:if="{{showPermissionModal}}" class="records-permission-modal">
    <view class="records-permission-modal__mask"></view>
    <view class="records-permission-modal__panel">
      <view class="records-permission-modal__title" style="font-size:{{fs.title}}">无法保存图片</view>
      <view class="records-permission-modal__subtitle" style="font-size:{{fs.body}}">需要开启“相册写入”权限</view>
      <view class="records-permission-modal__step" style="font-size:{{fs.label}}">步骤 1：点击下方“去设置”按钮</view>
      <view class="records-permission-modal__step" style="font-size:{{fs.label}}">步骤 2：将“添加到相册”设为允许</view>
      <view class="records-permission-modal__actions">
        <button class="records-permission-modal__button records-permission-modal__button--primary" bindtap="handleOpenPermissionSetting" style="font-size:{{fs.body}}">
          去设置
        </button>
        <button class="records-permission-modal__button records-permission-modal__button--secondary" bindtap="handleClosePermissionModal" style="font-size:{{fs.body}}">
          暂不下载
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{showDeleteDialog}}" class="records-dialog-layer">
    <view class="records-dialog-layer__mask" bindtap="handleDeleteDialogMaskTap"></view>
    <view class="records-dialog-layer__card">
      <view class="records-dialog-layer__icon-wrap">
        <view class="records-dialog-layer__icon">🗑</view>
      </view>
      <view class="records-dialog-layer__title" style="font-size:{{fs.title}}">确定删除此记录？</view>
      <view class="records-dialog-layer__text" style="font-size:{{fs.label}}">
        删除后数据将无法恢复，并会影响您的健康趋势分析。
      </view>
      <button
        class="records-dialog-layer__confirm"
        bindtap="handleDeleteDialogConfirm"
        loading="{{isDeletingRecord}}"
        disabled="{{isDeletingRecord}}"
       style="font-size:{{fs.body}}">
        确定删除
      </button>
      <view class="records-dialog-layer__cancel" bindtap="handleDeleteDialogCancel" style="font-size:{{fs.body}}">取消</view>
    </view>
  </view>

  <view wx:if="{{feedbackVisible}}" class="records-feedback-layer">
    <view class="records-feedback-layer__mask"></view>
    <view class="records-feedback-layer__card">
      <view class="records-feedback-layer__icon-wrap">
        <view class="records-feedback-layer__icon">🗑</view>
      </view>
      <view class="records-feedback-layer__title" style="font-size:{{fs.title}}">{{feedbackTitle}}</view>
    </view>
  </view>
</view>
