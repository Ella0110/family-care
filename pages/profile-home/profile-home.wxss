.profile-home-page {
    padding: 0 28rpx;
    padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

.profile-home-page .card {
    box-sizing: border-box;
    padding: 48rpx;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-card);
}

.profile-home__topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.profile-home__title {
    display: inline-flex;
    align-items: center;
    gap: 10rpx;
    color: var(--text-primary);
    font-size: 36rpx;
    font-weight: 800;
    letter-spacing: -0.5px;
    line-height: 1.35;
}

.profile-home__arrow {
    font-size: 22rpx;
    color: var(--text-secondary);
}

.profile-home__settings {
    color: var(--text-link);
    font-weight: 600;
    border-radius: var(--radius-sm);
    display: inline-block;
    background-color: rgba(255, 255, 255, 0.9);
    border: none;
    font-size: 26rpx;
    padding: 10rpx 28rpx;
    box-shadow: var(--shadow-card);
    line-height: 1.4;
}

.profile-home__empty {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 200rpx - env(safe-area-inset-bottom));
    box-sizing: border-box;
}

.profile-home__state-title {
    font-size: 36rpx;
    font-weight: 700;
}

.profile-home__state-text {
    color: var(--text-secondary);
    font-size: 26rpx;
    line-height: 1.6;
}

.profile-home__content {
    display: flex;
    flex-direction: column;
    gap: 0;
}

.profile-home__hero {
    margin-top: 0;
}

.profile-home__hero-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.profile-home__avatar {
    width: 88rpx;
    height: 88rpx;
    border-radius: var(--radius-full);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: var(--bg-primary-light);
    font-weight: 600;
    font-size: 36rpx;
    box-shadow: var(--shadow-card);
}

.profile-home__hero-body {
    flex: 1;
    min-width: 0;
}

.profile-home__hero-name-row {
    display: flex;
    align-items: center;
    min-width: 0;
}

.profile-home__hero-name-group {
    flex: 1;
    display: flex;
    align-items: center;
    min-width: 0;
    overflow: hidden;
}

.profile-home__hero-name {
    flex-shrink: 1;
    font-size: 36rpx;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 1rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.profile-home__hero-age {
    margin-left: 8rpx;
    padding: 6rpx 14rpx;
    border-radius: var(--radius-sm);
    font-size: 22rpx;
    background: var(--bg-input);
    color: var(--text-secondary);
    font-weight: 500;
    flex-shrink: 0;
}

.profile-home__hero-birth {
    color: var(--text-secondary);
    font-size: 26rpx;
    line-height: 1.5;
}

.profile-home__edit {
    font-weight: 600;
    flex-shrink: 0;
    background: var(--bg-input);
    padding: 8rpx 20rpx;
    border-radius: var(--radius-sm);
    font-size: 26rpx;
    color: var(--text-secondary);
    line-height: 1.4;
}

.profile-home__overview {
    border-top: 1rpx solid var(--border-light);
}

.profile-home__overview-title,
.profile-home__section-title {
    font-size: 24rpx;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    line-height: 1.5;
}

.profile-home__overview-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 20rpx;
}

.profile-home__overview-row:first-child {
    margin-top: 0;
}

.profile-home__overview-label {
    color: var(--text-secondary);
    font-size: 24rpx;
    line-height: 1.5;
}

.profile-home__overview-value {
    color: var(--text-primary);
    font-size: 30rpx;
    font-weight: 500;
    line-height: 1.5;
}

.profile-home__overview-value--danger {
    color: var(--color-danger);
    font-weight: 700;
}

.profile-home__section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.profile-home__section-title {
    margin-bottom: 0;
}

.profile-home__members-scroll {
    white-space: nowrap;
    margin-top: 0;
}

.profile-home__members-scroll::-webkit-scrollbar {
    height: 4rpx;
}

.profile-home__members-scroll::-webkit-scrollbar-track {
    background: rgba(142, 142, 147, 0.16);
    border-radius: var(--radius-full);
}

.profile-home__members-scroll::-webkit-scrollbar-thumb {
    background: rgba(60, 60, 67, 0.28);
    border-radius: var(--radius-full);
}

.profile-home__members-list {
    display: inline-flex;
    gap: 24rpx;
    padding-bottom: 8rpx;
}

.profile-home__member {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    width: 132rpx;
}

.profile-home__member-avatar {
    width: 88rpx;
    height: 88rpx;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--bg-input);
    color: var(--color-primary);
    font-size: 30rpx;
    font-weight: 600;
}

.profile-home__member-avatar--image {
    background: var(--border-light);
}

.profile-home__member-avatar--placeholder {
    background: transparent;
}

.profile-home__member-avatar-image {
    width: 100%;
    height: 100%;
}

.profile-home__member-avatar-icon {
    width: 88rpx;
    height: 88rpx;
}

.profile-home__member-avatar--invite {
    border: 2rpx dashed var(--border-light);
    background: transparent;
    color: var(--color-primary);
    font-size: 40rpx;
}

.profile-home__member-name-row {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 6rpx;
    min-height: 38rpx;
    text-align: center;
}

.profile-home__member-name {
    font-weight: 600;
    text-align: center;
    white-space: normal;
    color: var(--text-primary);
    font-size: 26rpx;
    line-height: 1.4;
}

.profile-home__member-role {
    text-align: center;
    margin-top: 4rpx;
    color: var(--text-secondary);
    font-size: 22rpx;
    font-weight: 400;
    line-height: 1.4;
}

.profile-home__shortcut-grid {
    display: flex;
    flex-direction: column;
}

.profile-home__shortcut {
    display: flex;
    align-items: center;
    gap: 20rpx;
}

.profile-home__shortcut--disabled {
    opacity: 0.5;
}

.profile-home__shortcut-icon {
    width: 80rpx;
    height: 80rpx;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-on-primary);
    font-size: 36rpx;
    font-weight: 700;
    flex-shrink: 0;
}

.profile-home__shortcut-icon--report {
    background: var(--bg-primary-light);
}

.profile-home__shortcut-icon--medication {
    background: var(--bg-warning-light);
}

.profile-home__shortcut-body {
    flex: 1;
    min-width: 0;
}

.profile-home__shortcut-title {
    color: var(--text-primary);
    font-size: 30rpx;
    font-weight: 700;
    line-height: 1.5;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.profile-home__shortcut-subtitle {
    margin-top: 6rpx;
    color: var(--text-secondary);
    font-size: 26rpx;
    line-height: 1.6;
}

.profile-home__shortcut-arrow {
    color: var(--text-tertiary);
    font-size: 36rpx;
    flex-shrink: 0;
}

.profile-home__settings-card {
    display: flex;
    flex-direction: column;
    gap: 18rpx;
    margin-top: 0;
}

.profile-home__settings-stack {
    display: flex;
    flex-direction: column;
}

.profile-home__setting-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24rpx;
}

.profile-home__setting-main {
    flex: 1;
    min-width: 0;
}

.profile-home__setting-title {
    color: var(--text-primary);
    font-size: 30rpx;
    font-weight: 600;
    line-height: 1.5;
}

.profile-home__setting-subtitle {
    margin-top: 4rpx;
    color: var(--text-secondary);
    font-size: 26rpx;
    line-height: 1.6;
}

.profile-home__font-scale-control {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4rpx;
    padding: 4rpx;
    background: var(--bg-input);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
}

.profile-home__font-scale-pill {
    min-width: 84rpx;
    min-height: 60rpx;
    padding: 10rpx 24rpx;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    background: transparent;
    font-size: 26rpx;
    font-weight: 600;
    box-sizing: border-box;
}

.profile-home__font-scale-pill--active {
    background: var(--color-primary);
    color: var(--text-on-primary);
    box-shadow: var(--shadow-button);
}

.profile-home__danger {
    display: flex;
    align-items: center;
    gap: 18rpx;
}

.profile-home__danger-icon {
    width: 64rpx;
    height: 64rpx;
    border-radius: var(--radius-sm);
    background: rgba(180, 35, 24, 0.08);
    color: var(--color-danger);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36rpx;
    flex-shrink: 0;
}

.profile-home__danger-main {
    flex: 1;
}

.profile-home__danger-title {
    color: var(--color-danger);
    font-size: 30rpx;
    font-weight: 700;
    line-height: 1.5;
}

.profile-home__danger-subtitle {
    margin-top: 4rpx;
    color: var(--text-secondary);
    font-size: 22rpx;
    line-height: 1.6;
}

.profile-home__loading {
    min-height: calc(100vh - 64rpx);
    background: var(--bg-page);
    display: flex;
    align-items: center;
    justify-content: center;
}

.profile-home__loading-spinner {
    width: 56rpx;
    height: 56rpx;
    border-radius: var(--radius-full);
    border: 6rpx solid var(--border-light);
    border-top-color: var(--color-primary);
    animation: profile-home-loading-spin 0.8s linear infinite;
}

.profile-home__invite-dialog {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 56rpx;
    box-sizing: border-box;
}

.profile-home__invite-mask {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    background: rgba(0, 0, 0, 0.5);
}

.profile-home__invite-sheet {
    position: relative;
    z-index: 1;
    width: 85%;
    max-width: 640rpx;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-float);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: stretch;
}

.profile-home__invite-title {
    color: var(--text-primary);
    font-size: 34rpx;
    font-weight: 700;
    line-height: 1.5;
    text-align: center;
}

.profile-home__invite-text {
    color: var(--text-secondary);
    font-size: 26rpx;
    line-height: 1.7;
    text-align: center;
}

.profile-home__invite-input {
    width: 100%;
    min-height: 96rpx;
    border-radius: var(--radius-sm);
    border: 2rpx solid var(--border-light);
    background: var(--bg-input);
    color: var(--text-primary);
    line-height: 1.5;
    box-sizing: border-box;
}

.profile-home__invite-share {
    width: 100%;
    min-height: 96rpx;
    border-radius: var(--radius-md);
    background: var(--color-primary);
    color: var(--text-on-primary);
    font-size: 32rpx;
    font-weight: 700;
    line-height: 1.4;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    box-shadow: var(--shadow-button);
}

.profile-home__invite-share::after,
.profile-home__invite-cancel::after {
    border: none;
}

.profile-home__invite-cancel {
    padding: 8rpx 0;
    background: transparent;
    color: var(--text-secondary);
    font-size: 28rpx;
    font-weight: 500;
    line-height: 1.5;
}

.profile-home__self-action-dialog {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 60;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0;
    box-sizing: border-box;
}

.profile-home__self-action-mask {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    background: rgba(0, 0, 0, 0.5);
}

.profile-home__self-action-sheet {
    position: relative;
    z-index: 1;
    width: 100%;
    border-radius: 32rpx 32rpx 0 0;
    padding: 40rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    background: var(--bg-card);
    box-shadow: var(--shadow-sheet);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    animation: profile-home-sheet-up 0.18s ease-out;
}

.profile-home__self-action-avatar {
    width: 104rpx;
    height: 104rpx;
    margin: 0 auto;
    border-radius: var(--radius-full);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-primary-light);
    color: var(--text-primary);
    font-size: 40rpx;
    font-weight: 700;
}

.profile-home__self-action-avatar--image {
    background: var(--border-light);
}

.profile-home__self-action-avatar--placeholder {
    background: transparent;
}

.profile-home__self-action-avatar-image {
    width: 100%;
    height: 100%;
}

.profile-home__self-action-avatar-icon {
    width: 104rpx;
    height: 104rpx;
}

.profile-home__self-action-name {
    color: var(--text-primary);
    font-size: 32rpx;
    font-weight: 700;
    line-height: 1.4;
    text-align: center;
}

.profile-home__self-action-role {
    color: var(--text-secondary);
    font-size: 24rpx;
    line-height: 1.5;
    text-align: center;
}

.profile-home__self-action-divider {
    width: 100%;
    height: 1rpx;
    background: var(--border-light);
}

.profile-home__self-action-button {
    width: 100%;
    min-height: 96rpx;
    border-radius: var(--radius-md);
    font-size: 32rpx;
    font-weight: 700;
    line-height: 1.4;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
}

.profile-home__self-action-button::after,
.profile-home__self-action-cancel::after {
    border: none;
}

.profile-home__self-action-button--primary {
    background: var(--color-primary);
    color: var(--text-on-primary);
    box-shadow: var(--shadow-button);
}

.profile-home__self-action-cancel {
    padding: 0;
    background: transparent;
    color: var(--text-secondary);
    font-size: 28rpx;
    font-weight: 500;
    line-height: 1.5;
}

@keyframes profile-home-sheet-up {
    from {
        transform: translateY(24rpx);
        opacity: 0;
    }

    to {
        transform: translateY(0);
        opacity: 1;
    }
}

@keyframes profile-home-loading-spin {
    from {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }
}
