.profile-home-page {
    padding: 0 28rpx;
    padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

.profile-home-page .card {
    box-sizing: border-box;
    padding: 48rpx;
    border-radius: 32rpx;
    background: var(--color-card);
    box-shadow: 0 12rpx 32rpx rgba(17, 24, 39, 0.08);
}

.profile-home__topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 24rpx;
    margin-bottom: 24rpx;
}

.profile-home__title {
    display: inline-flex;
    align-items: center;
    gap: 10rpx;
    color: var(--color-text);
    font-size: 36rpx;
    font-weight: 800;
    letter-spacing: -0.5px;
    line-height: 1.35;
}

.profile-home__arrow {
    font-size: 22rpx;
    color: var(--color-text-secondary);
}

.profile-home__settings {
    color: var(--color-primary);
    font-weight: 600;
    border-radius: 16rpx;
    display: inline-block;
    background-color: rgba(255, 255, 255, 0.9);
    border: none;
    font-size: 26rpx;
    padding: 10rpx 28rpx;
    box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
    line-height: 1.4;
}

.profile-home__empty {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 200rpx - env(safe-area-inset-bottom));
    box-sizing: border-box;
}

.profile-home__state-title {
    font-size: 36rpx;
    font-weight: 700;
}

.profile-home__state-text {
    margin-top: 12rpx;
    color: var(--color-text-secondary);
    font-size: 26rpx;
    line-height: 1.6;
}

.profile-home__content {
    display: flex;
    flex-direction: column;
    gap: 0;
}

.profile-home__hero {
    margin-top: 0;
}

.profile-home__hero-top {
    display: flex;
    align-items: center;
    gap: 24rpx;
}

.profile-home__avatar {
    width: 88rpx;
    height: 88rpx;
    border-radius: 50%;
    /* background: rgba(49, 130, 247, 0.14); */
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    font-weight: 600;
    font-size: 36rpx;
    box-shadow: inset 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.profile-home__hero-body {
    flex: 1;
    min-width: 0;
}

.profile-home__hero-name-row {
    display: flex;
    align-items: center;
    gap: 12rpx;
    flex-wrap: wrap;
}

.profile-home__hero-name {
    font-size: 36rpx;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 1rpx;
}

.profile-home__hero-age {
    padding: 6rpx 14rpx;
    border-radius: 16rpx;
    font-size: 22rpx;
    background: #f2f2f7;
    color: #8e8e93;
    font-weight: 500;
}

.profile-home__hero-birth {
    margin-top: 8rpx;
    color: var(--color-text-secondary);
    font-size: 26rpx;
    line-height: 1.5;
}

.profile-home__edit {
    font-weight: 600;
    flex-shrink: 0;
    background: #f2f2f7;
    padding: 8rpx 20rpx;
    border-radius: 16rpx;
    font-size: 26rpx;
    color: #8e8e93;
    line-height: 1.4;
}

.profile-home__overview {
    margin-top: 28rpx;
    border-top: 1rpx solid #f1f5f9;
    padding-top: 24rpx;
}

.profile-home__overview-title,
.profile-home__section-title {
    font-size: 24rpx;
    font-weight: 600;
    color: #94a3b8;
    letter-spacing: 0.05em;
    line-height: 1.5;
}

.profile-home__overview-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 20rpx;
}

.profile-home__overview-row:first-child {
    margin-top: 0;
}

.profile-home__overview-label {
    color: #8e8e93;
    font-size: 24rpx;
    line-height: 1.5;
}

.profile-home__overview-value {
    color: #1c1c1e;
    font-size: 30rpx;
    font-weight: 500;
    line-height: 1.5;
}

.profile-home__overview-value--danger {
    color: var(--color-danger);
    font-weight: 700;
}

.profile-home__section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.profile-home__section-title {
    margin-top: 32rpx;
    margin-bottom: 0;
}

.profile-home__members.card {
    margin-top: 16rpx;
    padding: 28rpx 32rpx;
}

.profile-home__members-scroll {
    white-space: nowrap;
    margin-top: 0;
}

.profile-home__members-list {
    display: inline-flex;
    gap: 24rpx;
    padding-bottom: 8rpx;
}

.profile-home__member {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    width: 132rpx;
}

.profile-home__member-avatar {
    width: 88rpx;
    height: 88rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #f0f4f8;
    color: #007aff;
    font-size: 30rpx;
    font-weight: 600;
}

.profile-home__member-avatar--image {
    background: #e5e7eb;
}

.profile-home__member-avatar--placeholder {
    background: transparent;
}

.profile-home__member-avatar-image {
    width: 100%;
    height: 100%;
}

.profile-home__member-avatar-icon {
    width: 88rpx;
    height: 88rpx;
}

.profile-home__member-avatar--invite {
    border: 2rpx dashed #d1d9e0;
    background: transparent;
    color: #007aff;
    font-size: 40rpx;
}

.profile-home__member-name-row {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 6rpx;
    margin-top: 12rpx;
    min-height: 38rpx;
    text-align: center;
}

.profile-home__member-name {
    font-weight: 600;
    text-align: center;
    white-space: normal;
    color: #1d1d1f;
    font-size: 26rpx;
    line-height: 1.4;
}

.profile-home__member-role {
    text-align: center;
    margin-top: 4rpx;
    color: #8e8e93;
    font-size: 22rpx;
    font-weight: 400;
    line-height: 1.4;
}

.profile-home__shortcut-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 16rpx;
}

.profile-home__shortcut {
    display: flex;
    align-items: center;
    gap: 20rpx;
}

.profile-home__shortcut + .profile-home__shortcut {
    margin-top: 16rpx;
}

.profile-home__shortcut--disabled {
    opacity: 0.5;
}

.profile-home__shortcut-icon {
    width: 80rpx;
    height: 80rpx;
    border-radius: 24rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-size: 36rpx;
    font-weight: 700;
    flex-shrink: 0;
}

.profile-home__shortcut-icon--report {
    background: #ebf5ff;
}

.profile-home__shortcut-icon--medication {
    background: #fff7ed;
}

.profile-home__shortcut-body {
    flex: 1;
    min-width: 0;
}

.profile-home__shortcut-title {
    color: var(--color-text);
    font-size: 30rpx;
    font-weight: 700;
    line-height: 1.5;
}

.profile-home__shortcut-subtitle {
    margin-top: 6rpx;
    color: var(--color-text-secondary);
    font-size: 26rpx;
    line-height: 1.6;
}

.profile-home__shortcut-arrow {
    color: #9ca3af;
    font-size: 36rpx;
}

.profile-home__settings-card {
    display: flex;
    flex-direction: column;
    gap: 18rpx;
    margin-top: 0;
}

.profile-home__settings-stack {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 16rpx;
}

.profile-home__settings-card + .profile-home__settings-card {
    margin-top: 16rpx;
}

.profile-home__setting-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24rpx;
}

.profile-home__setting-main {
    flex: 1;
    min-width: 0;
}

.profile-home__setting-title {
    color: var(--color-text);
    font-size: 30rpx;
    font-weight: 600;
    line-height: 1.5;
}

.profile-home__setting-subtitle {
    margin-top: 4rpx;
    color: var(--color-text-secondary);
    font-size: 26rpx;
    line-height: 1.6;
}

.profile-home__font-scale-control {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4rpx;
    padding: 4rpx;
    background: #f1f5f9;
    border-radius: 16rpx;
    flex-shrink: 0;
}

.profile-home__font-scale-pill {
    min-width: 84rpx;
    min-height: 60rpx;
    padding: 10rpx 24rpx;
    border-radius: 16rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #94a3b8;
    background: transparent;
    font-size: 26rpx;
    font-weight: 600;
    box-sizing: border-box;
}

.profile-home__font-scale-pill--active {
    background: #3182f7;
    color: #ffffff;
    box-shadow: 0 2rpx 8rpx rgba(49, 130, 247, 0.2);
}

.profile-home__danger {
    display: flex;
    align-items: center;
    gap: 18rpx;
    margin-top: 16rpx;
    padding: 0 32rpx;
    background: transparent;
    box-shadow: none;
}

.profile-home__danger-icon {
    width: 64rpx;
    height: 64rpx;
    border-radius: 16rpx;
    background: rgba(180, 35, 24, 0.08);
    color: var(--color-danger);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36rpx;
    flex-shrink: 0;
}

.profile-home__danger-main {
    flex: 1;
}

.profile-home__danger-title {
    color: var(--color-danger);
    font-size: 30rpx;
    font-weight: 700;
    line-height: 1.5;
}

.profile-home__danger-subtitle {
    margin-top: 4rpx;
    color: #94a3b8;
    font-size: 22rpx;
    line-height: 1.6;
}

.profile-home__loading {
    min-height: calc(100vh - 64rpx);
    background: #f2f2f7;
    display: flex;
    align-items: center;
    justify-content: center;
}

.profile-home__loading-spinner {
    width: 56rpx;
    height: 56rpx;
    border-radius: 50%;
    border: 6rpx solid #e5e7eb;
    border-top-color: var(--color-primary);
    animation: profile-home-loading-spin 0.8s linear infinite;
}

.profile-home__invite-dialog {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 56rpx;
    box-sizing: border-box;
}

.profile-home__invite-mask {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    background: rgba(0, 0, 0, 0.5);
}

.profile-home__invite-sheet {
    position: relative;
    z-index: 1;
    width: 85%;
    max-width: 640rpx;
    border-radius: 32rpx;
    padding: 48rpx;
    background: #ffffff;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: stretch;
}

.profile-home__invite-title {
    color: #0f172a;
    font-size: 34rpx;
    font-weight: 700;
    line-height: 1.5;
    text-align: center;
}

.profile-home__invite-text {
    margin-top: 16rpx;
    color: #94a3b8;
    font-size: 26rpx;
    line-height: 1.7;
    text-align: center;
}

.profile-home__invite-input {
    width: 100%;
    min-height: 96rpx;
    margin-top: 32rpx;
    padding: 20rpx 24rpx;
    border-radius: 16rpx;
    border: 2rpx solid #e2e8f0;
    background: #f8fafc;
    color: #0f172a;
    line-height: 1.5;
    box-sizing: border-box;
}

.profile-home__invite-share {
    margin-top: 48rpx;
    width: 100%;
    min-height: 96rpx;
    border-radius: 24rpx;
    background: #3478f6;
    color: #ffffff;
    font-size: 32rpx;
    font-weight: 700;
    line-height: 1.4;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
}

.profile-home__invite-share::after,
.profile-home__invite-cancel::after {
    border: none;
}

.profile-home__invite-cancel {
    margin-top: 24rpx;
    padding: 8rpx 0;
    background: transparent;
    color: #94a3b8;
    font-size: 28rpx;
    font-weight: 500;
    line-height: 1.5;
}

.profile-home__self-action-dialog {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 60;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0;
    box-sizing: border-box;
}

.profile-home__self-action-mask {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    background: rgba(0, 0, 0, 0.5);
}

.profile-home__self-action-sheet {
    position: relative;
    z-index: 1;
    width: 100%;
    border-radius: 32rpx 32rpx 0 0;
    padding: 40rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));
    background: #ffffff;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    animation: profile-home-sheet-up 0.18s ease-out;
}

.profile-home__self-action-avatar {
    width: 104rpx;
    height: 104rpx;
    margin: 0 auto;
    border-radius: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%);
    color: #0f172a;
    font-size: 40rpx;
    font-weight: 700;
}

.profile-home__self-action-avatar--image {
    background: #e5e7eb;
}

.profile-home__self-action-avatar--placeholder {
    background: transparent;
}

.profile-home__self-action-avatar-image {
    width: 100%;
    height: 100%;
}

.profile-home__self-action-avatar-icon {
    width: 104rpx;
    height: 104rpx;
}

.profile-home__self-action-name {
    margin-top: 20rpx;
    color: #0f172a;
    font-size: 32rpx;
    font-weight: 700;
    line-height: 1.4;
    text-align: center;
}

.profile-home__self-action-role {
    margin-top: 8rpx;
    color: #94a3b8;
    font-size: 24rpx;
    line-height: 1.5;
    text-align: center;
}

.profile-home__self-action-divider {
    width: 100%;
    height: 1rpx;
    margin: 28rpx 0 32rpx;
    background: #e5e7eb;
}

.profile-home__self-action-button {
    width: 100%;
    min-height: 96rpx;
    border-radius: 24rpx;
    font-size: 32rpx;
    font-weight: 700;
    line-height: 1.4;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
}

.profile-home__self-action-button::after,
.profile-home__self-action-cancel::after {
    border: none;
}

.profile-home__self-action-button--primary {
    background: #007aff;
    color: #ffffff;
}

.profile-home__self-action-cancel {
    margin-top: 20rpx;
    padding: 0;
    background: transparent;
    color: #94a3b8;
    font-size: 28rpx;
    font-weight: 500;
    line-height: 1.5;
}

@keyframes profile-home-sheet-up {
    from {
        transform: translateY(24rpx);
        opacity: 0;
    }

    to {
        transform: translateY(0);
        opacity: 1;
    }
}

@keyframes profile-home-loading-spin {
    from {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }
}
