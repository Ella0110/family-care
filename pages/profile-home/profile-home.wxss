.profile-home-page {
  padding-bottom: calc(188rpx + env(safe-area-inset-bottom));
}

.profile-home__topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.profile-home__title {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text);
}

.profile-home__arrow {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.profile-home__settings {
  color: var(--color-primary);
  font-size: var(--font-base);
  font-weight: 600;
}

.profile-home__empty {
  padding-top: 120rpx;
}

.profile-home__state-title {
  font-size: var(--font-lg);
  font-weight: 700;
}

.profile-home__state-text {
  margin-top: 12rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-base);
}

.profile-home__content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.profile-home__hero-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.profile-home__avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: rgba(49, 130, 247, 0.14);
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-xl);
  font-weight: 700;
  flex-shrink: 0;
}

.profile-home__hero-body {
  flex: 1;
  min-width: 0;
}

.profile-home__hero-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.profile-home__hero-name {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text);
}

.profile-home__hero-age {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
}

.profile-home__hero-birth {
  margin-top: 10rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
}

.profile-home__edit {
  color: var(--color-primary);
  font-size: var(--font-base);
  font-weight: 600;
  flex-shrink: 0;
}

.profile-home__overview {
  margin-top: 28rpx;
  border-top: 1rpx solid #e5e7eb;
  padding-top: 24rpx;
}

.profile-home__overview-title,
.profile-home__section-title {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text);
}

.profile-home__overview-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 18rpx;
}

.profile-home__overview-label {
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
  flex-shrink: 0;
}

.profile-home__overview-value {
  text-align: right;
  color: var(--color-text);
  font-size: var(--font-base);
}

.profile-home__overview-value--danger {
  color: var(--color-danger);
  font-weight: 700;
}

.profile-home__section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.profile-home__members-scroll {
  margin-top: 22rpx;
  white-space: nowrap;
}

.profile-home__members-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 4rpx;
}

.profile-home__member {
  width: 132rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
}

.profile-home__member-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #eff6ff;
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  font-weight: 700;
  overflow: hidden;
}

.profile-home__member-avatar--image {
  background: #e5e7eb;
}

.profile-home__member-avatar-image {
  width: 100%;
  height: 100%;
}

.profile-home__member-avatar--invite {
  border: 2rpx dashed #93c5fd;
  background: #f8fbff;
}

.profile-home__member-name {
  margin-top: 12rpx;
  color: var(--color-text);
  font-size: var(--font-sm);
  font-weight: 600;
  text-align: center;
  white-space: normal;
  line-height: 1.4;
}

.profile-home__member-role {
  margin-top: 4rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-xs);
  text-align: center;
}

.profile-home__shortcut-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.profile-home__shortcut {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-home__shortcut--disabled {
  opacity: 0.5;
}

.profile-home__shortcut-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: var(--font-lg);
  font-weight: 700;
  flex-shrink: 0;
}

.profile-home__shortcut-icon--report {
  background: #3182f7;
}

.profile-home__shortcut-icon--medication {
  background: #f59e0b;
}

.profile-home__shortcut-body {
  flex: 1;
  min-width: 0;
}

.profile-home__shortcut-title {
  color: var(--color-text);
  font-size: var(--font-base);
  font-weight: 700;
}

.profile-home__shortcut-subtitle {
  margin-top: 6rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
}

.profile-home__shortcut-arrow {
  color: #9ca3af;
  font-size: var(--font-lg);
}

.profile-home__settings-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.profile-home__setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding-top: 6rpx;
}

.profile-home__setting-row--link {
  padding-top: 22rpx;
  border-top: 1rpx solid #e5e7eb;
}

.profile-home__setting-main {
  flex: 1;
  min-width: 0;
}

.profile-home__setting-title {
  color: var(--color-text);
  font-size: var(--font-base);
  font-weight: 600;
}

.profile-home__setting-subtitle {
  margin-top: 4rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
}

.profile-home__setting-link {
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
}

.profile-home__danger {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.profile-home__danger-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: rgba(180, 35, 24, 0.08);
  color: var(--color-danger);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  flex-shrink: 0;
}

.profile-home__danger-main {
  flex: 1;
}

.profile-home__danger-title {
  color: var(--color-danger);
  font-size: var(--font-base);
  font-weight: 700;
}

.profile-home__danger-subtitle {
  margin-top: 4rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
}

.profile-home__footer-link {
  color: var(--color-primary);
  font-size: var(--font-base);
  font-weight: 600;
  text-align: center;
  padding: 12rpx 0;
}

.profile-home__loading {
  min-height: calc(100vh - 64rpx);
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-home__loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 6rpx solid #e5e7eb;
  border-top-color: var(--color-primary);
  animation: profile-home-loading-spin 0.8s linear infinite;
}

@keyframes profile-home-loading-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
