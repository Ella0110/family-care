<view class="page page-root profile-home-page">
  <view wx:if="{{pageReady}}">
    <view wx:if="{{profiles.length > 0}}" class="profile-home__topbar">
      <view class="profile-home__title" bindtap="handleOpenProfileSwitcher" style="font-size:{{fs.title}}">
        用户档案
        <text wx:if="{{hasProfile}}" class="profile-home__arrow" style="font-size:{{fs.caption}}">▼</text>
      </view>
      <view class="profile-home__settings" bindtap="handleOpenUserSettings" style="font-size:{{fs.secondary}}">设置</view>
    </view>

    <view wx:if="{{!hasProfile}}" class="profile-home__empty">
      <profile-empty-guide bind:create="handleCreateProfile" />
    </view>

    <view wx:elif="{{errorText}}" class="card profile-home__state">
      <view class="profile-home__state-title" style="font-size:{{fs.title}}">暂时无法加载</view>
      <view class="profile-home__state-text" style="font-size:{{fs.secondary}}">{{errorText}}</view>
    </view>

    <view wx:else class="profile-home__content">
      <view class="card profile-home__hero">
        <view class="profile-home__hero-top">
          <view class="profile-home__avatar" style="font-size:{{fs.title}}">{{profileInitial}}</view>
          <view class="profile-home__hero-body">
            <view class="profile-home__hero-name-row">
              <view class="profile-home__hero-name" style="font-size:{{fs.title}}">{{profileName}}</view>
              <view wx:if="{{profileAgeText}}" class="profile-home__hero-age" style="font-size:{{fs.caption}}">{{profileAgeText}}</view>
            </view>
            <view wx:if="{{profileBirthYearText}}" class="profile-home__hero-birth" style="font-size:{{fs.secondary}}">{{profileBirthYearText}}</view>
          </view>
          <view wx:if="{{canEditCurrentProfile}}" class="profile-home__edit" style="font-size:{{fs.secondary}}" bindtap="handleEditProfile">编辑 ></view>
        </view>

        <view class="profile-home__overview">
          <!-- <view class="profile-home__overview-title" style="font-size:{{fs.label}}">健康概览</view> -->

          <view class="profile-home__overview-row">
            <view class="profile-home__overview-label" style="font-size:{{fs.label}}">当前血压</view>
            <view class="profile-home__overview-value {{latestRecordDisplay && latestRecordDisplay.isAbnormal ? 'profile-home__overview-value--danger' : ''}}" style="font-size:{{fs.body}}">
              {{latestRecordDisplay ? latestRecordDisplay.bpText : '暂无记录'}}
            </view>
          </view>

          <view class="profile-home__overview-row">
            <view class="profile-home__overview-label" style="font-size:{{fs.label}}">当前心率</view>
            <view class="profile-home__overview-value" style="font-size:{{fs.body}}">{{latestRecordDisplay ? latestRecordDisplay.heartRateText : '--'}}</view>
          </view>

          <view wx:if="{{hasMedicationSummary}}" class="profile-home__overview-row">
            <view class="profile-home__overview-label" style="font-size:{{fs.label}}">长期用药</view>
            <view class="profile-home__overview-value" style="font-size:{{fs.body}}">{{medicationText}}</view>
          </view>

          <view wx:if="{{emergencyText}}" class="profile-home__overview-row">
            <view class="profile-home__overview-label" style="font-size:{{fs.label}}">紧急联系人</view>
            <view class="profile-home__overview-value" style="font-size:{{fs.body}}">{{emergencyText}}</view>
          </view>
        </view>
      </view>
      <view class="profile-home__section-title" style="font-size:{{fs.label}}">成员管理（{{memberCount}}/10）</view>
      <view class="card profile-home__members">
        <scroll-view scroll-x class="profile-home__members-scroll">
          <view class="profile-home__members-list">
            <view
              wx:for="{{memberItems}}"
              wx:key="relationshipId"
              class="profile-home__member"
              data-relationship-id="{{item.relationshipId}}"
              bindtap="handleMemberTap"
            >
              <view wx:if="{{item.avatarUrl}}" class="profile-home__member-avatar profile-home__member-avatar--image" style="font-size:{{fs.body}}">
                <image class="profile-home__member-avatar-image" src="{{item.avatarUrl}}" mode="aspectFill" />
              </view>
              <view wx:else class="profile-home__member-avatar" style="font-size:{{fs.body}}">{{item.avatarFallback}}</view>
              <view class="profile-home__member-name" style="font-size:{{fs.secondary}}">{{item.displayName}}</view>
              <view class="profile-home__member-role" style="font-size:{{fs.caption}}">{{item.roleLabel}}</view>
            </view>

            <view
              wx:if="{{canInviteCurrentProfile}}"
              class="profile-home__member profile-home__member--invite"
              bindtap="handleCreateInvitation"
            >
              <view class="profile-home__member-avatar profile-home__member-avatar--invite" style="font-size:{{fs.body}}">+</view>
              <view class="profile-home__member-name" style="font-size:{{fs.secondary}}">邀请</view>
            </view>
          </view>
        </scroll-view>
      </view>
      <view class="profile-home__section-head">
          <view class="profile-home__section-title" style="font-size:{{fs.label}}">功能</view>
    </view>
      <view class="profile-home__shortcut-grid">
        <view
          class="card profile-home__shortcut {{!hasLatestRecord ? 'profile-home__shortcut--disabled' : ''}}"
          bindtap="handleOpenReport"
        >
          <view class="profile-home__shortcut-icon profile-home__shortcut-icon--report">📄</view>
          <view class="profile-home__shortcut-body">
            <view class="profile-home__shortcut-title" style="font-size:{{fs.body}}">生成血压报告</view>
            <view class="profile-home__shortcut-subtitle" style="font-size:{{fs.secondary}}">选择时间段，导出专业报表</view>
          </view>
          <view class="profile-home__shortcut-arrow" style="font-size:{{fs.title}}">›</view>
        </view>

        <view class="card profile-home__shortcut" bindtap="handleOpenMedicationManagement">
          <view class="profile-home__shortcut-icon profile-home__shortcut-icon--medication">💊</view>
          <view class="profile-home__shortcut-body">
            <view class="profile-home__shortcut-title" style="font-size:{{fs.body}}">药物管理</view>
            <view class="profile-home__shortcut-subtitle" style="font-size:{{fs.secondary}}">{{medicationShortcutText}}</view>
          </view>
          <view class="profile-home__shortcut-arrow" style="font-size:{{fs.title}}">›</view>
        </view>
      </view>

      <view class="profile-home__section-title" style="font-size:{{fs.label}}">快捷设置</view>
      <view class="profile-home__settings-stack">

        <view class="card profile-home__settings-card">
          <view class="profile-home__setting-row">
            <view class="profile-home__setting-main">
              <view class="profile-home__setting-title" style="font-size:{{fs.body}}">异常血压通知</view>
              <view class="profile-home__setting-subtitle" style="font-size:{{fs.secondary}}">血压异常时推送提醒</view>
            </view>
            <switch
              checked="{{activeRelationshipSubscribeAlerts}}"
              color="#3182F7"
              bindchange="handleToggleSubscribeAlerts"
            />
          </view>
        </view>
        <view class="card profile-home__settings-card">
          <view class="profile-home__setting-row">
            <view class="profile-home__setting-main">
              <view class="profile-home__setting-title" style="font-size:{{fs.body}}">字体大小</view>
            </view>
            <view class="profile-home__font-scale-control">
              <view
                wx:for="{{fontScaleOptions}}"
                wx:key="value"
                class="profile-home__font-scale-pill {{selectedFontScale === item.value ? 'profile-home__font-scale-pill--active' : ''}}"
                data-scale="{{item.value}}"
                bindtap="handleSelectFontScale"
               style="font-size:{{fs.secondary}}">
                {{item.label}}
              </view>
            </view>
          </view>
        </view>
      </view>
      <block wx:if="{{canManageCurrentProfile}}">
        <view class="profile-home__section-head">
          <view class="profile-home__section-title" style="font-size:{{fs.label}}">其他</view>
        </view>
        <view class="card profile-home__danger" bindtap="handleDeleteProfile">
          <view class="profile-home__danger-icon" style="font-size:{{fs.title}}">⚠</view>
          <view class="profile-home__danger-main">
            <view class="profile-home__danger-title" style="font-size:{{fs.body}}">删除档案</view>
            <view class="profile-home__danger-subtitle" style="font-size:{{fs.caption}}">删除后所有记录无法恢复</view>
          </view>
        </view>
      </block>

      <!-- <view class="profile-home__footer-link" bindtap="handleOpenProfileSwitcher" style="font-size:{{fs.body}}">查看全部档案</view> -->
    </view>
  </view>

  <view wx:else class="profile-home__loading">
    <view class="profile-home__loading-spinner"></view>
  </view>

  <view wx:if="{{showInviteDialog}}" class="profile-home__invite-dialog">
    <view class="profile-home__invite-mask" bindtap="handleCloseInviteDialog"></view>
    <view class="profile-home__invite-sheet" catchtap="noop">
      <view class="profile-home__invite-title" style="font-size:{{fs.body}}">
        邀请家人关注「{{profileName}}」的健康
      </view>
      <block wx:if="{{showNicknameInput}}">
        <view class="profile-home__invite-text" style="font-size:{{fs.secondary}}">
          请先设置你的昵称，让家人知道是谁邀请的
        </view>
        <input
          class="profile-home__invite-input"
          type="nickname"
          maxlength="20"
          placeholder="你的昵称"
          value="{{inviteNicknameDraft}}"
          bindinput="handleInviteNicknameInput"
          style="font-size:{{fs.body}}"
        />
        <button
          class="profile-home__invite-share"
          bindtap="handleConfirmInviteNickname"
          loading="{{isSavingInviteNickname}}"
          disabled="{{isSavingInviteNickname}}"
          style="font-size:{{fs.button}}"
        >
          确认并分享
        </button>
      </block>
      <block wx:else>
        <view class="profile-home__invite-text" style="font-size:{{fs.secondary}}">
          对方将可以查看 {{profileName}} 的血压和用药情况，但不能修改数据。
        </view>
        <button
          class="profile-home__invite-share"
          open-type="share"
          bindtap="handleInviteShareTap"
          data-share-type="invite"
          style="font-size:{{fs.button}}"
        >
          分享给家人
        </button>
      </block>
      <button
        class="profile-home__invite-cancel"
        bindtap="handleCloseInviteDialog"
        style="font-size:{{fs.secondary}}"
      >
        取消
      </button>
    </view>
  </view>

  <view wx:if="{{showSelfActionDialog}}" class="profile-home__self-action-dialog">
    <view class="profile-home__self-action-mask" bindtap="handleCloseSelfActionDialog"></view>
    <view class="profile-home__self-action-sheet" catchtap="noop">
      <view wx:if="{{selfActionDialogMember.avatarUrl}}" class="profile-home__self-action-avatar profile-home__self-action-avatar--image" style="font-size:{{fs.title}}">
        <image class="profile-home__self-action-avatar-image" src="{{selfActionDialogMember.avatarUrl}}" mode="aspectFill" />
      </view>
      <view wx:else class="profile-home__self-action-avatar" style="font-size:{{fs.title}}">
        {{selfActionDialogMember.avatarFallback}}
      </view>
      <view class="profile-home__self-action-name" style="font-size:{{fs.body}}">我</view>
      <view class="profile-home__self-action-role" style="font-size:{{fs.caption}}">
        当前角色：{{selfActionDialogMember.roleLabel}}
      </view>
      <view class="profile-home__self-action-divider"></view>

      <block wx:if="{{!selfActionDialogHasAvatar}}">
        <button
          class="profile-home__self-action-button profile-home__self-action-button--wechat"
          bindtap="handleSelfActionAuthorizeTap"
          style="font-size:{{fs.button}}"
        >
          一键授权微信昵称与头像
        </button>
        <button
          class="profile-home__self-action-button profile-home__self-action-button--outline"
          bindtap="handleOpenUserProfileEdit"
          style="font-size:{{fs.button}}"
        >
          自行修改个人资料
        </button>
      </block>
      <button
        wx:else
        class="profile-home__self-action-button profile-home__self-action-button--primary"
        bindtap="handleOpenUserProfileEdit"
        style="font-size:{{fs.button}}"
      >
        修改个人资料
      </button>
      <button
        class="profile-home__self-action-cancel"
        bindtap="handleCloseSelfActionDialog"
        style="font-size:{{fs.secondary}}"
      >
        取消
      </button>
    </view>
  </view>

  <view wx:if="{{showQuickProfileSyncDialog}}" class="profile-home__quick-sync-dialog">
    <view class="profile-home__quick-sync-mask" bindtap="handleCloseQuickProfileSyncDialog"></view>
    <view class="profile-home__quick-sync-sheet" catchtap="noop">
      <view class="profile-home__quick-sync-title" style="font-size:{{fs.body}}">
        一键同步微信昵称与头像
      </view>
      <view class="profile-home__quick-sync-text" style="font-size:{{fs.secondary}}">
        先选择微信头像，再补充昵称，即可同步到家人协作资料中。
      </view>

      <button
        class="profile-home__quick-sync-avatar-button"
        open-type="chooseAvatar"
        bindchooseavatar="handleQuickProfileSyncChooseAvatar"
      >
        <view
          wx:if="{{quickProfileSyncForm.avatarUrl}}"
          class="profile-home__quick-sync-avatar profile-home__quick-sync-avatar--image"
          style="font-size:{{fs.title}}"
        >
          <image
            class="profile-home__quick-sync-avatar-image"
            src="{{quickProfileSyncForm.avatarUrl}}"
            mode="aspectFill"
          />
        </view>
        <view
          wx:else
          class="profile-home__quick-sync-avatar"
          style="font-size:{{fs.title}}"
        >
          {{quickProfileSyncForm.avatarFallback}}
        </view>
        <view class="profile-home__quick-sync-avatar-badge">微信头像</view>
      </button>

      <view class="profile-home__quick-sync-field-head">
        <view class="profile-home__quick-sync-label" style="font-size:{{fs.secondary}}">昵称</view>
        <view class="profile-home__quick-sync-count" style="font-size:{{fs.caption}}">
          {{quickProfileSyncForm.nickname.length}}/20
        </view>
      </view>
      <input
        class="profile-home__quick-sync-input"
        type="nickname"
        maxlength="20"
        placeholder="请输入昵称"
        value="{{quickProfileSyncForm.nickname}}"
        focus="{{quickProfileSyncNicknameFocus}}"
        bindinput="handleQuickProfileSyncNicknameInput"
        style="font-size:{{fs.body}}"
      />

      <view
        wx:if="{{quickProfileSyncErrorText}}"
        class="profile-home__quick-sync-error"
        style="font-size:{{fs.caption}}"
      >
        {{quickProfileSyncErrorText}}
      </view>

      <button
        class="profile-home__quick-sync-save"
        bindtap="handleQuickProfileSyncSave"
        loading="{{isSavingQuickProfileSync}}"
        disabled="{{isSavingQuickProfileSync}}"
        style="font-size:{{fs.button}}"
      >
        保存同步
      </button>
      <button
        class="profile-home__quick-sync-cancel"
        bindtap="handleCloseQuickProfileSyncDialog"
        disabled="{{isSavingQuickProfileSync}}"
        style="font-size:{{fs.secondary}}"
      >
        取消
      </button>
    </view>
  </view>

  <profile-switcher
    show="{{showProfileSwitcher}}"
    profiles="{{profiles}}"
    current-profile-id="{{currentProfileId}}"
    return-tab="/pages/profile-home/profile-home"
    bind:select="handleSelectProfile"
    bind:close="handleCloseProfileSwitcher"
    bind:openfullprofilelist="handleOpenFullProfileList"
    bind:visibilitychange="handleProfileSwitcherVisibilityChange"
  />

  <member-panel
    show="{{showMemberPanel}}"
    member="{{selectedMember}}"
    current-user-role="{{relationshipRole}}"
    profile-id="{{currentProfileId}}"
    bind:close="handleMemberPanelClose"
    bind:visibilitychange="handleMemberPanelVisibilityChange"
    bind:memberChanged="handleMemberChanged"
  />

  <profile-edit-panel
    show="{{showEditPanel}}"
    profile-id="{{currentProfileId}}"
    bind:saved="handleProfileEditSaved"
    bind:close="handleCloseEditPanel"
    bind:visibilitychange="handleEditPanelVisibilityChange"
  />

  <subscribe-guide
    show="{{showSubscribeGuide}}"
    inviter-name="{{subscribeGuideInviterName}}"
    profile-name="{{subscribeGuideProfileName}}"
    bind:result="handleSubscribeGuideResult"
    bind:reject="handleSubscribeGuideReject"
  />
</view>
