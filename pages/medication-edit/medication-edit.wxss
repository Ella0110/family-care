.medication-list-page {
  min-height: 100vh;
  padding: 32rpx 28rpx calc(188rpx + env(safe-area-inset-bottom));
  background: #eef3fb;
}

.medication-list__state,
.medication-empty,
.medication-card {
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
}

.medication-list__state {
  padding: 48rpx 40rpx;
}

.medication-list__state-title,
.medication-empty__title {
  color: #0f172a;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.35;
}

.medication-list__state-text,
.medication-empty__text {
  margin-top: 12rpx;
  color: #94a3b8;
  font-size: 26rpx;
  line-height: 1.7;
}

.medication-list__retry {
  margin-top: 28rpx;
}

.medication-list__section + .medication-list__section {
  margin-top: 32rpx;
}

.medication-list__section-title {
  margin: 0 8rpx 16rpx;
  color: #94a3b8;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  line-height: 1.5;
}

.medication-list__cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.medication-card-swipe {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  background: transparent;
}

.medication-card-swipe__delete {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 148rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ef4444;
  border-radius: 0 32rpx 32rpx 0;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
}

.medication-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
  transition: transform 0.18s ease;
}

.medication-card__content {
  flex: 1;
  min-width: 0;
}

.medication-card__title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.5;
}

.medication-card__meta,
.medication-card__timing {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

.medication-card__arrow {
  color: #cbd5e1;
  font-size: 36rpx;
  font-weight: 500;
  line-height: 1;
}

.medication-card--historical .medication-card__title {
  color: #334155;
}

.medication-card--historical .medication-card__meta,
.medication-card--historical .medication-card__timing {
  color: #94a3b8;
}

.medication-empty {
  margin-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 72rpx 48rpx;
}

.medication-empty__button {
  width: 100%;
  margin-top: 32rpx;
}

.medication-list__footer {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.medication-list__footer-button {
  width: 100%;
  min-height: 96rpx;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 14rpx 28rpx rgba(52, 120, 246, 0.18);
  font-size: 32rpx;
  line-height: 1.4;
  box-sizing: border-box;
}

.medication-list__footer-button::after,
.medication-empty__button::after,
.medication-list__retry::after {
  border: 0;
}
