.medication-list-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 32rpx 28rpx calc(188rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: var(--bg-page);
}

.medication-list__state,
.medication-card {
  border-radius: var(--radius-lg);
  background: var(--bg-card);
  box-shadow: var(--shadow-card);
}

.medication-list__state {
  padding: 48rpx 40rpx;
}

.medication-list__state-title,
.medication-empty__title {
  color: var(--text-primary);
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.35;
}

.medication-list__state-text,
.medication-empty__text {
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.7;
}

.medication-list__retry {
  margin-top: 28rpx;
}

.medication-list__section + .medication-list__section {
  margin-top: 32rpx;
}

.medication-list__section-title {
  margin: 0 8rpx 16rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  line-height: 1.5;
}

.medication-list__cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.medication-card-swipe {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-lg);
  background: transparent;
}

.medication-card-swipe__delete {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 148rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-danger);
  border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
  color: var(--text-on-primary);
  font-size: 32rpx;
  font-weight: 700;
}

.medication-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
  transition: transform 0.18s ease;
}

.medication-card__content {
  flex: 1;
  min-width: 0;
}

.medication-card__title {
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.5;
}

.medication-card__meta,
.medication-card__timing {
  margin-top: 10rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.6;
}

.medication-card__arrow {
  color: var(--text-tertiary);
  font-size: 36rpx;
  font-weight: 500;
  line-height: 1;
}

.medication-card--historical .medication-card__title {
  color: var(--text-secondary);
}

.medication-card--historical .medication-card__meta,
.medication-card--historical .medication-card__timing {
  color: var(--text-secondary);
}

.medication-empty {
  margin-top: auto;
  margin-bottom: auto;
  width: 100%;
  max-width: 620rpx;
  align-self: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 72rpx 48rpx;
  /* 保留定制玻璃态，不走标准 card token */
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--radius-lg);
  /* 保留定制阴影，不走 shadow token */
  box-shadow: 0 8px 32px rgba(49, 130, 247, 0.08);
}

.medication-empty__button {
  width: 100%;
  margin-top: 32rpx;
  box-shadow: var(--shadow-button);
}

.medication-list__footer {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.medication-list__footer-button {
  width: 100%;
  min-height: 96rpx;
  padding: 24rpx 32rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-button);
  font-size: 32rpx;
  line-height: 1.4;
  box-sizing: border-box;
}

.medication-list__footer-button::after,
.medication-empty__button::after,
.medication-list__retry::after {
  border: 0;
}
