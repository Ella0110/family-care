.page {
  background: var(--bg-page);
}

.medication-detail-page {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
  background: var(--bg-page);
}

.medication-detail__state,
.medication-detail__form {
  border-radius: var(--radius-lg);
  background: var(--bg-card);
  box-shadow: var(--shadow-card);
}

.medication-detail__state {
  margin-bottom: 20rpx;
  padding: 32rpx;
}

.medication-detail__state-text {
  color: var(--text-secondary);
  font-size: 30rpx;
  line-height: 1.6;
}

.medication-detail__form {
  padding: 36rpx 32rpx;
}

.form-item + .form-item {
  margin-top: 36rpx;
}

.form-label {
  margin-bottom: 16rpx;
  color: var(--text-secondary);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
}

.form-required,
.medication-detail__error,
.medication-detail__delete {
  color: var(--color-danger);
}

.form-input,
.picker-field {
  box-sizing: border-box;
  width: 100%;
  min-height: 88rpx;
  padding: 20rpx 28rpx;
  border: 2rpx solid var(--border-light);
  border-radius: var(--radius-sm);
  background: var(--bg-input);
  color: var(--text-primary);
  font-size: 30rpx;
  line-height: 1.5;
}

.form-input--custom {
  margin-top: 16rpx;
}

.picker-field {
  display: flex;
  align-items: center;
}

.picker-field.is-placeholder,
.form-placeholder {
  color: var(--text-secondary);
}

.date-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16rpx;
  align-items: center;
}

.date-clear {
  flex-shrink: 0;
  min-width: 88rpx;
  color: var(--text-link);
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.form-help {
  margin-top: 10rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
  line-height: 1.5;
}

.medication-detail__actions {
  padding: 32rpx 8rpx 0;
}

.medication-detail__error {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--bg-danger-light);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.6;
}

.medication-detail__button,
.medication-detail__cancel {
  width: 100%;
  min-height: 96rpx;
  padding: 24rpx 32rpx;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
  box-sizing: border-box;
}

.medication-detail__button {
  box-shadow: var(--shadow-button);
}

.medication-detail__button::after,
.medication-detail__delete::after,
.medication-detail__cancel::after {
  border: 0;
}

.medication-detail__delete {
  margin-top: 20rpx;
  background: transparent;
  font-size: 30rpx;
  font-weight: 700;
}

.medication-detail__cancel {
  margin-top: 12rpx;
  background: transparent;
  color: var(--text-secondary);
}
