.page-root {
  min-height: 100vh;
  padding: 24rpx 32rpx 60rpx;
  background: var(--bg-page);
}

.settings-group + .settings-group {
  margin-top: 32rpx;
}

.settings-group--first {
  margin-top: 0;
}

.settings-group--last {
  padding-bottom: 0;
}

.settings-group__title {
  margin: 0 0 16rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.05em;
}

.settings-card {
  padding: 36rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.settings-card__divider {
  height: 1rpx;
  margin: 28rpx 0;
  background: var(--bg-input);
}

.settings-profile {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.settings-profile__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: var(--color-primary);
  color: var(--text-on-primary);
  font-size: 32rpx;
  font-weight: 800;
  overflow: hidden;
}

.settings-profile__avatar--image {
  background: var(--border-light);
}

.settings-profile__avatar-image {
  width: 100%;
  height: 100%;
}

.settings-profile__body {
  flex: 1;
  min-width: 0;
}

.settings-profile__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.settings-profile__headline {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 600;
}

.settings-profile__link {
  flex-shrink: 0;
  color: var(--text-link);
  font-size: 28rpx;
  font-weight: 600;
}

.settings-profile__hint {
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
}

.settings-notify-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.settings-notify-row__body {
  flex: 1;
  min-width: 0;
}

.settings-notify-row__title,
.settings-font-row__title {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 600;
}

.settings-notify-row__desc,
.settings-link-row__desc {
  margin-top: 4rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
}

.settings-notify-row__meta {
  margin-top: 8rpx;
  color: var(--text-tertiary);
  font-size: 20rpx;
}

.settings-link-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 96rpx;
}

.settings-link-row__body {
  flex: 1;
  min-width: 0;
}

.settings-link-row__title {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 600;
}

.settings-link-row__side {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.settings-link-row__value {
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 600;
}

.settings-link-row__arrow {
  color: var(--text-tertiary);
  font-size: 28rpx;
  font-weight: 600;
}

.settings-stepper-block + .settings-stepper-block {
  margin-top: 0;
}

.settings-stepper-block__title {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 600;
}

.settings-stepper-block__row,
.settings-font-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.settings-stepper-block--split + .settings-stepper-block--split {
  padding-top: 28rpx;
  border-top: 1rpx solid var(--bg-input);
}

.settings-stepper-block__label {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--text-secondary);
  font-size: 22rpx;
  font-weight: 600;
}

.settings-threshold-readonly {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.settings-threshold-readonly__value {
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.6;
}

.settings-threshold-readonly__hint {
  color: var(--text-secondary);
  font-size: 22rpx;
  line-height: 1.6;
}

.settings-stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.settings-stepper--stacked {
  width: 100%;
}

.settings-stepper__button {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid var(--text-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  background: transparent;
  font-size: 28rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.settings-stepper__button:active {
  background: var(--color-primary);
  color: var(--text-on-primary);
}

.settings-stepper__button--disabled {
  border-color: var(--border-light);
  color: var(--border-light);
}

.settings-stepper__button--disabled:active {
  background: transparent;
  color: var(--border-light);
}

.settings-stepper__value {
  min-width: 72rpx;
  text-align: center;
  color: var(--text-primary);
  font-size: 36rpx;
  font-weight: 700;
}

.settings-reference-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 32rpx;
}

.settings-reference-grid__column {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
}

.settings-reference-grid__label {
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}

.font-scale-control {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: 4rpx;
  padding: 4rpx;
  background: var(--bg-input);
  border-radius: var(--radius-sm);
}

.font-scale-control__item {
  flex: 1;
  min-width: 0;
  min-height: 64rpx;
  padding: 12rpx 28rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  background: transparent;
  font-size: 24rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.font-scale-control__item--active {
  background: var(--color-primary);
  color: var(--text-on-primary);
  box-shadow: var(--shadow-button);
}

.settings-about__name {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 700;
}

.settings-about__version {
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
}

.settings-about__privacy {
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: 20rpx;
  line-height: 1.6;
}

.settings-empty-hint {
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.7;
}

.settings-sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.5);
  z-index: 9998;
}

.settings-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(env(safe-area-inset-bottom) + 32rpx);
  background: var(--bg-card);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  box-shadow: var(--shadow-sheet);
  z-index: 9999;
}

.settings-sheet__handle {
  width: 80rpx;
  height: 8rpx;
  margin: 0 auto;
  border-radius: var(--radius-pill);
  background: var(--border-light);
}

.settings-sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 28rpx;
}

.settings-sheet__title {
  color: var(--text-primary);
  font-size: 40rpx !important;
  font-weight: 700;
}

.settings-sheet__close {
  color: var(--text-link);
  font-size: 26rpx;
  font-weight: 600;
}

.settings-sheet__state {
  padding: 56rpx 16rpx 24rpx;
  text-align: center;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.settings-sheet__state--error {
  color: var(--color-danger);
}

.settings-sheet__retry {
  margin-top: 18rpx;
  color: var(--text-link);
  font-size: 26rpx;
  font-weight: 600;
}

.settings-sheet__list {
  margin-top: 24rpx;
}

.settings-sheet__item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 112rpx;
  padding: 20rpx 0;
}

.settings-sheet__item + .settings-sheet__item {
  border-top: 1rpx solid var(--bg-input);
}

.settings-sheet__member {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.settings-sheet__avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: var(--border-light);
  color: var(--text-secondary);
  font-size: 32rpx;
  font-weight: 700;
  overflow: hidden;
}

.settings-sheet__avatar--image {
  background: var(--border-light);
}

.settings-sheet__avatar-image {
  width: 100%;
  height: 100%;
}

.settings-sheet__member-body {
  flex: 1;
  min-width: 0;
}

.settings-sheet__member-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 600;
}

.settings-sheet__member-role {
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
}

.settings-sheet__member-status-pending {
  margin-top: 6rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
  line-height: 1.5;
}
