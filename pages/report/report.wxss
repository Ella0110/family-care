.report-page {
  padding: 32rpx 28rpx 240rpx;
  box-sizing: border-box;
  background: #eef3fb;
}

.report-tabs,
.report-state,
.report-permission-modal__panel {
  border-radius: 32rpx;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
}

.report-tabs {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
}

.report-tabs__item {
  flex: 1;
  min-height: 72rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: calc(28rpx * var(--font-scale));
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
}

.report-tabs__item--active {
  background: #dbeafe;
  color: #1d4ed8;
}

.report-tabs__item--disabled {
  opacity: 0.4;
}

.report-tabs__item--disabled.report-tabs__item--active {
  background: #f1f5f9;
  color: #94a3b8;
}

.report-state,
.report-content {
  margin-top: 20rpx;
}

.report-state__title,
.report-header__title {
  color: #111827;
  font-size: calc(36rpx * var(--font-scale));
  font-weight: 800;
  line-height: 1.35;
}

.report-state__text,
.report-header__time {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: calc(24rpx * var(--font-scale));
  line-height: 1.7;
}

.report-content {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
}

.report-section {
  padding: 0 0 40rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.report-section + .report-section {
  margin-top: 40rpx;
}

.report-section--header {
  padding-bottom: 36rpx;
}

.report-section--disclaimer {
  padding-bottom: 0;
  border-bottom: none;
}

.report-section__eyebrow {
  color: #94a3b8;
  font-size: calc(24rpx * var(--font-scale));
  font-weight: 800;
  line-height: 1.5;
  letter-spacing: 4rpx;
}

.report-section__eyebrow--patient {
  color: #3478f6;
  font-size: calc(24rpx * var(--font-scale));
  font-weight: 700;
  letter-spacing: 2rpx;
}

.report-section__heading-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.report-section__unit {
  color: #cbd5e1;
  font-size: calc(22rpx * var(--font-scale));
  font-weight: 700;
  flex-shrink: 0;
}

.report-profile__grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 28rpx 32rpx;
  margin-top: 24rpx;
}

.report-profile__item {
  min-width: 0;
}

.report-profile__item--full {
  grid-column: 1 / -1;
}

.report-profile__label {
  color: #94a3b8;
  font-size: calc(24rpx * var(--font-scale));
  font-weight: 700;
  letter-spacing: 2rpx;
  line-height: 1.5;
}

.report-profile__value {
  margin-top: 12rpx;
  color: #0f172a;
  font-size: calc(30rpx * var(--font-scale));
  font-weight: 700;
  line-height: 1.6;
  word-break: break-all;
}

.report-profile__value--emergency {
  color: #ef4444;
}

.privacy-target {
  color: #0f172a;
}

.report-alert {
  border-left: 6rpx solid #ef4444;
  border-radius: 24rpx;
  background: #fef2f2;
  padding: 28rpx 28rpx 28rpx 24rpx;
}

.report-alert--warning {
  border-left-color: #f97316;
  background: #fff7ed;
}

.report-alert__title {
  color: #991b1b;
  font-size: calc(32rpx * var(--font-scale));
  font-weight: 800;
  line-height: 1.4;
}

.report-alert--warning .report-alert__title {
  color: #9a3412;
}

.report-alert__text {
  margin-top: 10rpx;
  color: #7f1d1d;
  font-size: calc(26rpx * var(--font-scale));
  line-height: 1.7;
}

.report-alert--warning .report-alert__text {
  color: #9a3412;
}

.report-summary {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 24rpx;
}

.report-summary__item {
  min-height: 180rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.report-summary__label {
  color: #6b7280;
  font-size: calc(24rpx * var(--font-scale));
  line-height: 1.5;
}

.report-summary__value {
  margin-top: 18rpx;
  color: #111827;
  font-size: calc(48rpx * var(--font-scale));
  font-weight: 800;
  line-height: 1.15;
}

.report-summary__value--danger {
  color: #b42318;
}

.report-summary__value--warning {
  color: #c2410c;
}

.report-summary__unit {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: calc(24rpx * var(--font-scale));
}

.report-empty,
.report-chart-card__empty,
.report-alert-list__empty {
  color: #6b7280;
  font-size: calc(28rpx * var(--font-scale));
  line-height: 1.7;
  text-align: center;
}

.report-chart-card__canvas {
  width: 100%;
  height: 200px;
  margin-top: 24rpx;
}

.report-chart-card__empty {
  min-height: 200rpx;
  margin-top: 24rpx;
  line-height: 200rpx;
}

.report-alert-list__item {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 24rpx;
}

.report-alert-list__item + .report-alert-list__item {
  padding-top: 24rpx;
  border-top: 1rpx solid #eef2f7;
}

.report-alert-list__left {
  flex: 1;
  min-width: 0;
}

.report-alert-list__right {
  flex-shrink: 0;
  text-align: right;
}

.report-alert-list__time {
  color: #111827;
  font-size: calc(28rpx * var(--font-scale));
  font-weight: 700;
}

.report-alert-list__tags {
  margin-top: 8rpx;
  color: #b42318;
  font-size: calc(24rpx * var(--font-scale));
  line-height: 1.6;
}

.report-alert-list__bp {
  color: #111827;
  font-size: calc(34rpx * var(--font-scale));
  font-weight: 800;
  line-height: 1.2;
}

.report-alert-list__heart {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: calc(24rpx * var(--font-scale));
}

.report-disclaimer__text {
  color: #94a3b8;
  font-size: calc(22rpx * var(--font-scale));
  line-height: 1.8;
}

.report-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -12rpx 32rpx rgba(15, 23, 42, 0.08);
  box-sizing: border-box;
}

.report-actions__privacy {
  flex: 1;
  min-width: 0;
}

.report-actions__privacy-title {
  color: #111827;
  font-size: calc(28rpx * var(--font-scale));
  font-weight: 700;
  line-height: 1.4;
}

.report-actions__privacy-text {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: calc(22rpx * var(--font-scale));
  line-height: 1.5;
}

.report-actions__button {
  flex-shrink: 0;
  min-width: 260rpx;
  min-height: 84rpx;
  margin: 0;
  font-size: calc(28rpx * var(--font-scale));
}

.report-export-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 375px;
  pointer-events: none;
}

.report-permission-modal {
  position: fixed;
  inset: 0;
  z-index: 40;
}

.report-permission-modal__mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
}

.report-permission-modal__panel {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
}

.report-permission-modal__title {
  color: #111827;
  font-size: calc(38rpx * var(--font-scale));
  font-weight: 800;
  line-height: 1.35;
}

.report-permission-modal__subtitle {
  margin-top: 12rpx;
  color: #4b5563;
  font-size: calc(30rpx * var(--font-scale));
  line-height: 1.6;
}

.report-permission-modal__step {
  margin-top: 16rpx;
  color: #6b7280;
  font-size: calc(28rpx * var(--font-scale));
  line-height: 1.6;
}

.report-permission-modal__actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 28rpx;
}

.report-permission-modal__button {
  width: 100%;
  margin: 0;
}
