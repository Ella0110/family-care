.invite-page,
.invite-generated {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.invite-section {
  padding: 40rpx;
  border-radius: 32rpx;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
}

.invite-section__title {
  font-size: 24rpx;
  font-weight: 700;
  color: #94a3b8;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.invite-section__hint,
.invite-section__count,
.invite-profile-item__summary,
.invite-generated__hint,
.invite-generated__preview-subtitle {
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.6;
}

.invite-profile-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.invite-profile-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid #e2e8f0;
  transition: all 0.2s ease;
}

.invite-profile-item__check {
  width: 40rpx;
  min-width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #cbd5e1;
  color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
}

.invite-profile-item__content {
  flex: 1;
  min-width: 0;
}

.invite-profile-item__label {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.invite-profile-item--active {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.invite-profile-item--active .invite-profile-item__check {
  background: #3478f6;
  border-color: #3478f6;
  color: #ffffff;
}

.invite-role-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.invite-role-selector__option {
  flex: 1;
  min-height: 96rpx;
  min-width: 220rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  color: #64748b;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1.4;
  box-sizing: border-box;
}

.invite-role-selector__option--active {
  background: #3478f6;
  color: #ffffff;
  box-shadow: 0 8px 24px rgba(49, 130, 247, 0.2);
}

.invite-message {
  width: 100%;
  min-height: 160rpx;
  font-size: 30rpx;
  line-height: 1.6;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
  background: #f8fafc;
}

.invite-inviter {
  display: flex;
  gap: 20rpx;
  align-items: center;
  margin-top: 20rpx;
}

.invite-inviter--summary {
  justify-content: space-between;
  align-items: flex-start;
}

.invite-inviter__summary-main {
  display: flex;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.invite-inviter__summary-avatar {
  width: 120rpx;
  min-width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #eff6ff;
}

.invite-inviter__summary-copy {
  flex: 1;
  min-width: 0;
}

.invite-inviter__summary-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.invite-inviter__summary-action,
.invite-inviter__editor-action {
  font-size: 30rpx;
  color: #3478f6;
  font-weight: 600;
}

.invite-inviter__editor-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.invite-inviter__avatar-button {
  width: 120rpx;
  min-width: 120rpx;
  height: 120rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: #eff6ff;
  color: #3478f6;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  line-height: 1.3;
}

.invite-inviter__avatar-button::after {
  border: none;
}

.invite-inviter__avatar-image {
  width: 100%;
  height: 100%;
}

.invite-inviter__avatar-placeholder {
  width: 100%;
  height: 100%;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.invite-inviter__avatar-placeholder--initial {
  font-size: 36rpx;
  font-weight: 700;
}

.invite-inviter__nickname {
  flex: 1;
  min-height: 96rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
  font-size: 30rpx;
  color: #0f172a;
  background: #f8fafc;
  line-height: 1.5;
  box-sizing: border-box;
}

.invite-page__button,
.invite-generated__button {
  min-height: 96rpx;
}

.invite-page__secondary,
.invite-generated__secondary {
  min-height: 96rpx;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
  box-sizing: border-box;
}

.invite-page__secondary {
  background: transparent;
  color: #94a3b8;
  border: none;
}

.invite-page__secondary::after {
  border: none;
}

.invite-generated {
  padding: 40rpx;
  border-radius: 32rpx;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
}

.invite-generated__title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.35;
}

.invite-generated__preview {
  padding: 32rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
}

.invite-generated__preview-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.invite-generated__preview-avatar {
  width: 88rpx;
  min-width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #dbeafe;
}

.invite-generated__preview-avatar-image,
.invite-generated__preview-avatar-fallback {
  width: 100%;
  height: 100%;
}

.invite-generated__preview-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #475569;
}

.invite-generated__preview-copy {
  flex: 1;
  min-width: 0;
}

.invite-generated__preview-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.invite-generated__button {
  box-shadow: 0 8px 24px rgba(49, 130, 247, 0.2);
}

.invite-generated__secondary {
  background: #ffffff;
  color: #3478f6;
  border: 2rpx solid #3478f6;
}
