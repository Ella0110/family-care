.import-page {
  min-height: 100vh;
  padding-bottom: 220rpx;
  background: #f0f4fa;
}

.import-card + .import-card {
  margin-top: 24rpx;
}

.import-card {
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.import-card__title,
.import-preview__summary,
.import-result__title {
  color: #1e293b;
  font-size: calc(32rpx * var(--font-scale));
  font-weight: 800;
  line-height: 1.4;
}

.import-card__text,
.import-result__text,
.import-footer__text,
.import-preview__sub {
  margin-top: 12rpx;
  color: #94a3b8;
  font-size: calc(24rpx * var(--font-scale));
  line-height: 1.7;
}

.import-textarea {
  width: 100%;
  min-height: 420rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  box-sizing: border-box;
  color: #64748b;
  font-size: calc(26rpx * var(--font-scale));
  line-height: 1.7;
}

.import-card__actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.import-card__button,
.import-result__button,
.import-footer__button {
  flex: 1;
  min-height: 88rpx;
  border-radius: 20rpx;
  font-size: calc(28rpx * var(--font-scale));
  font-weight: 600;
}

.import-card__button::after,
.import-result__button::after,
.import-footer__button::after {
  border-width: 0;
}

.import-card__button.btn-primary,
.import-result__button.btn-primary,
.import-footer__button.btn-primary {
  background: #3182f7;
  color: #ffffff;
}

.import-card__button.btn-secondary {
  background: #ffffff;
  border: 2rpx solid #3182f7;
  color: #3182f7;
}

.import-preview__section {
  margin-top: 28rpx;
}

.import-preview__section-title {
  font-size: calc(28rpx * var(--font-scale));
  font-weight: 700;
}

.import-preview__section-title--success {
  color: #047857;
}

.import-preview__section-title--error {
  color: #b42318;
}

.import-preview__item + .import-preview__item {
  margin-top: 16rpx;
}

.import-preview__item {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 20rpx;
}

.import-preview__item--success {
  background: #ecfdf5;
}

.import-preview__item--error {
  background: #fef2f2;
}

.import-preview__main {
  color: #1e293b;
  font-size: calc(26rpx * var(--font-scale));
  font-weight: 700;
  line-height: 1.6;
}

.import-footer {
  position: fixed;
  right: 32rpx;
  bottom: 32rpx;
  left: 32rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 32rpx rgba(17, 24, 39, 0.12);
}

.import-footer__button[disabled] {
  background: #e2e8f0;
  color: #94a3b8;
}
