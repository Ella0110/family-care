.page-root {
  min-height: 100vh;
  padding: 0 0 calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #f4f5f7;
}

.profile-edit-shell {
  width: 100%;
  padding: 0;
  box-sizing: border-box;
}

.profile-edit-card {
  background: #ffffff;
  border-radius: 48rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  padding: 64rpx;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.015);
  margin: 48rpx 56rpx 0;
}

.profile-edit-section--avatar {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.profile-edit-label {
  color: #8E8E93;
  font-size: 26rpx;
  font-weight: 700;
}

.profile-edit-field-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0 4rpx;
  }

.profile-edit-count {
    color: #C7C7CC;
    font-size: 24rpx;
}

.profile-edit-avatar {
    width: 176rpx; /* 88px 精致尺寸 */
    height: 176rpx;
    border-radius: 50%;
    background: #E5E5EA;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    box-sizing: border-box;
    border: 4rpx solid #ffffff;
    /* 采用极细外描边和微透漫散，干净利落 */
    box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.04), 0 0 0 1rpx rgba(0, 0, 0, 0.04);
}

.profile-edit-avatar:active {
    transform: scale(0.96); /* 精确微动的点击物理反馈 */
  }

.profile-edit-avatar--image {
  background: transparent;
}

.profile-edit-avatar--placeholder {
  background: transparent;
}

.profile-edit-avatar__image {
  width: 100%;
  height: 100%;
}

.profile-edit-avatar__placeholder-icon {
  width: 100%;
  height: 100%;
}

.profile-edit-avatar-link {
  margin-top: 32rpx;
  padding: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  color: #007aff;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.4;
}

.profile-edit-avatar-link::after {
  border: none;
}

.profile-edit-input {
  width: 100%;
  min-height: 104rpx;
  margin-top: 20rpx;
  padding: 28rpx 32rpx;
  box-sizing: border-box;
  background: #F2F2F7;
  border-radius: 20rpx; 
  border: 2rpx solid transparent;
  color: #1c1c1e;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.5;
  transition: background 0.2s ease, border-color 0.2s ease;
}

.profile-edit-input::placeholder {
  color: #c7c7cc;
}

.profile-edit-input:focus {
  background: #ffffff;
  border: 2rpx solid #007aff;
}

.profile-edit-error {
  margin-top: 24rpx;
  color: #ff3b30;
  font-size: 26rpx;
  line-height: 1.6;
}

.profile-edit-save-bar {
  margin: 40rpx 56rpx 0;
  padding: 0 0 env(safe-area-inset-bottom);
  box-sizing: border-box;
}

.profile-edit-save {
  width: 100%;
  margin-top: 0;
  min-height: 96rpx;
  border-radius: 28rpx;
  background: #007aff;
  font-size: 32rpx;
  padding: 28rpx 32rpx;
  line-height: 1.4;
  box-sizing: border-box;
  color: #ffffff;
  font-weight: 600;
  opacity: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-edit-save::after {
  border: none;
}

.profile-edit-save:active {
  opacity: 0.85;
}
