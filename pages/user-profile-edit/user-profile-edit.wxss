.page-root {
  min-height: 100vh;
  padding: 32rpx 28rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #f2f2f7;
}

.profile-edit-card {
  padding: 48rpx 40rpx 40rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
}

.profile-edit-section + .profile-edit-section {
  margin-top: 40rpx;
}

.profile-edit-section--avatar {
  margin-bottom: 8rpx;
}

.profile-edit-label {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 700;
}

.profile-edit-hint {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 24rpx;
  line-height: 1.6;
}

.profile-edit-avatar-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 24rpx;
}

.profile-edit-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%);
  color: #0f172a;
  font-size: 40rpx;
  font-weight: 700;
  overflow: hidden;
  flex-shrink: 0;
}

.profile-edit-avatar--image {
  background: transparent;
}

.profile-edit-avatar__image {
  width: 100%;
  height: 100%;
}

.profile-edit-avatar__button {
  margin: 0;
  padding: 0;
  min-height: auto;
  background: transparent;
  color: #3478f6;
  border-radius: 0;
  border: none;
  font-size: 28rpx;
  line-height: 1.4;
}

.profile-edit-avatar__button::after {
  border: 0;
}

.profile-edit-input {
  width: 100%;
  min-height: 96rpx;
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
  color: #0f172a;
  font-size: 30rpx;
  line-height: 1.5;
}

.profile-edit-input::placeholder {
  color: #cbd5e1;
}

.profile-edit-error {
  margin-top: 24rpx;
  color: #ff3b30;
  font-size: 26rpx;
  line-height: 1.6;
}

.profile-edit-save {
  width: 100%;
  margin-top: 40rpx;
  border-radius: 24rpx;
  background: #3478f6;
  font-size: 32rpx;
  min-height: 96rpx;
  padding: 24rpx 32rpx;
  line-height: 1.4;
  box-sizing: border-box;
}

.profile-edit-cancel {
  width: 100%;
  margin-top: 24rpx;
  border-radius: 24rpx;
  border: none;
  background: transparent;
  color: #94a3b8;
  font-size: 32rpx;
  min-height: 96rpx;
  padding: 24rpx 32rpx;
  line-height: 1.4;
  box-sizing: border-box;
}

.profile-edit-cancel::after {
  border: 0;
}
