<view class="page page-root">
  <view class="profile-edit-shell">
    <view class="profile-edit-card">
      <view class="profile-edit-section profile-edit-section--avatar">
        <view wx:if="{{form.avatarUrl}}" class="profile-edit-avatar profile-edit-avatar--image" style="font-size:{{fs.title}}">
          <image class="profile-edit-avatar__image" src="{{form.avatarUrl}}" mode="aspectFill" />
        </view>
        <view wx:else class="profile-edit-avatar" style="font-size:{{fs.title}}">{{form.avatarFallback}}</view>
        <button
          class="profile-edit-avatar-link"
          open-type="chooseAvatar"
          bindchooseavatar="onChooseAvatar"
          style="font-size:{{fs.body}}"
        >
          更换头像
        </button>
      </view>

      <view class="profile-edit-section">
        <view class="profile-edit-field-head">
          <view class="profile-edit-label" style="font-size:{{fs.body}}">昵称</view>
          <view class="profile-edit-count" style="font-size:{{fs.label}}">{{form.nickname.length}}/20</view>
        </view>
        <input
          class="profile-edit-input"
          type="nickname"
          maxlength="20"
          placeholder="请输入昵称"
          value="{{form.nickname}}"
          bindinput="onNicknameInput"
          style="font-size:{{fs.body}}"
        />
      </view>

      <view wx:if="{{errorText}}" class="profile-edit-error" style="font-size:{{fs.secondary}}">{{errorText}}</view>
    </view>
  </view>

  <view class="profile-edit-save-bar">
    <button
      class="profile-edit-save"
      bindtap="handleSave"
      loading="{{isSaving}}"
      disabled="{{isSaving}}"
      style="font-size:{{fs.body}}">
      保存修改
    </button>
  </view>
</view>
