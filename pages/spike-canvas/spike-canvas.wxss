.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f5f5f5;
}

.panel {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.panel__title,
.debug__title,
.preview__title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.panel__desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #6b7280;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.actions__button {
  flex: 1;
}

.actions__button--secondary {
  color: #1d4ed8;
  background: #eff6ff;
}

.debug__row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
}

.debug__row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.debug__label {
  flex: 0 0 240rpx;
  font-size: 26rpx;
  color: #4b5563;
}

.debug__value {
  flex: 1;
  font-size: 26rpx;
  color: #111827;
  text-align: right;
  word-break: break-all;
}

.preview__image {
  width: 100%;
  margin-top: 20rpx;
  border-radius: 16rpx;
  background: #f8fafc;
}

.preview__placeholder {
  margin-top: 20rpx;
  padding: 36rpx 24rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  font-size: 26rpx;
  text-align: center;
  color: #6b7280;
}

.preview__path {
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6b7280;
  word-break: break-all;
}

.spike-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 750px;
  height: 2000px;
  pointer-events: none;
}
