.page {
  background: #f2f2f7;
}

.profile-edit-page {
  padding: 36rpx 28rpx 48rpx;
}

.profile-edit__header {
  padding: 16rpx 8rpx 48rpx;
}

.profile-edit__title {
  color: #0f172a;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.35;
}

.profile-edit__subtitle {
  margin-top: 16rpx;
  color: #94a3b8;
  font-size: 26rpx;
  line-height: 1.65;
}

.profile-edit__form {
  padding: 40rpx 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
}

.profile-edit__form--create {
  padding: 48rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.7);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  box-shadow: 0 8px 32px rgba(49, 130, 247, 0.08);
}

.form-item + .form-item {
  margin-top: 36rpx;
}

.form-item--nested {
  margin-top: 16rpx;
}

.form-label {
  margin-bottom: 16rpx;
  color: #334155;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
}

.form-required {
  color: #ff3b30;
}

.form-input,
.form-picker,
.form-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 96rpx;
  padding: 20rpx 28rpx;
  border: 1px solid #e2e8f0;
  border-radius: 16rpx;
  background: #f8fafc;
  color: #0f172a;
  font-size: 30rpx;
  line-height: 1.45;
}

.form-input {
  display: block;
}

.form-input--name {
  font-weight: 700;
}

.form-input--spaced {
  margin-top: 16rpx;
}

.form-picker {
  display: flex;
  align-items: center;
}

.form-picker--empty,
.form-placeholder {
  color: #94a3b8;
}

.form-textarea {
  min-height: 180rpx;
  padding: 24rpx 28rpx;
}

.form-help {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 22rpx;
  line-height: 1.5;
}

.gender-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.gender-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  border: 1px solid #e2e8f0;
  background: #f8fafc;
  color: #475569;
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.gender-option--active {
  border-color: #3478f6;
  background: #3478f6;
  color: #ffffff;
}

.profile-edit__progress {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.profile-edit__progress-title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 800;
}

.profile-edit__progress-item {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

.profile-edit__progress-item.is-completed {
  color: #3478f6;
}

.profile-edit__actions {
  margin-top: 40rpx;
}

.profile-edit__actions--create {
  margin-top: 40rpx;
}

.profile-edit__button {
  width: 100%;
  min-height: 96rpx;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
  box-sizing: border-box;
}

.profile-edit__button--create {
  box-shadow: 0 8px 24px rgba(49, 130, 247, 0.3);
}

.profile-edit__button + .profile-edit__button {
  margin-top: 20rpx;
}

.profile-edit__button--ghost {
  min-height: 72rpx;
  background: transparent;
  color: #94a3b8;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: none;
}

.profile-edit__button::after {
  border: 0;
}
