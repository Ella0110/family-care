.page {
  background: var(--bg-page);
}

.profile-edit-page {
  padding: 36rpx 28rpx 48rpx;
}

.profile-edit__header {
  padding: 16rpx 8rpx 48rpx;
}

.profile-edit__title {
  color: var(--text-primary);
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.35;
}

.profile-edit__subtitle {
  margin-top: 16rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.65;
}

.profile-edit__form {
  padding: 40rpx 32rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-card);
  box-shadow: var(--shadow-card);
}

.profile-edit__form--create {
  padding: 48rpx;
  border-radius: var(--radius-lg);
  /* 保留玻璃态背景，不收敛为标准卡片 */
  background: rgba(255, 255, 255, 0.7);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  /* 保留玻璃态 glow，不走 shadow token */
  box-shadow: 0 16rpx 64rpx rgba(49, 130, 247, 0.08);
}

.form-item + .form-item {
  margin-top: 36rpx;
}

.form-item--nested {
  margin-top: 16rpx;
}

.form-label {
  margin-bottom: 16rpx;
  color: var(--text-secondary);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
}

.form-required {
  color: var(--color-danger);
}

.form-input,
.form-picker,
.form-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 96rpx;
  padding: 20rpx 28rpx;
  border: 2rpx solid var(--border-light);
  border-radius: var(--radius-sm);
  background: var(--bg-input);
  color: var(--text-primary);
  font-size: 30rpx;
  line-height: 1.45;
}

.form-input {
  display: block;
}

.form-input--name {
  font-weight: 700;
}

.form-input--spaced {
  margin-top: 16rpx;
}

.form-picker {
  display: flex;
  align-items: center;
}

.form-picker--empty,
.form-placeholder {
  color: var(--text-secondary);
}

.form-textarea {
  min-height: 180rpx;
  padding: 24rpx 28rpx;
}

.form-help {
  margin-top: 10rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
  line-height: 1.5;
}

.gender-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.gender-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 16rpx 32rpx;
  border-radius: var(--radius-sm);
  border: 2rpx solid var(--border-light);
  background: var(--bg-input);
  color: var(--text-secondary);
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.gender-option--active {
  border-color: var(--color-primary);
  background: var(--color-primary);
  color: var(--text-on-primary);
}

.profile-edit__progress {
  padding: 24rpx;
  border-radius: var(--radius-md);
  background: var(--bg-input);
}

.profile-edit__progress-title {
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 800;
}

.profile-edit__progress-item {
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.6;
}

.profile-edit__progress-item.is-completed {
  color: var(--text-link);
}

.profile-edit__actions {
  margin-top: 40rpx;
}

.profile-edit__actions--create {
  margin-top: 40rpx;
}

.profile-edit__button {
  width: 100%;
  min-height: 96rpx;
  padding: 24rpx 32rpx;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
  box-sizing: border-box;
}

.profile-edit__button--create {
  box-shadow: var(--shadow-button);
}

.profile-edit__button + .profile-edit__button {
  margin-top: 20rpx;
}

.profile-edit__button--ghost {
  min-height: 72rpx;
  background: transparent;
  color: var(--text-secondary);
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: none;
}

.profile-edit__button::after {
  border: 0;
}
