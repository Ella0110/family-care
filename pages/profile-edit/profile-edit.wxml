<view class="page">
  <view class="profile-edit__header">
    <view class="profile-edit__title">{{pageTitle}}</view>
    <view class="profile-edit__subtitle">{{pageSubtitle}}</view>
  </view>

  <view class="card profile-edit__form">
    <view class="form-item">
      <view class="form-label">姓名 <text class="form-required">*</text></view>
      <input
        class="form-input form-input--name"
        value="{{form.name}}"
        maxlength="20"
        placeholder="{{isEditMode ? '例如：爸爸' : '例如：爸爸、妈妈、我自己'}}"
        placeholder-class="form-placeholder"
        focus="{{!isEditMode}}"
        bindinput="onNameInput"
      />
    </view>

    <block wx:if="{{isEditMode}}">
      <view class="form-item">
        <view class="form-label">与你的关系</view>
        <picker mode="selector" range="{{relationOptions}}" value="{{relationIndex}}" bindchange="onRelationChange">
          <view class="form-picker {{relationPickerText ? '' : 'form-picker--empty'}}">
            {{relationPickerText || '请选择关系'}}
          </view>
        </picker>
        <view wx:if="{{showCustomRelation}}" class="form-item form-item--nested">
          <input
            class="form-input"
            value="{{form.relationCustom}}"
            maxlength="10"
            placeholder="请填写具体关系，如：弟弟、奶奶等"
            placeholder-class="form-placeholder"
            bindinput="onRelationCustomInput"
          />
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">性别</view>
        <view class="gender-options">
          <view
            wx:for="{{genderOptions}}"
            wx:key="value"
            class="gender-option {{form.gender === item.value ? 'gender-option--active' : ''}}"
            data-value="{{item.value}}"
            bindtap="onGenderTap"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">出生日期</view>
        <picker mode="date" value="{{form.birthDate}}" bindchange="onBirthDateChange">
          <view class="form-picker {{form.birthDate ? '' : 'form-picker--empty'}}">
            {{form.birthDate || '请选择出生日期'}}
          </view>
        </picker>
      </view>

      <view class="form-item">
        <view class="form-label">紧急联系人</view>
        <input
          class="form-input"
          value="{{form.emergencyContactName}}"
          maxlength="20"
          placeholder="联系人姓名（选填）"
          placeholder-class="form-placeholder"
          bindinput="onEmergencyContactNameInput"
        />
        <input
          class="form-input form-input--spaced"
          value="{{form.emergencyContactPhone}}"
          maxlength="11"
          type="number"
          placeholder="手机号（选填）"
          placeholder-class="form-placeholder"
          bindinput="onEmergencyContactPhoneInput"
        />
      </view>

      <view class="form-item">
        <view class="form-label">是否长期服药</view>
        <view class="gender-options">
          <view
            wx:for="{{longTermMedicationOptions}}"
            wx:key="label"
            class="gender-option {{form.longTermMedication === item.value ? 'gender-option--active' : ''}}"
            data-value="{{item.value}}"
            bindtap="onLongTermMedicationTap"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">备注</view>
        <textarea
          class="form-textarea"
          value="{{form.note}}"
          maxlength="200"
          placeholder="可填写长期病史、测量注意事项等"
          placeholder-class="form-placeholder"
          bindinput="onNoteInput"
        />
        <view class="form-help">最多 200 个字</view>
      </view>

      <view class="form-item profile-edit__progress">
        <view class="profile-edit__progress-title">{{completionSummary}}</view>
        <view
          wx:for="{{completionItems}}"
          wx:key="label"
          class="profile-edit__progress-item {{item.completed ? 'is-completed' : ''}}"
        >
          {{item.mark}} {{item.label}}
        </view>
      </view>
    </block>
  </view>

  <view class="profile-edit__actions">
    <button
      class="btn-primary profile-edit__button"
      loading="{{isSaving}}"
      disabled="{{isSaving}}"
      bindtap="handleSubmit"
    >
      {{saveButtonText}}
    </button>
    <button
      class="btn-secondary profile-edit__button"
      disabled="{{isSaving}}"
      bindtap="handleCancel"
    >
      取消
    </button>
  </view>
</view>
