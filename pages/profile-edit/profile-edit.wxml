<view class="page profile-edit-page">
  <view class="profile-edit__header" style="padding: {{fs.spaceMD}} 8rpx {{fs.space2XL}};">
    <view class="profile-edit__title" style="font-size:{{fs.title}}">{{pageTitle}}</view>
    <view class="profile-edit__subtitle" style="font-size:{{fs.secondary}}">{{pageSubtitle}}</view>
  </view>

  <block wx:if="{{!isEditMode}}">
    <view class="card profile-edit__form profile-edit__form--create" style="padding: {{fs.space2XL}};">
      <view class="form-item">
        <view class="form-label" style="font-size:{{fs.body}}">姓名 <text class="form-required">*</text></view>
        <input
          class="form-input"
          value="{{form.name}}"
          maxlength="20"
          placeholder="例如：爸爸、妈妈、我自己"
          placeholder-class="form-placeholder"
          focus="{{true}}"
          bindinput="onNameInput"
          style="font-size:{{fs.body}}"
        />
      </view>

      <view class="form-item">
        <view class="form-label" style="font-size:{{fs.body}}">与你的关系</view>
        <picker mode="selector" range="{{relationOptions}}" value="{{relationIndex}}" bindchange="onRelationChange">
          <view class="form-picker {{relationPickerText ? '' : 'form-picker--empty'}}" style="font-size:{{fs.body}}">
            {{relationPickerText || '请选择关系'}}
          </view>
        </picker>
        <view wx:if="{{showCustomRelation}}" class="form-item form-item--nested">
          <input
            class="form-input"
            value="{{form.relationCustom}}"
            maxlength="10"
            placeholder="请填写具体关系，如：弟弟、奶奶等"
            placeholder-class="form-placeholder"
            bindinput="onRelationCustomInput"
            style="font-size:{{fs.body}}"
          />
        </view>
      </view>
    </view>

    <view class="profile-edit__actions profile-edit__actions--create" style="margin-top: {{fs.spaceXL}};">
      <button
        class="btn-primary profile-edit__button profile-edit__button--create"
        loading="{{isSaving}}"
        disabled="{{isSaving}}"
        bindtap="handleSubmit"
       style="padding: {{fs.spaceLG}} {{fs.spaceXL}}; font-size:{{fs.button}}">
        {{saveButtonText}}
      </button>
      <button
        class="profile-edit__button profile-edit__button--ghost"
        disabled="{{isSaving}}"
        bindtap="handleCancel"
       style="padding: {{fs.spaceMD}} {{fs.spaceXL}}; font-size:{{fs.button}}">
        取消
      </button>
    </view>
  </block>

  <view wx:else class="card profile-edit__form" style="padding: {{fs.spaceXL}};">
      <view class="form-item">
        <view class="form-label" style="font-size:{{fs.body}}">姓名 <text class="form-required">*</text></view>
        <input
          class="form-input form-input--name"
          value="{{form.name}}"
          maxlength="20"
          placeholder="例如：爸爸"
          placeholder-class="form-placeholder"
          bindinput="onNameInput"
          style="font-size:{{fs.body}}"
        />
      </view>

      <view class="form-item">
        <view class="form-label" style="font-size:{{fs.body}}">性别</view>
        <view class="gender-options">
          <view
            wx:for="{{genderOptions}}"
            wx:key="value"
            class="gender-option {{form.gender === item.value ? 'gender-option--active' : ''}}"
            data-value="{{item.value}}"
            bindtap="onGenderTap"
           style="font-size:{{fs.body}}">
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label" style="font-size:{{fs.body}}">出生日期</view>
        <picker mode="date" value="{{form.birthDate}}" bindchange="onBirthDateChange">
          <view class="form-picker {{form.birthDate ? '' : 'form-picker--empty'}}" style="font-size:{{fs.body}}">
            {{form.birthDate || '请选择出生日期'}}
          </view>
        </picker>
      </view>

      <view class="form-item">
        <view class="form-label" style="font-size:{{fs.body}}">紧急联系人</view>
        <input
          class="form-input"
          value="{{form.emergencyContactName}}"
          maxlength="20"
          placeholder="联系人姓名（选填）"
          placeholder-class="form-placeholder"
          bindinput="onEmergencyContactNameInput"
          style="font-size:{{fs.body}}"
        />
        <input
          class="form-input form-input--spaced"
          value="{{form.emergencyContactPhone}}"
          maxlength="11"
          type="number"
          placeholder="手机号（选填）"
          placeholder-class="form-placeholder"
          bindinput="onEmergencyContactPhoneInput"
          style="font-size:{{fs.body}}"
        />
      </view>

      <view class="form-item">
        <view class="form-label" style="font-size:{{fs.body}}">是否长期服药</view>
        <view class="gender-options">
          <view
            wx:for="{{longTermMedicationOptions}}"
            wx:key="label"
            class="gender-option {{form.longTermMedication === item.value ? 'gender-option--active' : ''}}"
            data-value="{{item.value}}"
            bindtap="onLongTermMedicationTap"
           style="font-size:{{fs.body}}">
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label" style="font-size:{{fs.body}}">备注</view>
        <textarea
          class="form-textarea"
          value="{{form.note}}"
          maxlength="200"
          placeholder="可填写长期病史、测量注意事项等"
          placeholder-class="form-placeholder"
          bindinput="onNoteInput"
          style="font-size:{{fs.body}}"
        />
        <view class="form-help" style="font-size:{{fs.caption}}">最多 200 个字</view>
      </view>

      <view class="form-item profile-edit__progress">
        <view class="profile-edit__progress-title" style="font-size:{{fs.body}}">{{completionSummary}}</view>
        <view
          wx:for="{{completionItems}}"
          wx:key="label"
          class="profile-edit__progress-item {{item.completed ? 'is-completed' : ''}}"
         style="font-size:{{fs.secondary}}">
          {{item.mark}} {{item.label}}
        </view>
      </view>
  </view>

  <view wx:if="{{isEditMode}}" class="profile-edit__actions" style="margin-top: {{fs.spaceXL}};">
    <button
      class="btn-primary profile-edit__button"
      loading="{{isSaving}}"
      disabled="{{isSaving}}"
      bindtap="handleSubmit"
     style="padding: {{fs.spaceLG}} {{fs.spaceXL}}; font-size:{{fs.button}}">
      {{saveButtonText}}
    </button>
    <button
      class="btn-secondary profile-edit__button"
      disabled="{{isSaving}}"
      bindtap="handleCancel"
     style="padding: {{fs.spaceLG}} {{fs.spaceXL}}; font-size:{{fs.button}}">
      取消
    </button>
  </view>
</view>
