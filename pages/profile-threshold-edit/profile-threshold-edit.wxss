.threshold-card + .threshold-card {
  margin-top: 20rpx;
}

.threshold-card__title {
  color: #111827;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.35;
}

.threshold-card__help,
.threshold-card__info-text {
  margin-top: 16rpx;
  color: #4b5563;
  font-size: 30rpx;
  line-height: 1.6;
}

.threshold-card__info-title {
  color: #1e3a8a;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
}

.threshold-stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-top: 28rpx;
}

.threshold-stepper__button {
  width: 88rpx;
  min-height: 88rpx;
  margin: 0;
  padding: 20rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.2;
  box-sizing: border-box;
}

.threshold-stepper__button::after {
  border: 0;
}

.threshold-stepper__value {
  min-width: 120rpx;
  color: #111827;
  font-size: 56rpx;
  font-weight: 800;
  text-align: center;
}

.threshold-error {
  margin-top: 24rpx;
  color: #b42318;
  font-size: 30rpx;
  line-height: 1.5;
}

.threshold-actions {
  margin-top: 32rpx;
}

.threshold-actions__button + .threshold-actions__button {
  margin-top: 20rpx;
}
