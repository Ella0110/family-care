<view class="page page-root" style="--font-scale: {{fontScale}};">
  <view wx:if="{{!isLoginReady}}" class="home-loading card">
    <view class="home-loading__title">正在加载档案</view>
    <view class="home-loading__text">请稍候...</view>
  </view>

  <view wx:elif="{{isLoginFailed}}" class="home-failed card">
    <view class="home-failed__title">暂时无法加载</view>
    <view class="home-failed__text">{{loginErrorText || '操作失败，请重试'}}</view>
    <button
      class="btn-primary home-failed__button"
      loading="{{isRetrying}}"
      disabled="{{isRetrying}}"
      bindtap="handleRetryLogin"
    >
      点击重试
    </button>
  </view>

  <view wx:elif="{{isEmptyState}}">
    <view class="home-empty-actions">
      <view class="home-settings-entry" bindtap="handleOpenUserSettings">⚙</view>
    </view>
    <empty-state
      title="记录家人的血压，从第一条开始"
      subtitle="先建一个档案吧"
      buttonText="为家人或自己建档案"
      bind:buttontap="handleCreateProfile"
    />
  </view>

  <view wx:elif="{{isMultiProfileList}}" class="home-profile-list">
    <view class="home-profile-list__header">
      <view>
        <view class="home-profile-list__title">关注的家人</view>
        <view class="home-profile-list__subtitle">一眼查看每个档案的最近血压</view>
      </view>
      <view class="home-profile-list__header-actions">
        <view class="home-settings-entry" bindtap="handleOpenUserSettings">⚙</view>
        <button class="home-profile-list__add" bindtap="handleCreateProfile">+</button>
      </view>
    </view>

    <view class="home-profile-list__cards">
      <view
        wx:for="{{profileCards}}"
        wx:key="profile._id"
        class="profile-card card"
        data-profile-id="{{item.profile._id}}"
        bindtap="handleProfileCardTap"
      >
        <view class="profile-card__top">
          <view>
            <view class="profile-card__name">{{item.profile.name}}</view>
            <view class="profile-card__relation">{{item.relationText}}</view>
          </view>
          <view class="profile-card__arrow">›</view>
        </view>

        <view wx:if="{{item.isLoading}}" class="profile-card__empty">正在读取最近血压...</view>
        <view wx:elif="{{item.latestRecordError}}" class="profile-card__empty">{{item.latestRecordError}}</view>
        <view wx:elif="{{item.hasLatestRecord}}" class="profile-card__record">
          <view class="profile-card__bp {{item.latestRecordDisplay.statusClassName}}">
            {{item.latestRecordDisplay.systolic}} <text>/</text> {{item.latestRecordDisplay.diastolic}}
          </view>
          <bp-status-tag
            systolic="{{item.latestRecordDisplay.systolic}}"
            diastolic="{{item.latestRecordDisplay.diastolic}}"
            reference-lines="{{item.profile.settings.bp.referenceLines}}"
          />
          <view class="profile-card__time">{{item.latestRecordDisplay.measuredAtText}}</view>
        </view>
        <view wx:else class="profile-card__empty">还没有记录</view>
      </view>
    </view>
  </view>

  <view wx:else class="home-profile">
    <view class="home-profile__header">
      <view>
        <view
          wx:if="{{canReturnToProfileList}}"
          class="home-profile__back"
          bindtap="handleReturnToProfileList"
        >
          ← 返回档案列表
        </view>
      </view>
      <view class="home-profile__actions">
        <view class="home-settings-entry" bindtap="handleOpenUserSettings">⚙</view>
        <button class="home-profile__add" bindtap="handleCreateProfile">添加档案</button>
      </view>
    </view>

    <view class="card home-profile-detail">
      <view class="home-profile-detail__top">
        <view class="home-profile-detail__title">档案：{{profileDetail.title}}</view>
        <view wx:if="{{canEditCurrentProfile}}" class="home-profile-detail__edit" bindtap="handleEditProfile">⚙ 编辑档案</view>
      </view>

      <view wx:if="{{profileDetail.metaLine}}" class="home-profile-detail__meta">
        {{profileDetail.metaLine}}
      </view>

      <view wx:if="{{profileDetail.emergencyLine}}" class="home-profile-detail__contact">
        紧急联系人：{{profileDetail.emergencyLine}}
      </view>

      <view class="home-profile-detail__bottom">
        <view class="home-profile-detail__threshold">阈值：{{profileDetail.thresholdLine}}</view>
        <view wx:if="{{canManageCurrentProfile}}" class="home-profile-detail__adjust" bindtap="handleOpenThresholdEditor">📊 调整</view>
      </view>
    </view>

    <view wx:if="{{showProfileCompletionPrompt}}" class="card home-profile-tip">
      <view class="home-profile-tip__content">
        <view class="home-profile-tip__icon">i</view>
        <view class="home-profile-tip__text">
          <view class="home-profile-tip__title">完善档案信息，获得更准确的健康建议</view>
          <view class="home-profile-tip__link" bindtap="handleCompleteProfile">去完善 →</view>
        </view>
      </view>
      <view class="home-profile-tip__close" bindtap="handleDismissProfileCompletionPrompt">×</view>
    </view>

    <view wx:if="{{isLoadingLatestRecord}}" class="card home-record-card">
      <view class="home-profile__placeholder">正在读取最近一次血压...</view>
    </view>

    <view wx:elif="{{latestRecordError}}" class="card home-record-card">
      <view class="home-profile__placeholder">{{latestRecordError}}</view>
      <button class="btn-secondary home-profile__button" bindtap="loadLatestRecord">重试</button>
    </view>

    <view wx:elif="{{hasLatestRecord}}" class="card home-record-card home-record-card--{{latestRecordDisplay.statusLevel}}">
      <view class="home-record-card__top">
        <view class="home-record-card__label">最近一次</view>
        <bp-status-tag
          systolic="{{latestRecordDisplay.systolic}}"
          diastolic="{{latestRecordDisplay.diastolic}}"
          reference-lines="{{referenceLines}}"
        />
      </view>
      <view class="home-record-card__value {{latestRecordDisplay.statusClassName}}">
        {{latestRecordDisplay.systolic}} <text class="home-record-card__slash">/</text> {{latestRecordDisplay.diastolic}}
      </view>
      <view class="home-record-card__meta">
        {{latestRecordDisplay.measuredAtText}} · {{latestRecordDisplay.statusLabel}}
      </view>
      <view wx:if="{{latestRecordDisplay.heartRate}}" class="home-record-card__heart">
        心率 {{latestRecordDisplay.heartRate}} bpm
      </view>
      <button wx:if="{{canWriteCurrentProfile}}" class="btn-primary home-profile__button" bindtap="handleAddRecord">录入血压</button>
      <view class="home-record-card__link" bindtap="handleViewRecords">查看所有记录</view>
    </view>

    <view wx:else class="card home-record-card">
      <view class="home-profile__placeholder">{{canWriteCurrentProfile ? '还没有血压记录，先录入一条吧。' : '还没有血压记录'}}</view>
      <button wx:if="{{canWriteCurrentProfile}}" class="btn-primary home-profile__button" bindtap="handleAddRecord">录入血压</button>
      <view class="home-record-card__link" bindtap="handleViewRecords">查看所有记录</view>
    </view>

    <view class="card home-medication-card">
      <view class="home-medication-card__header">
        <view>
          <view class="home-medication-card__title">用药管理</view>
          <view class="home-medication-card__subtitle">长期用药会显示在这里</view>
        </view>
        <view wx:if="{{canWriteCurrentProfile}}" class="home-medication-card__add" bindtap="handleAddMedication">+ 添加用药</view>
      </view>

      <view wx:if="{{isLoadingMedications}}" class="home-medication-card__placeholder">正在读取用药...</view>

      <view wx:elif="{{medicationError}}" class="home-medication-card__error">
        <view>{{medicationError}}</view>
        <view class="home-medication-card__retry" bindtap="loadMedicationsForActiveProfile">重试</view>
      </view>

      <view wx:elif="{{!hasAnyMedications}}" class="home-medication-card__placeholder">
        TA 还没有长期用药
      </view>

      <view wx:else>
        <view wx:if="{{visibleActiveMedications.length > 0}}">
          <medication-item
            wx:for="{{visibleActiveMedications}}"
            wx:key="_id"
            medication="{{item}}"
            clickable="{{canWriteCurrentProfile}}"
            bind:tapitem="handleMedicationTap"
          />
        </view>

        <view
          wx:elif="{{hasHistoricalMedications && !isShowAllMedications}}"
          class="home-medication-card__placeholder"
        >
          当前没有正在服用的药物
        </view>

        <view
          wx:if="{{showMedicationExpandButton}}"
          class="home-medication-card__link"
          bindtap="handleViewAllMedications"
        >
          {{medicationExpandText}}
        </view>

        <view wx:if="{{isShowAllMedications && hasHistoricalMedications}}" class="home-medication-history">
          <view class="home-medication-history__toggle" bindtap="handleToggleHistoricalMedications">
            {{isShowHistoricalMedications ? '收起' : '展开'}}历史用药（{{historicalMedicationCount}}）
          </view>

          <view wx:if="{{isShowHistoricalMedications}}" class="home-medication-history__list">
            <medication-item
              wx:for="{{historicalMedications}}"
              wx:key="_id"
              medication="{{item}}"
              clickable="{{canWriteCurrentProfile}}"
              bind:tapitem="handleMedicationTap"
            />
          </view>
        </view>
      </view>
    </view>

    <view class="card home-report-card {{!hasLatestRecord && !isLoadingLatestRecord && !latestRecordError ? 'home-report-card--disabled' : ''}}" bindtap="handleOpenReport">
      <view>
        <view class="home-report-card__title">就诊报告</view>
        <view class="home-report-card__subtitle">查看血压心率趋势与异常汇总</view>
      </view>
      <view class="home-report-card__arrow">›</view>
    </view>

    <view class="home-danger-zone">
      <view class="home-danger-zone__toggle" bindtap="handleToggleDangerZone">
        ⚙ 高级设置 {{isDangerZoneExpanded ? '▲' : '▼'}}
      </view>

      <view wx:if="{{isDangerZoneExpanded}}" class="home-danger-zone__content">
        <view wx:for="{{advancedSettingsItems}}" wx:key="type">
          <view
            wx:if="{{!item.toggle}}"
            class="card home-danger-zone__item {{item.danger ? 'home-danger-zone__item--danger' : ''}}"
            data-type="{{item.type}}"
            bindtap="handleAdvancedSettingTap"
          >
            <view class="home-danger-zone__item-main">
              <view class="home-danger-zone__item-title {{item.danger ? 'home-danger-zone__item-title--danger' : ''}}">
                {{item.danger && item.type === 'delete' ? '⚠️ ' : ''}}{{item.label}}
              </view>
              <view class="home-danger-zone__item-text">{{item.desc}}</view>
            </view>
          </view>

          <view wx:else class="card home-danger-zone__item">
            <view class="home-danger-zone__item-main">
              <view class="home-danger-zone__item-title">{{item.label}}</view>
              <view class="home-danger-zone__item-text">{{item.desc}}</view>
            </view>
            <switch
              checked="{{item.checked}}"
              bindchange="handleToggleOwnSubscribeAlerts"
            />
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{isDeleteConfirmVisible}}" class="home-delete-modal">
      <view class="home-delete-modal__mask"></view>
      <view class="home-delete-modal__panel card">
        <view class="home-delete-modal__title">再次确认删除</view>
        <view class="home-delete-modal__text">{{deleteConfirmMessage}}</view>
        <input
          class="home-delete-modal__input"
          value="{{deleteConfirmInput}}"
          placeholder="请输入档案名"
          bindinput="onDeleteConfirmInput"
        />
        <view class="home-delete-modal__actions">
          <button class="btn-secondary home-delete-modal__button" bindtap="handleCancelDeleteProfile" disabled="{{isDeletingProfile}}">
            取消
          </button>
          <button
            class="btn-primary home-delete-modal__button home-delete-modal__button--danger"
            bindtap="handleConfirmDeleteProfile"
            loading="{{isDeletingProfile}}"
            disabled="{{!isDeleteConfirmReady || isDeletingProfile}}"
          >
            删除
          </button>
        </view>
      </view>
    </view>
  </view>
</view>
