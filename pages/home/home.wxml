<view class="page">
  <view wx:if="{{!isLoginReady}}" class="home-loading card">
    <view class="home-loading__title">正在加载档案</view>
    <view class="home-loading__text">请稍候...</view>
  </view>

  <view wx:elif="{{isLoginFailed}}" class="home-failed card">
    <view class="home-failed__title">暂时无法加载</view>
    <view class="home-failed__text">{{loginErrorText || '操作失败，请重试'}}</view>
    <button
      class="btn-primary home-failed__button"
      loading="{{isRetrying}}"
      disabled="{{isRetrying}}"
      bindtap="handleRetryLogin"
    >
      点击重试
    </button>
  </view>

  <empty-state
    wx:elif="{{isEmptyState}}"
    title="记录家人的血压，从第一条开始"
    subtitle="先建一个档案吧"
    buttonText="为家人或自己建档案"
    bind:buttontap="handleCreateProfile"
  />

  <view wx:elif="{{isMultiProfileList}}" class="home-profile-list">
    <view class="home-profile-list__header">
      <view>
        <view class="home-profile-list__title">关注的家人</view>
        <view class="home-profile-list__subtitle">一眼查看每个档案的最近血压</view>
      </view>
      <button class="home-profile-list__add" bindtap="handleCreateProfile">+</button>
    </view>

    <view class="home-profile-list__cards">
      <view
        wx:for="{{profileCards}}"
        wx:key="profile._id"
        class="profile-card card"
        data-profile-id="{{item.profile._id}}"
        bindtap="handleProfileCardTap"
      >
        <view class="profile-card__top">
          <view>
            <view class="profile-card__name">{{item.profile.name}}</view>
            <view class="profile-card__relation">{{item.relationText}}</view>
          </view>
          <view class="profile-card__arrow">›</view>
        </view>

        <view wx:if="{{item.isLoading}}" class="profile-card__empty">正在读取最近血压...</view>
        <view wx:elif="{{item.latestRecordError}}" class="profile-card__empty">{{item.latestRecordError}}</view>
        <view wx:elif="{{item.hasLatestRecord}}" class="profile-card__record">
          <view class="profile-card__bp {{item.latestRecordDisplay.statusClassName}}">
            {{item.latestRecordDisplay.systolic}} <text>/</text> {{item.latestRecordDisplay.diastolic}}
          </view>
          <bp-status-tag
            systolic="{{item.latestRecordDisplay.systolic}}"
            diastolic="{{item.latestRecordDisplay.diastolic}}"
            reference-lines="{{item.profile.settings.bp.referenceLines}}"
          />
          <view class="profile-card__time">{{item.latestRecordDisplay.measuredAtText}}</view>
        </view>
        <view wx:else class="profile-card__empty">还没有记录</view>
      </view>
    </view>
  </view>

  <view wx:else class="home-profile">
    <view class="home-profile__header">
      <view>
        <view
          wx:if="{{canReturnToProfileList}}"
          class="home-profile__back"
          bindtap="handleReturnToProfileList"
        >
          ← 返回档案列表
        </view>
        <view class="home-profile__eyebrow">当前档案</view>
        <view class="home-profile__title">已建档：{{activeProfile.name}}</view>
      </view>
      <button class="home-profile__add" bindtap="handleCreateProfile">添加档案</button>
    </view>

    <view wx:if="{{isLoadingLatestRecord}}" class="card home-record-card">
      <view class="home-profile__placeholder">正在读取最近一次血压...</view>
    </view>

    <view wx:elif="{{latestRecordError}}" class="card home-record-card">
      <view class="home-profile__placeholder">{{latestRecordError}}</view>
      <button class="btn-secondary home-profile__button" bindtap="loadLatestRecord">重试</button>
    </view>

    <view wx:elif="{{hasLatestRecord}}" class="card home-record-card home-record-card--{{latestRecordDisplay.statusLevel}}">
      <view class="home-record-card__top">
        <view class="home-record-card__label">最近一次</view>
        <bp-status-tag
          systolic="{{latestRecordDisplay.systolic}}"
          diastolic="{{latestRecordDisplay.diastolic}}"
          reference-lines="{{referenceLines}}"
        />
      </view>
      <view class="home-record-card__value {{latestRecordDisplay.statusClassName}}">
        {{latestRecordDisplay.systolic}} <text class="home-record-card__slash">/</text> {{latestRecordDisplay.diastolic}}
      </view>
      <view class="home-record-card__meta">
        {{latestRecordDisplay.measuredAtText}} · {{latestRecordDisplay.statusLabel}}
      </view>
      <view wx:if="{{latestRecordDisplay.heartRate}}" class="home-record-card__heart">
        心率 {{latestRecordDisplay.heartRate}} bpm
      </view>
      <button class="btn-primary home-profile__button" bindtap="handleAddRecord">录入血压</button>
      <view class="home-record-card__link" bindtap="handleViewRecords">查看所有记录</view>
    </view>

    <view wx:else class="card home-record-card">
      <view class="home-profile__placeholder">还没有血压记录，先录入一条吧。</view>
      <button class="btn-primary home-profile__button" bindtap="handleAddRecord">录入血压</button>
      <view class="home-record-card__link" bindtap="handleViewRecords">查看所有记录</view>
    </view>
  </view>
</view>
