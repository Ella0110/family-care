.home-loading,
.home-failed {
  margin-top: 32rpx;
}

.home-profile {
  margin-top: 8rpx;
}

.home-profile-list {
  margin-top: 8rpx;
}

.home-profile-list__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.home-profile-list__title {
  color: #111827;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.3;
}

.home-profile-list__subtitle {
  margin-top: 10rpx;
  color: #4b5563;
  font-size: 30rpx;
}

.home-profile-list__add {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  margin: 0;
  padding: 0;
  border-radius: 38rpx;
  background: #1d4ed8;
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.home-profile-list__add::after {
  border: 0;
}

.profile-card + .profile-card {
  margin-top: 24rpx;
}

.profile-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.profile-card__name {
  color: #111827;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.3;
}

.profile-card__relation {
  margin-top: 8rpx;
  color: #4b5563;
  font-size: 28rpx;
}

.profile-card__arrow {
  color: #9ca3af;
  font-size: 48rpx;
  line-height: 1;
}

.profile-card__record {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 18rpx;
  margin-top: 24rpx;
}

.profile-card__bp {
  color: #1f2937;
  font-size: 44rpx;
  font-weight: 800;
}

.profile-card__bp.is-high {
  color: #b42318;
}

.profile-card__bp.is-low {
  color: #c2410c;
}

.profile-card__time {
  grid-column: 1 / -1;
  color: #6b7280;
  font-size: 28rpx;
}

.profile-card__empty {
  margin-top: 24rpx;
  color: #6b7280;
  font-size: 30rpx;
}

.home-loading__title,
.home-failed__title,
.home-profile__title {
  color: #111827;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.35;
}

.home-loading__text,
.home-failed__text,
.home-profile__placeholder {
  margin-top: 16rpx;
  color: #4b5563;
  font-size: 32rpx;
  line-height: 1.55;
}

.home-failed__button,
.home-profile__button {
  margin-top: 40rpx;
}

.home-profile__eyebrow {
  margin-bottom: 12rpx;
  color: #1d4ed8;
  font-size: 28rpx;
  font-weight: 700;
}

.home-profile__back {
  display: inline-flex;
  align-items: center;
  min-height: 56rpx;
  margin-bottom: 18rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 28rpx;
  font-weight: 700;
}

.home-profile__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.home-profile__add {
  min-width: 144rpx;
  min-height: 64rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 64rpx;
}

.home-profile__add::after {
  border: 0;
}

.home-record-card {
  margin-top: 20rpx;
}

.home-medication-card {
  margin-top: 20rpx;
}

.home-profile-tip {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 20rpx;
  background: rgba(219, 234, 254, 0.6);
}

.home-profile-tip__content {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  flex: 1;
}

.home-profile-tip__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 28rpx;
  font-weight: 800;
}

.home-profile-tip__title {
  color: #1e3a8a;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
}

.home-profile-tip__link {
  margin-top: 12rpx;
  color: #1d4ed8;
  font-size: 28rpx;
  font-weight: 700;
}

.home-profile-tip__close {
  color: #6b7280;
  font-size: 34rpx;
  line-height: 1;
}

.home-record-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.home-record-card__label {
  color: #4b5563;
  font-size: 30rpx;
  font-weight: 700;
}

.home-record-card__value {
  margin-top: 24rpx;
  color: #1f2937;
  font-size: 76rpx;
  font-weight: 800;
  letter-spacing: -2rpx;
  line-height: 1.1;
}

.home-record-card__value.is-high {
  color: #b42318;
}

.home-record-card__value.is-low {
  color: #c2410c;
}

.home-record-card__slash {
  color: currentColor;
  font-size: 56rpx;
}

.home-record-card__meta {
  margin-top: 16rpx;
  color: #374151;
  font-size: 32rpx;
  font-weight: 600;
}

.home-record-card__heart {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.home-record-card__link {
  margin-top: 28rpx;
  color: #1d4ed8;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}

.home-medication-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.home-medication-card__title {
  color: #111827;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.35;
}

.home-medication-card__subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.home-medication-card__add {
  flex-shrink: 0;
  color: #1d4ed8;
  font-size: 28rpx;
  font-weight: 700;
}

.home-medication-card__placeholder,
.home-medication-card__error {
  margin-top: 24rpx;
  color: #4b5563;
  font-size: 30rpx;
  line-height: 1.6;
}

.home-medication-card__retry,
.home-medication-history__toggle,
.home-medication-card__link {
  color: #1d4ed8;
  font-size: 30rpx;
  font-weight: 700;
}

.home-medication-card__link {
  margin-top: 20rpx;
  text-align: center;
}

.home-medication-card__error .home-medication-card__retry {
  margin-top: 14rpx;
}

.home-medication-history {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e5e7eb;
}

.home-medication-history__list {
  margin-top: 12rpx;
}
