<view class="page page-root" style="--font-scale: {{fontScale}};">
  <view class="record-header">
    <view class="record-header__back" bindtap="handleCancel">返回</view>
    <view class="record-header__text">
      <view class="record-header__title">{{pageTitle}}</view>
      <view class="record-header__subtitle">{{pageSubtitle}}</view>
    </view>
  </view>

  <view class="record-profile-lock">
    <view class="record-profile-lock__label">档案</view>
    <view class="record-profile-lock__name">{{profileName}}</view>
    <view class="record-profile-lock__hint">不可修改</view>
  </view>

  <view wx:if="{{isLoadingRecord}}" class="card record-loading">
    正在读取记录...
  </view>

  <view class="card record-form">
    <view class="form-item">
      <view class="form-label">血压 <text class="form-required">*</text></view>
      <bp-input
        systolic="{{form.systolic}}"
        diastolic="{{form.diastolic}}"
        disabled="{{isSaving}}"
        bind:change="onBPChange"
      />
      <bp-status-tag
        wx:if="{{form.systolic && form.diastolic}}"
        systolic="{{form.systolic}}"
        diastolic="{{form.diastolic}}"
        reference-lines="{{referenceLines}}"
      />
    </view>

    <view class="form-item">
      <view class="form-label">心率</view>
      <view class="number-field">
        <input
          class="number-field__input"
          type="number"
          value="{{form.heartRate}}"
          placeholder="选填"
          placeholder-class="form-placeholder"
          disabled="{{isSaving}}"
          bindinput="onHeartRateInput"
        />
        <view class="number-field__unit">bpm</view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">测量时间 <text class="form-required">*</text></view>
      <view class="time-row">
        <picker
          mode="date"
          value="{{form.measuredDate}}"
          start="{{minMeasuredDate}}"
          end="{{maxMeasuredDate}}"
          bindchange="onMeasuredDateChange"
        >
          <view class="time-picker">{{form.measuredDate}}</view>
        </picker>
        <picker mode="time" value="{{form.measuredTime}}" bindchange="onMeasuredTimeChange">
          <view class="time-picker">{{form.measuredTime}}</view>
        </picker>
      </view>
      <view class="form-help">{{form.measuredDate}} {{form.measuredTime}}</view>
    </view>

    <view class="form-item">
      <view class="form-label">备注</view>
      <textarea
        class="form-textarea"
        value="{{form.note}}"
        maxlength="100"
        placeholder="可填写测量前状态、用药情况等"
        placeholder-class="form-placeholder"
        disabled="{{isSaving}}"
        bindinput="onNoteInput"
      />
      <view class="form-help">最多 100 个字</view>
    </view>
  </view>

  <view class="record-actions">
    <view wx:if="{{errorText}}" class="record-error">{{errorText}}</view>
    <button
      class="btn-primary record-button"
      loading="{{isSaving}}"
      disabled="{{isSaving || isDeleting || isLoadingRecord}}"
      bindtap="handleSave"
    >
      {{isEditMode ? '保存修改' : '保存'}}
    </button>
    <button
      wx:if="{{isEditMode && canDeleteRecord}}"
      class="record-delete-button"
      loading="{{isDeleting}}"
      disabled="{{isSaving || isDeleting || isLoadingRecord}}"
      bindtap="handleDelete"
    >
      删除
    </button>
    <button class="btn-secondary record-button" disabled="{{isSaving || isDeleting}}" bindtap="handleCancel">
      取消
    </button>
  </view>
</view>
