.record-header {
  position: sticky;
  top: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: -32rpx -32rpx 28rpx;
  padding: 28rpx 32rpx 24rpx;
  background: #f5f5f5;
}

.record-header__back {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 30rpx;
  font-weight: 700;
}

.record-header__text {
  flex: 1;
}

.record-header__title {
  color: #111827;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.3;
}

.record-header__subtitle {
  margin-top: 6rpx;
  color: #4b5563;
  font-size: 28rpx;
}

.record-form {
  padding: 36rpx 32rpx;
}

.record-profile-lock {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
  padding: 22rpx 28rpx;
  border-radius: 24rpx;
  background: #eaf2ff;
}

.record-profile-lock__label,
.record-profile-lock__hint {
  color: #4b5563;
  font-size: 28rpx;
}

.record-profile-lock__name {
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
}

.record-loading {
  margin-bottom: 24rpx;
  color: #4b5563;
  font-size: 30rpx;
}

.form-item + .form-item {
  margin-top: 38rpx;
}

.form-label {
  margin-bottom: 16rpx;
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
}

.form-required,
.record-error {
  color: #b42318;
}

.number-field {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  padding: 0 28rpx;
  border: 2rpx solid #bfdbfe;
  border-radius: 24rpx;
  background: #f8fbff;
}

.number-field__input {
  flex: 1;
  height: 88rpx;
  color: #111827;
  font-size: 42rpx;
  font-weight: 700;
}

.number-field__unit {
  color: #6b7280;
  font-size: 30rpx;
}

.time-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.time-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border: 2rpx solid #bfdbfe;
  border-radius: 24rpx;
  background: #f8fbff;
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
}

.form-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 180rpx;
  padding: 24rpx 28rpx;
  border: 2rpx solid #bfdbfe;
  border-radius: 24rpx;
  background: #f8fbff;
  color: #111827;
  font-size: 32rpx;
  line-height: 1.5;
}

.form-placeholder {
  color: #9ca3af;
}

.form-help {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.record-actions {
  padding: 32rpx 0;
}

.record-error {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #fee2e2;
  font-size: 30rpx;
  font-weight: 700;
}

.record-button + .record-button {
  margin-top: 20rpx;
}

.record-button::after {
  border: 0;
}

.record-delete-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  margin-top: 20rpx;
  padding: 0 32rpx;
  border-radius: 24rpx;
  background: #fee2e2;
  color: #b42318;
  font-size: 36rpx;
  font-weight: 800;
}

.record-delete-button::after {
  border: 0;
}
