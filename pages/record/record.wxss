.record-header {
  position: sticky;
  top: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: -32rpx -32rpx 28rpx;
  padding: 28rpx 32rpx 24rpx;
  background: #f5f5f5;
}

.record-feedback-layer,
.record-dialog-layer {
  position: fixed;
  inset: 0;
  z-index: 20;
}

.record-feedback-layer__mask,
.record-dialog-layer__mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.9);
}

.record-feedback-layer {
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-feedback-card {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  min-width: 360rpx;
  padding: 52rpx 48rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.16);
}

.record-feedback-card__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  background: #10b981;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 700;
}

.record-feedback-card__icon.is-danger {
  background: #ef4444;
}

.record-feedback-card__title {
  font-size: calc(36rpx * var(--font-scale));
  font-weight: 700;
  color: #1e293b;
}

.record-dialog {
  position: absolute;
  left: 48rpx;
  right: 48rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 48rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.16);
  box-sizing: border-box;
  text-align: center;
}

.record-dialog__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #fef2f2;
  font-size: 40rpx;
}

.record-dialog__title {
  font-size: calc(36rpx * var(--font-scale));
  font-weight: 700;
  color: #1e293b;
}

.record-dialog__subtitle {
  margin-top: 16rpx;
  font-size: calc(24rpx * var(--font-scale));
  line-height: 1.7;
  color: #94a3b8;
}

.record-dialog__confirm {
  margin-top: 32rpx;
  padding: 28rpx;
  border: none;
  border-radius: 24rpx;
  background: #ef4444;
  color: #ffffff;
  font-size: calc(30rpx * var(--font-scale));
  font-weight: 600;
  line-height: 1.2;
}

.record-dialog__cancel {
  margin-top: 24rpx;
  font-size: calc(28rpx * var(--font-scale));
  color: #94a3b8;
}

.record-header__back {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: calc(30rpx * var(--font-scale));
  font-weight: 700;
}

.record-header__text {
  flex: 1;
}

.record-header__title {
  color: #111827;
  font-size: calc(42rpx * var(--font-scale));
  font-weight: 800;
  line-height: 1.3;
}

.record-header__subtitle {
  margin-top: 6rpx;
  color: #4b5563;
  font-size: calc(28rpx * var(--font-scale));
}

.record-form {
  padding: 36rpx 32rpx;
}

.record-profile-lock {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
  padding: 22rpx 28rpx;
  border-radius: 24rpx;
  background: #eaf2ff;
}

.record-profile-lock__label,
.record-profile-lock__hint {
  color: #4b5563;
  font-size: calc(28rpx * var(--font-scale));
}

.record-profile-lock__name {
  color: #111827;
  font-size: calc(32rpx * var(--font-scale));
  font-weight: 800;
}

.record-loading {
  margin-bottom: 24rpx;
  color: #4b5563;
  font-size: calc(30rpx * var(--font-scale));
}

.form-item + .form-item {
  margin-top: 38rpx;
}

.form-label {
  margin-bottom: 16rpx;
  color: #111827;
  font-size: calc(34rpx * var(--font-scale));
  font-weight: 700;
}

.form-required,
.record-error {
  color: #b42318;
}

.number-field {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  padding: 0 28rpx;
  border: 2rpx solid #bfdbfe;
  border-radius: 24rpx;
  background: #f8fbff;
}

.number-field__input {
  flex: 1;
  height: 88rpx;
  color: #111827;
  font-size: calc(42rpx * var(--font-scale));
  font-weight: 700;
}

.number-field__unit {
  color: #6b7280;
  font-size: calc(30rpx * var(--font-scale));
}

.time-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.time-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border: 2rpx solid #bfdbfe;
  border-radius: 24rpx;
  background: #f8fbff;
  color: #111827;
  font-size: calc(34rpx * var(--font-scale));
  font-weight: 700;
}

.form-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 180rpx;
  padding: 24rpx 28rpx;
  border: 2rpx solid #bfdbfe;
  border-radius: 24rpx;
  background: #f8fbff;
  color: #111827;
  font-size: calc(32rpx * var(--font-scale));
  line-height: 1.5;
}

.form-placeholder {
  color: #9ca3af;
}

.form-help {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: calc(26rpx * var(--font-scale));
}

.record-actions {
  padding: 32rpx 0;
}

.record-error {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #fee2e2;
  font-size: calc(30rpx * var(--font-scale));
  font-weight: 700;
}

.record-button + .record-button {
  margin-top: 20rpx;
}

.record-button::after {
  border: 0;
}

.record-delete-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  margin-top: 20rpx;
  padding: 0 32rpx;
  border-radius: 24rpx;
  background: #fee2e2;
  color: #b42318;
  font-size: calc(36rpx * var(--font-scale));
  font-weight: 800;
}

.record-delete-button::after {
  border: 0;
}
