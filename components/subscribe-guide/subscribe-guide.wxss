.guide-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(15, 23, 42, 0.46);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
}
.guide-card {
    width: 620rpx;
    max-height: 85vh;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    padding: 52rpx 36rpx 36rpx;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: var(--shadow-float);
}
.guide-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 28rpx;
}
.title {
    font-size: 44rpx;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0;
    color: var(--text-primary);
}
.guide-body {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
}
.main-text {
    padding: 0;
    font-size: 32rpx;
    font-weight: 400;
    color: var(--text-primary);
    text-align: left;
    line-height: 1.65;
    margin-bottom: 32rpx;
}
.highlight {
    font-size: 32rpx;
    font-weight: 700;
    color: var(--text-primary);
}
.instruction-box {
    width: 100%;
    background: var(--bg-input);
    border-radius: var(--radius-md);
    padding: 24rpx 28rpx 20rpx;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    margin-bottom: 24rpx;
}
.inst-title {
    font-size: 26rpx;
    color: var(--text-tertiary);
    line-height: 1.5;
    margin-bottom: 10rpx;
}
.inst-item {
    font-size: 30rpx;
    font-weight: 400;
    color: var(--text-primary);
    line-height: 1.66;
}
.bold {
    font-weight: 700;
    color: var(--text-primary);
}
.warning-text {
    padding: 0 12rpx;
    font-size: 24rpx;
    color: var(--text-tertiary);
    text-align: center;
    line-height: 1.6;
    margin-bottom: 36rpx;
}
.guide-footer {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 16rpx;
}
.guide-btn-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    background: var(--color-primary);
    color: var(--text-on-primary);
    font-size: 34rpx;
    font-weight: 700;
    border-radius: var(--radius-md);
    padding: 26rpx 0;
    line-height: 1.1;
    text-align: center;
    box-shadow: var(--shadow-button);
}
.guide-btn-primary::after {
    border: none;
}
.guide-btn-primary:active {
    opacity: 0.8;
}
.guide-btn-secondary {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    background: transparent;
    color: var(--text-secondary);
    font-size: 30rpx;
    font-weight: 500;
    padding: 10rpx 0 2rpx;
    line-height: 1.2;
    border: none;
    box-shadow: none;
}
.guide-btn-secondary::after {
    border: none;
}
.guide-btn-secondary:active {
    opacity: 0.6;
}
