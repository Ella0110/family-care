.guide-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(15, 23, 42, 0.46);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
}
.guide-card {
    width: 620rpx;
    background: #ffffff;
    border-radius: 40rpx;
    padding: 52rpx 36rpx 36rpx;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 28rpx 80rpx rgba(15, 23, 42, 0.18);
}
.guide-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 28rpx;
}
.title {
    font-size: 44rpx;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0;
    color: #1c1c1e;
}
.guide-body {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
}
.main-text {
    padding: 0;
    font-size: 32rpx;
    font-weight: 400;
    color: #2f3640;
    text-align: left;
    line-height: 1.65;
    margin-bottom: 32rpx;
}
.highlight {
    font-size: 32rpx;
    font-weight: 700;
    color: #111827;
}
.instruction-box {
    width: 100%;
    background: #f6f7fc;
    border-radius: 28rpx;
    padding: 24rpx 28rpx 20rpx;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    margin-bottom: 24rpx;
}
.inst-title {
    font-size: 26rpx;
    color: #a0a7b4;
    line-height: 1.5;
    margin-bottom: 10rpx;
}
.inst-item {
    font-size: 30rpx;
    font-weight: 400;
    color: #2f3640;
    line-height: 1.66;
}
.bold {
    font-weight: 700;
    color: #111827;
}
.warning-text {
    padding: 0 12rpx;
    font-size: 24rpx;
    color: #9ba3af;
    text-align: center;
    line-height: 1.6;
    margin-bottom: 36rpx;
}
.guide-footer {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 16rpx;
}
.guide-btn-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    background: #007aff;
    color: #ffffff;
    font-size: 34rpx;
    font-weight: 700;
    border-radius: 28rpx;
    padding: 26rpx 0;
    line-height: 1.1;
    text-align: center;
    box-shadow: 0 16rpx 28rpx rgba(0, 122, 255, 0.22);
}
.guide-btn-primary::after {
    border: none;
}
.guide-btn-primary:active {
    opacity: 0.8;
}
.guide-btn-secondary {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    background: transparent;
    color: #8e8e93;
    font-size: 30rpx;
    font-weight: 500;
    padding: 10rpx 0 2rpx;
    line-height: 1.2;
    border: none;
    box-shadow: none;
}
.guide-btn-secondary::after {
    border: none;
}
.guide-btn-secondary:active {
    opacity: 0.6;
}
