.profile-switcher {
  position: fixed;
  inset: 0;
  z-index: 1200;
}

.profile-switcher__mask {
  position: absolute;
  inset: 0;
  background: rgba(17, 24, 39, 0.36);
}

.profile-switcher__sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 72vh;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  background: var(--bg-card);
  box-shadow: var(--shadow-float);
  box-sizing: border-box;
}

.profile-switcher__title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.35;
}

.profile-switcher__list {
  max-height: 46vh;
}

.profile-switcher__item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  border-bottom: 2rpx solid var(--border-light);
}

.profile-switcher__item--active .profile-switcher__item-name {
  color: var(--color-primary);
}

.profile-switcher__item-main {
  flex: 1;
  min-width: 0;
}

.profile-switcher__item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-switcher__item-relation {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.profile-switcher__item-mark {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: var(--radius-pill);
  background: rgba(0, 122, 255, 0.12);
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 600;
}

.profile-switcher__full-list-link {
  margin-top: 20rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.5;
}
