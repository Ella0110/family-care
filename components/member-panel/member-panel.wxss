.member-panel {
    position: fixed;
    inset: 0;
    z-index: 1300;
}

.member-panel__mask {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.5);
}

.member-panel__sheet {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 24rpx 40rpx calc(env(safe-area-inset-bottom) + 32rpx);
    border-radius: 40rpx 40rpx 0 0;
    background: #ffffff;
    box-sizing: border-box;
    box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.05);
    animation: member-panel-sheet-enter 0.32s ease-out;
}

.member-panel__grabber {
    width: 80rpx;
    height: 8rpx;
    margin: 0 auto 32rpx;
    border-radius: 999rpx;
    background: #e2e8f0;
}

.member-panel__hero {
    display: flex;
    align-items: center;
    gap: 24rpx;
    padding-bottom: 32rpx;
}

.member-panel__avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 96rpx;
    height: 96rpx;
    border-radius: 50%;
    background: #3182f7;
    color: #ffffff;
    font-size: 36rpx;
    font-weight: 800;
    flex-shrink: 0;
    overflow: hidden;
}

.member-panel__avatar--image {
    background: #dbeafe;
}

.member-panel__avatar-image {
    width: 100%;
    height: 100%;
}

.member-panel__hero-body {
    flex: 1;
    min-width: 0;
}

.member-panel__name {
    font-size: 30rpx;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.5;
}

.member-panel__role {
    margin-top: 8rpx;
    font-size: 22rpx;
    color: #94a3b8;
    line-height: 1.5;
}

.member-panel__section,
.member-panel__action-row {
    border-top: 1rpx solid #f1f5f9;
}

.member-panel__row,
.member-panel__action-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24rpx;
    min-height: 116rpx;
    padding: 28rpx 0;
}

.member-panel__divider {
    height: 1rpx;
    background: #f1f5f9;
}

.member-panel__row-main {
    flex: 1;
    min-width: 0;
}

.member-panel__row-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #1e293b;
    line-height: 1.5;
}

.member-panel__row-subtitle {
    margin-top: 8rpx;
    font-size: 22rpx;
    line-height: 1.5;
    color: #94a3b8;
}

.member-panel__arrow {
    font-size: 36rpx;
    color: #cbd5e1;
}

.member-panel__danger {
    margin-top: 16rpx;
    padding: 28rpx 0;
    text-align: center;
    font-size: 30rpx;
    font-weight: 600;
    color: #ef4444;
}

.member-panel__cancel {
    padding-top: 16rpx;
    text-align: center;
    font-size: 30rpx;
    color: #94a3b8;
}

.member-panel__overlay-layer {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
}

.member-panel__feedback-mask,
.member-panel__dialog-mask {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.5);
}

.member-panel__feedback-card,
.member-panel__dialog {
    position: relative;
    z-index: 1;
    width: 520rpx;
    max-width: calc(100vw - 80rpx);
    padding: 48rpx;
    border-radius: 32rpx;
    background: #ffffff;
    box-sizing: border-box;
    box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.16);
}

.member-panel__feedback-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24rpx;
    width: 400rpx;
    animation: member-panel-card-enter 220ms
        cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.member-panel__feedback-icon,
.member-panel__dialog-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 96rpx;
    height: 96rpx;
    margin: 0 auto;
    border-radius: 32rpx;
    background: #10b981;
    color: #ffffff;
    font-size: 48rpx;
    font-weight: 700;
}

.member-panel__dialog-icon {
    width: 80rpx;
    height: 80rpx;
    border-radius: 24rpx;
    margin-bottom: 24rpx;
    background: #fef2f2;
    color: #ef4444;
    font-size: 36rpx;
}

.member-panel__feedback-icon.is-danger,
.member-panel__dialog-icon.is-danger {
    background: #ef4444;
    color: #ffffff;
}

.member-panel__feedback-icon.is-primary,
.member-panel__dialog-icon.is-primary {
    background: #3182f7;
    color: #ffffff;
}

.member-panel__dialog-icon.is-primary {
    background: #eff6ff;
    color: #3182f7;
}

.member-panel__feedback-title,
.member-panel__dialog-title {
    text-align: center;
    font-size: 36rpx;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.35;
}

.member-panel__dialog-subtitle {
    margin-top: 16rpx;
    text-align: center;
    font-size: 24rpx;
    line-height: 1.6;
    color: #94a3b8;
}

.member-panel__dialog-confirm {
    width: 100%;
    margin-top: 40rpx;
    min-height: 96rpx;
    padding: 24rpx 32rpx;
    border: none;
    border-radius: 24rpx;
    background: #ef4444;
    color: #ffffff;
    font-size: 32rpx;
    font-weight: 600;
    line-height: 1.4;
    box-sizing: border-box;
}

.member-panel__dialog-confirm.is-primary {
    background: #3182f7;
}

.member-panel__dialog-confirm::after {
    border: none;
}

.member-panel__dialog-cancel {
    margin-top: 24rpx;
    text-align: center;
    font-size: 30rpx;
    color: #94a3b8;
}

@keyframes member-panel-sheet-enter {
    from {
        transform: translateY(100%);
    }

    to {
        transform: translateY(0);
    }
}

@keyframes member-panel-card-enter {
    from {
        opacity: 0;
        transform: scale(0.9);
    }

    to {
        opacity: 1;
        transform: scale(1);
    }
}
