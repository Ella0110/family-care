.bp-status-tag {
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.bp-status-tag--low {
  background: #eff6ff;
  color: #007aff;
}

.bp-status-tag--normal {
  background: #f0fff4;
  color: #34c759;
}

.bp-status-tag--elevated {
  background: #fff9eb;
  color: #f5a623;
}

.bp-status-tag--stage1 {
  background: #fff4eb;
  color: #ff9500;
}

.bp-status-tag--stage2,
.bp-status-tag--stage3,
.bp-status-tag--high {
  background: #fff0f0;
  color: #ff3b30;
}

.bp-status-tag__detail {
  margin-left: 8rpx;
}
