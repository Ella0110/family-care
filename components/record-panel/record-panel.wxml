<view wx:if="{{show}}" class="record-panel">
  <view class="record-panel__mask" bindtap="handleMaskTap"></view>

  <view wx:if="{{feedbackToastVisible}}" class="record-panel__overlay-layer">
    <view class="record-panel__overlay-mask"></view>
    <view class="record-panel__feedback-card">
      <view class="record-panel__feedback-icon {{feedbackToastTone === 'danger' ? 'is-danger' : ''}}">
        {{feedbackToastIconText}}
      </view>
      <view class="record-panel__feedback-title">{{feedbackToastTitle}}</view>
    </view>
  </view>

  <view wx:if="{{showDeleteConfirm}}" class="record-panel__overlay-layer">
    <view class="record-panel__overlay-mask" bindtap="handleDeleteDialogMaskTap"></view>
    <view class="record-panel__dialog" catchtap="noop">
      <view class="record-panel__dialog-icon">🗑</view>
      <view class="record-panel__dialog-title">确定删除此记录？</view>
      <view class="record-panel__dialog-subtitle">删除后数据将无法恢复，并会影响您的健康趋势分析。</view>
      <button
        class="record-panel__dialog-confirm"
        bindtap="handleDeleteConfirm"
        loading="{{isDeleting}}"
        disabled="{{isDeleting}}"
      >
        确定删除
      </button>
      <view class="record-panel__dialog-cancel" bindtap="handleDeleteCancel">取消</view>
    </view>
  </view>

  <view class="record-panel__sheet" catchtap="noop">
    <view class="record-panel__grabber"></view>

    <view class="record-panel__header">
      <view class="record-panel__title">{{panelTitle}}</view>
      <view class="record-panel__close" bindtap="handleClose">×</view>
    </view>

    <view class="record-panel__metrics">
      <view
        class="record-panel__metric {{activeField !== 'systolic' ? 'record-panel__metric--inactive' : ''}} {{shakingFields.systolic ? 'error-shake' : ''}}"
        data-field="systolic"
        bindtap="handleFieldTap"
      >
        <view class="record-panel__metric-label {{activeField === 'systolic' ? 'is-active' : ''}} {{fieldErrors.systolic ? 'is-error' : ''}}">收缩压</view>
        <view class="record-panel__metric-value {{!form.systolic ? 'is-placeholder' : ''}} {{fieldErrors.systolic ? 'is-error' : ''}} {{!fieldErrors.systolic && alertFields.systolic ? 'is-alert' : ''}}">
          {{form.systolic || '--'}}
        </view>
        <view wx:if="{{activeField === 'systolic'}}" class="record-panel__metric-line"></view>
      </view>

      <view
        class="record-panel__metric {{activeField !== 'diastolic' ? 'record-panel__metric--inactive' : ''}} {{shakingFields.diastolic ? 'error-shake' : ''}}"
        data-field="diastolic"
        bindtap="handleFieldTap"
      >
        <view class="record-panel__metric-label {{activeField === 'diastolic' ? 'is-active' : ''}} {{fieldErrors.diastolic ? 'is-error' : ''}}">舒张压</view>
        <view class="record-panel__metric-value {{!form.diastolic ? 'is-placeholder' : ''}} {{fieldErrors.diastolic ? 'is-error' : ''}} {{!fieldErrors.diastolic && alertFields.diastolic ? 'is-alert' : ''}}">
          {{form.diastolic || '--'}}
        </view>
        <view wx:if="{{activeField === 'diastolic'}}" class="record-panel__metric-line"></view>
      </view>

      <view
        class="record-panel__metric {{activeField !== 'heartRate' ? 'record-panel__metric--inactive' : ''}} {{shakingFields.heartRate ? 'error-shake' : ''}}"
        data-field="heartRate"
        bindtap="handleFieldTap"
      >
        <view class="record-panel__metric-label {{activeField === 'heartRate' ? 'is-active' : ''}} {{fieldErrors.heartRate ? 'is-error' : ''}}">心率</view>
        <view class="record-panel__metric-value {{!form.heartRate ? 'is-placeholder' : ''}} {{fieldErrors.heartRate ? 'is-error' : ''}}">
          {{form.heartRate || '--'}}
        </view>
        <view wx:if="{{activeField === 'heartRate'}}" class="record-panel__metric-line"></view>
      </view>
    </view>

    <view class="record-panel__time-row {{fieldErrors.measuredAt ? 'is-error' : ''}}">
      <view class="record-panel__time-label">测量时间</view>
      <view class="record-panel__time-actions">
        <picker
          mode="date"
          value="{{form.measuredDate}}"
          start="{{minMeasuredDate}}"
          end="{{maxMeasuredDate}}"
          bindchange="onMeasuredDateChange"
        >
          <view class="record-panel__time-value {{fieldErrors.measuredAt ? 'is-error' : ''}}">
            {{measuredDateLabel}}
          </view>
        </picker>
        <picker
          mode="time"
          value="{{form.measuredTime}}"
          bindchange="onMeasuredTimeChange"
        >
          <view class="record-panel__time-value {{fieldErrors.measuredAt ? 'is-error' : ''}}">
            {{form.measuredTime}}
          </view>
        </picker>
        <text class="record-panel__time-arrow">></text>
      </view>
    </view>

    <view wx:if="{{errorText}}" class="record-panel__error-banner">
      <text class="record-panel__error-icon">!</text>
      <text class="record-panel__error-text">{{errorText}}</text>
    </view>

    <view class="record-panel__keypad">
      <view
        wx:for="{{keypadKeys}}"
        wx:key="value"
        class="record-panel__key {{item.action !== 'digit' ? 'record-panel__key--action' : ''}}"
        data-action="{{item.action}}"
        data-value="{{item.value}}"
        bindtap="handleKeyTap"
      >
        {{item.label}}
      </view>
    </view>

    <view class="record-panel__actions">
      <button
        class="record-panel__save"
        bindtap="handleSave"
        loading="{{isSaving}}"
        disabled="{{isSaving || isDeleting || feedbackToastVisible || showDeleteConfirm}}"
      >
        {{saveButtonText}}
      </button>

      <view
        wx:if="{{isEditMode}}"
        class="record-panel__delete"
        bindtap="handleDelete"
      >
        删除记录
      </view>
    </view>
  </view>
</view>
