.record-panel {
    position: fixed;
    inset: 0;
    z-index: 1300;
}

.record-panel__mask {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.5);
}

.record-panel__sheet {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    min-height: 76vh;
    max-height: 82vh;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    background: var(--bg-card);
    box-sizing: border-box;
    box-shadow: var(--shadow-sheet);
    overflow-y: auto;
    animation: record-panel-sheet-enter 0.4s ease-out;
}

.record-panel__grabber {
    width: 80rpx;
    height: 8rpx;
    margin: 0 auto 24rpx;
    border-radius: var(--radius-pill);
    background: var(--border-light);
}

.record-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16rpx;
}

.record-panel__title {
    font-size: 36rpx;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.35;
    min-width: 0;
}

.record-panel__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64rpx;
    height: 64rpx;
    border-radius: var(--radius-full);
    background: var(--bg-input);
    color: var(--text-secondary);
    font-size: 36rpx;
    line-height: 1;
    flex-shrink: 0;
}

.record-panel__metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
}

.record-panel__metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: all 0.3s ease;
}

.record-panel__metric--inactive {
    opacity: 0.4;
}

.record-panel__metric-label {
    font-size: 22rpx;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
}

.record-panel__metric-label.is-active {
    color: var(--color-primary);
}

.record-panel__metric-label.is-error {
    color: var(--color-danger);
}

.record-panel__metric-value {
    margin-top: 16rpx;
    min-height: 92rpx;
    font-size: 80rpx;
    line-height: 1.1;
    font-weight: 900;
    color: var(--text-primary);
    white-space: nowrap;
}

.record-panel__metric-value.is-placeholder {
    color: var(--text-tertiary);
}

.record-panel__metric-value.is-error {
    color: var(--color-danger);
}

.record-panel__metric-line {
    width: 60rpx;
    height: 6rpx;
    margin-top: 12rpx;
    border-radius: 3rpx;
    background: var(--color-primary);
}

.record-panel__time-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16rpx;
    border-radius: var(--radius-md);
    background: var(--bg-input);
}

.record-panel__time-row.is-error {
    background: var(--bg-danger-light);
}

.record-panel__time-label {
    font-size: 30rpx;
    font-weight: 600;
    color: var(--text-secondary);
    line-height: 1.5;
    flex-shrink: 0;
}

.record-panel__time-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    min-width: 0;
}

.record-panel__time-value {
    font-size: 30rpx;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.5;
    white-space: nowrap;
}

.record-panel__time-value.is-error {
    color: var(--color-danger);
}

.record-panel__time-arrow {
    color: var(--text-tertiary);
    font-size: 30rpx;
    flex-shrink: 0;
}

.record-panel__error-banner {
    display: flex;
    align-items: center;
    border-radius: var(--radius-sm);
    background: var(--bg-danger-light);
}

.record-panel__error-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36rpx;
    height: 36rpx;
    border-radius: var(--radius-full);
    background: rgba(255, 59, 48, 0.12);
    color: var(--color-danger);
    font-size: 24rpx;
    font-weight: 700;
}

.record-panel__error-text {
    flex: 1;
    font-size: 24rpx;
    line-height: 1.5;
    color: var(--color-danger);
}

.record-panel__keypad {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
}

.record-panel__key {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100rpx;
    padding: 20rpx;
    border-radius: var(--radius-md);
    background: var(--bg-card);
    box-shadow: var(--shadow-card);
    color: var(--text-primary);
    font-size: 36rpx;
    font-weight: 700;
    transition: transform 0.1s ease;
    box-sizing: border-box;
}

.record-panel__key:active {
    transform: scale(0.96);
}

.record-panel__key--action {
    background: var(--bg-input);
    box-shadow: none;
    color: var(--text-secondary);
    font-size: 30rpx;
    font-weight: 600;
}

.record-panel__key--backspace {
    padding: 18rpx;
}

.record-panel__backspace-icon {
    width: 64rpx;
    height: 48rpx;
    font-weight: 900;
}

.record-panel__save {
    width: 100%;
    min-height: 96rpx;
    padding: 24rpx 32rpx;
    border: none;
    border-radius: var(--radius-md);
    background: var(--color-primary);
    color: var(--text-on-primary);
    font-size: 32rpx;
    font-weight: 700;
    line-height: 1.4;
    box-shadow: var(--shadow-button);
    box-sizing: border-box;
}

.record-panel__save::after {
    border: none;
}

.record-panel__save:active {
    transform: scale(0.98);
}

.record-panel__delete {
    text-align: center;
    font-size: 30rpx;
    font-weight: 600;
    color: var(--color-danger);
}

.record-panel__overlay-layer {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
}

.record-panel__feedback-mask,
.record-panel__dialog-mask {
    position: absolute;
    inset: 0;
}

.record-panel__feedback-mask {
    background: rgba(15, 23, 42, 0.9);
}

.record-panel__dialog-mask {
    background: rgba(15, 23, 42, 0.9);
}

.record-panel__feedback-card {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24rpx;
    min-width: 360rpx;
    padding: 52rpx 48rpx;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-float);
    animation: record-panel-feedback-enter 220ms
        cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.record-panel__feedback-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 96rpx;
    height: 96rpx;
    border-radius: var(--radius-lg);
    background: var(--color-success);
    color: var(--text-on-primary);
    font-size: 48rpx;
    font-weight: 700;
}

.record-panel__feedback-icon.is-danger {
    background: var(--color-danger);
}

.record-panel__feedback-title {
    font-size: 36rpx;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.35;
}

.record-panel__dialog {
    position: relative;
    z-index: 1;
    width: calc(100% - 96rpx);
    padding: 48rpx;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-sizing: border-box;
    text-align: center;
    box-shadow: var(--shadow-float);
    animation: record-panel-dialog-enter 220ms ease-out;
}

.record-panel__dialog-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 80rpx;
    height: 80rpx;
    margin-bottom: 24rpx;
    border-radius: var(--radius-full);
    background: var(--bg-danger-light);
    font-size: 36rpx;
}

.record-panel__dialog-title {
    font-size: 36rpx;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.35;
}

.record-panel__dialog-subtitle {
    margin-top: 16rpx;
    font-size: 24rpx;
    line-height: 1.7;
    color: var(--text-secondary);
}

.record-panel__dialog-confirm {
    margin-top: 32rpx;
    min-height: 96rpx;
    padding: 24rpx 32rpx;
    border: none;
    border-radius: var(--radius-md);
    background: var(--color-danger);
    color: var(--text-on-primary);
    font-size: 32rpx;
    font-weight: 600;
    line-height: 1.4;
    box-sizing: border-box;
}

.record-panel__dialog-confirm::after {
    border: none;
}

.record-panel__dialog-cancel {
    margin-top: 24rpx;
    font-size: 30rpx;
    color: var(--text-secondary);
}

.error-shake {
    animation: record-panel-shake 360ms ease-in-out;
}

@keyframes record-panel-shake {
    0%,
    100% {
        transform: translateX(0);
    }

    20%,
    60% {
        transform: translateX(-8rpx);
    }

    40%,
    80% {
        transform: translateX(8rpx);
    }
}

@keyframes record-panel-feedback-enter {
    from {
        opacity: 0;
        transform: scale(0.8);
    }

    to {
        opacity: 1;
        transform: scale(1);
    }
}

@keyframes record-panel-dialog-enter {
    from {
        opacity: 0;
        transform: scale(0.9);
    }

    to {
        opacity: 1;
        transform: scale(1);
    }
}

@keyframes record-panel-sheet-enter {
    from {
        transform: translateY(100%);
    }

    to {
        transform: translateY(0);
    }
}
