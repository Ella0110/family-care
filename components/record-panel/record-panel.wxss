.record-panel {
  position: fixed;
  inset: 0;
  z-index: 1300;
}

.record-panel__mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.4);
}

.record-panel__sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  min-height: 60vh;
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 -16rpx 48rpx rgba(17, 24, 39, 0.16);
}

.record-panel__grabber {
  width: 88rpx;
  height: 8rpx;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: #d1d5db;
}

.record-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.record-panel__title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text);
}

.record-panel__close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f3f4f6;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 56rpx;
  font-size: var(--font-xl);
}

.record-panel__field {
  margin-top: 24rpx;
}

.record-panel__label {
  margin-bottom: 14rpx;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.record-panel__label.is-error,
.record-panel__metric-label.is-error {
  color: #ef4444;
}

.record-panel__datetime {
  display: flex;
  gap: 16rpx;
}

.record-panel__datetime-item,
.record-panel__input {
  box-sizing: border-box;
  border-radius: 20rpx;
  border: 2rpx solid #e5e7eb;
  background: #f9fafb;
  color: var(--color-text);
}

.record-panel__datetime-item {
  min-width: 220rpx;
  padding: 22rpx 24rpx;
  font-size: var(--font-base);
}

.record-panel__datetime-item.is-error,
.record-panel__input.is-error {
  border-color: #ef4444;
  background: #fff5f5;
}

.record-panel__measurements {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.record-panel__metric {
  flex: 1;
}

.record-panel__metric--heart-rate {
  max-width: 180rpx;
}

.record-panel__metric-label {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.record-panel__input {
  width: 100%;
  min-height: 96rpx;
  padding: 0 24rpx;
  font-size: var(--font-lg);
  text-align: center;
}

.record-panel__slash {
  padding-bottom: 24rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-xl);
  font-weight: 600;
}

.record-panel__error-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #fef2f2;
  color: #ef4444;
}

.record-panel__error-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(239, 68, 68, 0.12);
  font-size: 24rpx;
  font-weight: 700;
}

.record-panel__error-text {
  flex: 1;
  font-size: var(--font-sm);
  line-height: 1.6;
}

.record-panel__save {
  margin-top: 28rpx;
}

.record-panel__delete {
  margin-top: 18rpx;
  padding: 12rpx 0;
  border: none;
  background: transparent;
  color: #ef4444;
  font-size: var(--font-base);
  line-height: 1.6;
}

.record-panel__feedback-layer,
.record-panel__dialog-layer {
  position: absolute;
  inset: 0;
  z-index: 2;
}

.record-panel__feedback-backdrop,
.record-panel__dialog-mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
}

.record-panel__feedback-layer {
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-panel__feedback-card {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  min-width: 360rpx;
  padding: 52rpx 48rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.16);
  animation: record-panel-feedback-enter 220ms cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.record-panel__feedback-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  background: #10b981;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 700;
}

.record-panel__feedback-icon.is-danger {
  background: #ef4444;
}

.record-panel__feedback-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.record-panel__dialog {
  position: absolute;
  left: 48rpx;
  right: 48rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 48rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.16);
  box-sizing: border-box;
  text-align: center;
  animation: record-panel-dialog-enter 220ms ease-out;
}

.record-panel__dialog-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #fef2f2;
  font-size: 40rpx;
}

.record-panel__dialog-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.record-panel__dialog-subtitle {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #94a3b8;
}

.record-panel__dialog-confirm {
  margin-top: 32rpx;
  padding: 28rpx;
  border: none;
  border-radius: 24rpx;
  background: #ef4444;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.2;
}

.record-panel__dialog-cancel {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #94a3b8;
}

.error-shake {
  animation: record-panel-shake 360ms ease-in-out;
}

@keyframes record-panel-shake {
  0%,
  100% {
    transform: translateX(0);
  }

  20%,
  60% {
    transform: translateX(-8rpx);
  }

  40%,
  80% {
    transform: translateX(8rpx);
  }
}

@keyframes record-panel-feedback-enter {
  from {
    opacity: 0;
    transform: scale(0.8);
  }

  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes record-panel-dialog-enter {
  from {
    opacity: 0;
    transform: translateY(-50%) scale(0.9);
  }

  to {
    opacity: 1;
    transform: translateY(-50%) scale(1);
  }
}
