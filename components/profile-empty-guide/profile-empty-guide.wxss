.profile-empty-guide {
  display: flex;
  justify-content: center;
}

.profile-empty-guide__card {
  box-sizing: border-box;
  width: 100%;
  padding: 80rpx 48rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 8px 32px rgba(49, 130, 247, 0.08);
  text-align: center;
}

.profile-empty-guide__title {
  color: #0f172a;
  font-size: calc(36rpx * var(--font-scale));
  font-weight: 700;
  line-height: 1.4;
}

.profile-empty-guide__subtitle {
  margin-top: 20rpx;
  color: #94a3b8;
  font-size: calc(28rpx * var(--font-scale));
  line-height: 1.6;
}

.profile-empty-guide__button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin-top: 48rpx;
  border-radius: 24rpx;
  background: #3478f6;
  box-shadow: 0 8px 24px rgba(49, 130, 247, 0.3);
  color: #ffffff;
  font-size: calc(32rpx * var(--font-scale));
  font-weight: 700;
  line-height: 1.2;
}

.profile-empty-guide__button::after {
  border: 0;
}

.profile-empty-guide__button--hover {
  background: #2467ee;
}
