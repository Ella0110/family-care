.bp-input {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 18rpx;
  position: relative;
  padding-bottom: 48rpx;
}

.bp-input__field {
  box-sizing: border-box;
  min-height: 156rpx;
  padding: 22rpx 18rpx 16rpx;
  border: 3rpx solid #bfdbfe;
  border-radius: 28rpx;
  background: #f8fbff;
}

.bp-input__field--focus {
  border-color: #1d4ed8;
  box-shadow: 0 0 0 6rpx rgba(29, 78, 216, 0.12);
}

.bp-input__control {
  height: 72rpx;
  color: #111827;
  font-size: 56rpx;
  font-weight: 800;
  line-height: 72rpx;
  text-align: center;
}

.bp-input__placeholder {
  color: #9ca3af;
  font-size: 40rpx;
  font-weight: 600;
}

.bp-input__label {
  margin-top: 8rpx;
  color: #4b5563;
  font-size: 26rpx;
  text-align: center;
}

.bp-input__slash {
  color: #1d4ed8;
  font-size: 56rpx;
  font-weight: 800;
}

.bp-input__unit {
  position: absolute;
  right: 4rpx;
  bottom: 0;
  color: #6b7280;
  font-size: 28rpx;
}
